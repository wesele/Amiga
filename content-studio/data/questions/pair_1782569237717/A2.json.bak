        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Bookshelf Background Left -->\n  <line x1=\"20\" y1=\"230\" x2=\"130\" y2=\"230\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"20\" y1=\"140\" x2=\"130\" y2=\"140\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Books on shelf 1 (bottom shelf) -->\n  <rect x=\"35\" y=\"190\" width=\"16\" height=\"40\" rx=\"2\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"56\" y=\"180\" width=\"20\" height=\"50\" rx=\"2\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"81\" y=\"195\" width=\"14\" height=\"35\" rx=\"2\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Books and plant on shelf 2 (top shelf) -->\n  <rect x=\"30\" y=\"105\" width=\"15\" height=\"35\" rx=\"2\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"50\" y=\"95\" width=\"18\" height=\"45\" rx=\"2\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Plant Pot -->\n  <path d=\"M82 125 L102 125 L99 140 L85 140 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"87\" cy=\"119\" r=\"6\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"97\" cy=\"119\" r=\"6\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Light Cone from Lamp -->\n  <polygon points=\"287,197 90,370 380,370\" fill=\"#FFC107\"/>\n\n  <!-- Ground Line -->\n  <line x1=\"20\" y1=\"370\" x2=\"380\" y2=\"370\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Chair Legs -->\n  <line x1=\"140\" y1=\"300\" x2=\"130\" y2=\"370\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <line x1=\"200\" y1=\"300\" x2=\"210\" y2=\"370\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <line x1=\"135\" y1=\"200\" x2=\"135\" y2=\"300\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n\n  <!-- Desk -->\n  <rect x=\"310\" y=\"300\" width=\"50\" height=\"35\" rx=\"3\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"250\" y1=\"300\" x2=\"370\" y2=\"300\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <line x1=\"335\" y1=\"335\" x2=\"335\" y2=\"370\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <circle cx=\"335\" cy=\"318\" r=\"4\" fill=\"#333333\"/>\n\n  <!-- Chair Cushions -->\n  <rect x=\"138\" y=\"210\" width=\"12\" height=\"80\" rx=\"5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"135\" y=\"285\" width=\"80\" height=\"15\" rx=\"5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Person: Legs -->\n  <rect x=\"150\" y=\"275\" width=\"80\" height=\"22\" rx=\"8\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"210\" y=\"285\" width=\"20\" height=\"65\" rx=\"8\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M210 350 L235 350 C240 350 240 362 230 362 L210 362 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Person: Torso & Head -->\n  <rect x=\"172\" y=\"180\" width=\"14\" height=\"20\" rx=\"3\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M152 205 L200 205 C212 205 215 235 210 278 L152 278 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"180\" cy=\"160\" r=\"24\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"162\" cy=\"164\" r=\"5\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M160 166 C152 140 170 128 190 133 C204 137 206 150 202 163 C193 158 189 160 183 156 C174 152 168 166 160 166 Z\" fill=\"#333333\"/>\n  \n  <!-- Face details (Calm/Relaxed expression) -->\n  <path d=\"M184 158 Q190 163 194 158\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M182 170 Q188 175 192 169\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Arms & Book -->\n  <!-- Left Hand (Background) -->\n  <circle cx=\"260\" cy=\"245\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Arm Outline & Sleeve -->\n  <path d=\"M190 220 L210 255 L235 240\" fill=\"none\" stroke=\"#333333\" stroke-width=\"20\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M190 220 L210 255 L235 240\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <!-- Book Cover -->\n  <path d=\"M212 227 L235 210 L270 215 L288 235 L265 251 L250 232 L230 246 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Book Pages -->\n  <path d=\"M217 225 L235 212 L248 228 L230 241 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M252 228 L268 217 L283 233 L267 246 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Right Hand (Foreground) -->\n  <circle cx=\"230\" cy=\"242\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"268\" cy=\"246\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Lamp (Sitting on desk) -->\n  <path d=\"M310 300 A15 15 0 0 1 340 300 Z\" fill=\"#333333\"/>\n  <path d=\"M325 285 L325 200 L295 185\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M282 192 L302 172 L312 182 L292 202 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n</svg>",
