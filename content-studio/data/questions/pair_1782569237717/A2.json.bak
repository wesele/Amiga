      {
        "desc": "一群观众坐在电影院观看喜剧电影，银幕上有卡通人物，紫色调",
        "prompt": "audience sitting in a cinema watching a comedy film, cartoon characters on screen, purple color scheme, dark theater interior",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Main Theater Backdrop (Purple-toned) -->\n  <rect x=\"30\" y=\"30\" width=\"340\" height=\"340\" rx=\"24\" fill=\"#2B1A4A\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Cinema Screen Frame -->\n  <rect x=\"56\" y=\"50\" width=\"288\" height=\"130\" rx=\"10\" fill=\"#333333\"/>\n  <!-- Glowing Cinema Screen -->\n  <rect x=\"68\" y=\"60\" width=\"264\" height=\"110\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Screen Content: Cartoon Characters (Comedy Movie) -->\n  <!-- Blue Character (Left) -->\n  <rect x=\"105\" y=\"90\" width=\"45\" height=\"55\" rx=\"10\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"118\" cy=\"105\" r=\"9\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"137\" cy=\"105\" r=\"9\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"120\" cy=\"105\" r=\"3\" fill=\"#333333\"/>\n  <circle cx=\"135\" cy=\"103\" r=\"3\" fill=\"#333333\"/>\n  <path d=\"M115 125 Q127.5 135 140 125\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M105 110 Q95 100 98 90\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M150 110 Q160 100 157 90\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Red Character (Right - Tilted/Falling Over) -->\n  <g transform=\"rotate(20 220 115)\">\n    <circle cx=\"220\" cy=\"115\" r=\"20\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <circle cx=\"220\" cy=\"110\" r=\"9\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <circle cx=\"220\" cy=\"110\" r=\"4\" fill=\"#333333\"/>\n    <ellipse cx=\"220\" cy=\"125\" rx=\"8\" ry=\"4\" fill=\"#333333\"/>\n  </g>\n\n  <!-- Fun Screen Details (Stars) -->\n  <path d=\"M175 75 L177 80 L182 82 L177 84 L175 89 L173 84 L168 82 L173 80 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n  <path d=\"M265 85 L267 90 L272 92 L267 94 L265 99 L263 94 L258 92 L263 90 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Screen Light Beam / Glow -->\n  <polygon points=\"68,170 332,170 345,350 55,350\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Highlight Rays -->\n  <polygon points=\"100,170 140,170 180,350 110,350\" fill=\"#FFC107\"/>\n  <polygon points=\"260,170 300,170 290,350 220,350\" fill=\"#FFC107\"/>\n\n  <!-- Row 2 Audience & Seats (Background Row) -->\n  <!-- Left Seat (2A) -->\n  <circle cx=\"100\" cy=\"205\" r=\"18\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"86\" cy=\"195\" r=\"8\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"114\" cy=\"195\" r=\"8\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"70\" y=\"215\" width=\"60\" height=\"60\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Middle Seat (2B) -->\n  <circle cx=\"200\" cy=\"200\" r=\"18\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"200\" cy=\"180\" r=\"7\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"170\" y=\"215\" width=\"60\" height=\"60\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Right Seat (2C) -->\n  <circle cx=\"300\" cy=\"205\" r=\"18\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"290\" cy=\"188\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"300\" cy=\"185\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"310\" cy=\"188\" r=\"5\" fill=\"#333333\"/>\n  <rect x=\"270\" y=\"215\" width=\"60\" height=\"60\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Row 1 Audience & Seats (Foreground Row - Larger & Laughing) -->\n  <!-- Left Foreground Seat (1A) -->\n  <path d=\"M95 290 L175 290 L165 248 L105 248 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"135\" cy=\"235\" rx=\"22\" ry=\"24\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" transform=\"rotate(12 135 235)\"/>\n  <rect x=\"90\" y=\"270\" width=\"90\" height=\"85\" rx=\"12\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"90\" y1=\"300\" x2=\"180\" y2=\"300\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"90\" y1=\"328\" x2=\"180\" y2=\"328\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Right Foreground Seat (1B) -->\n  <path d=\"M225 290 L305 290 L295 248 L235 248 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"265\" cy=\"235\" rx=\"22\" ry=\"24\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" transform=\"rotate(-12 265 235)\"/>\n  <circle cx=\"252\" cy=\"214\" r=\"9\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"278\" cy=\"214\" r=\"9\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"220\" y=\"270\" width=\"90\" height=\"85\" rx=\"12\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"220\" y1=\"300\" x2=\"310\" y2=\"300\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"220\" y1=\"328\" x2=\"310\" y2=\"328\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Armrests -->\n  <rect x=\"74\" y=\"295\" width=\"16\" height=\"60\" rx=\"6\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"192\" y=\"295\" width=\"16\" height=\"60\" rx=\"6\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"310\" y=\"295\" width=\"16\" height=\"60\" rx=\"6\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Soda Cup on Left Armrest -->\n  <polygon points=\"62,290 74,290 77,265 59,265\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M68 265 L68 255 L63 252\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Popcorn Bucket (Center Armrest) -->\n  <polygon points=\"182,275 218,275 223,235 177,235\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M190 235 L190 275 M200 235 L200 275 M210 235 L210 275\" stroke=\"#E53935\" stroke-width=\"3\"/>\n  <!-- Fluffy Popcorn -->\n  <circle cx=\"182\" cy=\"230\" r=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"198\" cy=\"226\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"215\" cy=\"230\" r=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"190\" cy=\"222\" r=\"7\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"206\" cy=\"222\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Flying Popcorn (Laughter Effect) -->\n  <circle cx=\"165\" cy=\"205\" r=\"5\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"155\" cy=\"220\" r=\"4\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"235\" cy=\"210\" r=\"5\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"245\" cy=\"225\" r=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"200\" cy=\"202\" r=\"5\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Laugh Lines / Expression Marks -->\n  <path d=\"M100 225 Q95 230 100 235\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M170 225 Q175 230 170 235\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M230 225 Q225 230 230 235\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M300 225 Q305 230 300 235\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M135 198 Q140 190 145 198\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M265 198 Q260 190 255 198\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Little Stars in Theater Atmosphere -->\n  <path d=\"M70 200 L72 204 L77 205 L72 206 L70 210 L68 206 L63 205 L68 204 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n  <path d=\"M320 200 L322 204 L327 205 L322 206 L320 210 L318 206 L313 205 L318 204 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n</svg>",
