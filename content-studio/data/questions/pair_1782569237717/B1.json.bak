  {
    "id": "pair_1782569237717-B1-U07-S01-008",
    "type": "T12",
    "typeName": "情景回应",
    "language": "en",
    "cefr": "B1",
    "unit": "U07",
    "unitTheme": "Health, Safety, and Emergencies",
    "difficulty": 3,
    "tags": [
      "health",
      "symptoms",
      "throat",
      "chest",
      "breathing",
      "cause and consequence",
      "doctor",
      "B1"
    ],
    "scenario": "你最近几天感到喉咙痛，吞咽时很痛，胸口发闷，呼吸也不太顺畅。你怀疑是因为在空调房里待太久导致的。现在你看医生，医生让你描述你的症状。请选择最合适的回答。",
    "options": [
      "I'm suffering from a painful throat and chest and I have trouble breathing. I need you to examine me and give me treatment.",
      "I have a sore throat and it's painful to swallow. I also feel tightness in my chest and it's hard to breathe. I think I got these symptoms because I stayed in an air-conditioned room for too long.",
      "My throat hurts and I can't eat properly. My chest feels tight and I can't breathe well. I need some medicine so I can feel better."
    ],
    "answerIdx": 1,
    "pragmaticsNote": "Option A is the most appropriate as it clearly describes the symptoms and provides a reason using 'because', which demonstrates the target grammar point of expressing cause and consequence. It gives the doctor necessary context. Option B mentions wanting medicine but does not explain what caused the symptoms. Option C focuses on requesting examination and treatment but lacks any causal explanation, making it less responsive to the doctor's request for symptom description.",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U07-S01"
  },
