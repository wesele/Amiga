  },
  {
    "id": "pair_1782569237717-B1-U10-S05-004",
    "type": "T08",
    "typeName": "听力选择",
    "language": "en",
    "cefr": "B1",
    "unit": "U10",
    "unitTheme": "Integrated Communication on Public Issues",
    "difficulty": 3,
    "tags": [
      "listening",
      "public issues",
      "youth responsibility",
      "conditionals",
      "passive voice",
      "relative clauses"
    ],
    "audioText": "At the youth forum last week, the speaker emphasized that it is essential for young people to be aware of public issues. She said that whatever career we choose, we have a responsibility to participate. Unless we make an effort to understand the problems, no effective change can be achieved. I felt confident that our generation is prepared to take action, whether it involves volunteering or voting. This achievement of awareness is just the first step.",
    "question": "根据听力内容，演讲者认为年轻人应该做什么？",
    "options": [
      "只关注自己的职业发展",
      "等待政府解决所有问题",
      "了解公共议题并参与其中"
    ],
    "answerIdx": 2,
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U10-S05"
  },
  {
    "id": "pair_1782569237717-B1-U10-S05-005",
    "type": "T09",
    "typeName": "Spelling Input",
    "language": "en",
