        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Cozy Wall Art (Home Environment) -->\n  <rect x=\"170\" y=\"60\" width=\"60\" height=\"50\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 172 102 L 195 80 L 210 95 L 222 85 L 228 102 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"215\" cy=\"75\" r=\"4\" fill=\"#FFC107\"/>\n\n  <!-- Glowing Lamp Light Beam (Layered behind desk and objects) -->\n  <polygon points=\"290,175 275,190 130,300 340,300\" fill=\"#FFF9C4\"/>\n\n  <!-- Chair -->\n  <!-- Chair Backrest Cushion -->\n  <rect x=\"65\" y=\"220\" width=\"16\" height=\"80\" rx=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Chair Seat -->\n  <rect x=\"75\" y=\"290\" width=\"65\" height=\"12\" rx=\"4\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Chair Spine -->\n  <path d=\"M 73 295 L 73 340\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Chair Legs -->\n  <line x1=\"85\" y1=\"302\" x2=\"80\" y2=\"375\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"125\" y1=\"302\" x2=\"130\" y2=\"375\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Desk Setup -->\n  <!-- Desk Legs -->\n  <line x1=\"90\" y1=\"312\" x2=\"90\" y2=\"385\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"310\" y1=\"312\" x2=\"310\" y2=\"385\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <!-- Desk Top -->\n  <rect x=\"50\" y=\"300\" width=\"300\" height=\"15\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Student -->\n  <!-- Torso -->\n  <path d=\"M 95 295 L 110 205 L 148 205 L 140 295 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-