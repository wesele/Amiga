    "imagePrompt": "traveller standing in front of large world map, pointing at a destination with finger, passport and travel brochure on table nearby, suitcase on the floor, simple flat illustration style",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Floor Line -->\n  <line x1=\"20\" y1=\"360\" x2=\"380\" y2=\"360\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- World Map Background (Wall Mounted) -->\n  <rect x=\"40\" y=\"40\" width=\"320\" height=\"150\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Landmasses (Green) -->\n  <!-- Americas -->\n  <path d=\"M 50 60 C 65 60 75 75 75 95 C 75 115 60 130 70 150 C 75 160 65 180 55 180 C 48 160 52 140 48 120 C 45 90 45 60 50 60 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <!-- Greenland -->\n  <path d=\"M 120 50 Q 140 45 130 60 Q 110 65 120 50 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <!-- Eurasia & Africa -->\n  <path d=\"M 150 75 C 170 60 210 65 230 75 C 250 85 280 65 310 70 C 330 75 340 95 330 110 C 320 120 300 110 290 125 C 280 140 310 160 300 180 C 290 190 270 170 260 180 C 250 190 230 180 230 160 C 230 140 210 135 200 150 C 190 165 170 170 165 155 C 160 140 175 120 170 100 C 165 85 155 85 150 75 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <!-- Australia -->\n  <path d=\"M 310 150 C 325 150 335 160 325 170 C 315 175 300 165 310 150 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Flight Path -->\n  <path d=\"M 70 110 Q 120 85 170 100\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-dasharray=\"6,6\" stroke-linecap=\"round\"/>\n  \n  <!-- Destination Pin -->\n  <polygon points=\"171,96 179,96 175,104\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n  <circle cx=\"175\" cy=\"92\" r=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"175\" cy=\"92\" r=\"2\" fill=\"#F