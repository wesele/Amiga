    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Ground Shadow -->\n  <ellipse cx=\"200\" cy=\"370\" rx=\"160\" ry=\"12\" fill=\"#EAEAEA\"/>\n\n  <!-- Red Suitcase -->\n  <g id=\"suitcase\">\n    <rect x=\"290\" y=\"295\" width=\"80\" height=\"65\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <!-- Suitcase Straps -->\n    <rect x=\"308\" y=\"295\" width=\"10\" height=\"65\" fill=\"#333333\"/>\n    <rect x=\"352\" y=\"295\" width=\"10\" height=\"65\" fill=\"#333333\"/>\n    <!-- Handle -->\n    <path d=\"M 318 295 V 280 H 342 V 295\" fill=\"none\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Wheels -->\n    <circle cx=\"308\" cy=\"364\" r=\"8\" fill=\"#333333\"/>\n    <circle cx=\"352\" cy=\"364\" r=\"8\" fill=\"#333333\"/>\n  </g>\n\n  <!-- Police Officer (Left) -->\n  <g id=\"police_officer\">\n    <!-- Legs/Pants -->\n    <path d=\"M 85 300 L 155 300 L 150 370 L 90 370 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    \n    <!-- Torso (Uniform Shirt) -->\n    <path d=\"M 80 180 L 160 180 L 155 305 L 85 305 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    \n    <!-- Epaulets -->\n    <rect x=\"80\" y=\"175\" width=\"20\" height=\"8\" rx=\"2\" fill=\"#333333\"/>\n    <rect x=\"140\" y=\"175\" width=\"20\" height=\"8\" rx=\"2\" fill=\"#333333\"/>\n    \n    <!-- Belt & Buckle -->\n    <rect x=\"83\" y=\"288\" width=\"74\" height=\"14\" fill=\"#333333\"/>\n    <rect x=\"112\" y=\"284\" width=\"16\" height=\"22\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" rx=\"2\"/>\n    \n    <!-- Tie & Collar -->\n    <polygon points=\"115,180 125,180 128,225 120,235 112,225\" fill=\"#333333\"/>\n    <path d=\"M 98 180 L 120 202 L 142 180\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    \n    <!-- Gold Badge -->\n    <polygon points=\"138,195 146,190 154,195 152,205 146,211 140,205\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n    \n    <!-- Head & Ears -->\n    <circle cx=\"92\" cy=\"135\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <circle cx=\"148\" cy=\"135\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <circle cx=\"120\" cy=\"135\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Police Cap -->\n    <path d=\"M 90 120 L 150 120 L 156 102 L 84 102 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 88 120 Q 120 134 152 120\" fill=\"none\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n    <polygon points=\"120,105 125,111 120,117 115,111\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n    \n    <!-- Face Details -->\n    <circle cx=\"110\" cy=\"140\" r=\"3\" fill=\"#333333\"/>\n    <circle cx=\"130\" cy=\"140\" r=\"3\" fill=\"#333333\"/>\n    <path d=\"M 120 138 V 144\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <line x1=\"113\" y1=\"153\" x2=\"127\" y2=\"153\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    \n    <!-- Left Arm holding Notepad -->\n    <polygon points=\"155,185 175,225 160,235 145,195\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 168 230 L 152 250\" stroke=\"#FFD1A9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <rect x=\"125\" y=\"235\" width=\"28\" height=\"38\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" transform=\"rotate(-5, 139, 254)\"/>\n    <line x1=\"130\" y1=\"243\" x2=\"146\" y2=\"241\" stroke=\"#E0E0E0\" stroke-width=\"2\"/>\n    <line x1=\"129\" y1=\"251\" x2=\"145\" y2=\"249\" stroke=\"#E0E0E0\" stroke-width=\"2\"/>\n    <line x1=\"128\" y1=\"259\" x2=\"144\" y2=\"257\" stroke=\"#E0E0E0\" stroke-width=\"2\"/>\n    <circle cx=\"152\" cy=\"252\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2\"/>\n    \n    <!-- Right Arm at Side -->\n    <polygon points=\"85,185 65,220 75,225 90,195\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 70 222 L 75 250\" stroke=\"#FFD1A9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <circle cx=\"75\" cy=\"254\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n\n  <!-- Traveler (Right) -->\n  <g id=\"traveler\">\n    <!-- Pants -->\n    <path d=\"M 225 300 L 285 300 L 280 370 L 230 370 Z\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    \n    <!-- Turned-Out Pockets (Empty) -->\n    <path d=\"M 227 288 C 205 292, 208 318, 227 308 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    <path d=\"M 283 288 C 305 292, 302 318, 283 308 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    \n    <!-- Torso (Green Shirt) -->\n    <path d=\"M 220 180 L 290 180 L 285 305 L 225 305 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    \n    <!-- Head & Ears -->\n    <circle cx=\"227\" cy=\"135\" r=\"5\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <circle cx=\"283\" cy=\"135\" r=\"5\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <circle cx=\"255\" cy=\"135\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Orange Hair & Cap -->\n    <path d=\"M 227 130 Q 255 100 283 130 C 287 115, 270 110, 255 110 C 240 110, 223 115, 227 130 Z\" fill=\"#D84315\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    <path d=\"M 232 120 C 232 98, 278 98, 278 120 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    <path d=\"M 273 118 L 290 122 L 283 128 L 268 122 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    \n    <!-- Distressed Face Details -->\n    <path d=\"M 238 128 Q 244 128 248 132\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <path d=\"M 272 128 Q 266 128 262 132\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <ellipse cx=\"245\" cy=\"140\" rx=\"3\" ry=\"4\" fill=\"#333333\"/>\n    <ellipse cx=\"265\" cy=\"140\" rx=\"3\" ry=\"4\" fill=\"#333333\"/>\n    <path d=\"M 247 156 Q 255 168 263 156 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    \n    <!-- Sweat/Worry Drop -->\n    <path d=\"M 292 125 C 292 125 298 131 296 134 C 294 136 291 135 290 132 Z\" fill=\"#4A90D9\"/>\n    \n    <!-- Left Arm Pointing to Pocket -->\n    <polygon points=\"230,185 200,215 212,225 240,195\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 206 220 L 195 245\" stroke=\"#FFD1A9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <circle cx=\"192\" cy=\"250\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=\"192\" y1=\"250\" x2=\"178\" y2=\"268\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    \n    <!-- Right Arm Gesturing Up (Distress) -->\n    <polygon points=\"280,185 305,210 295,220 270,195\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 300 215 L 320 225\" stroke=\"#FFD1A9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <circle cx=\"323\" cy=\"227\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=\"328\" y1=\"223\" x2=\"336\" y2=\"218\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <line x1=\"329\" y1=\"228\" x2=\"337\" y2=\"228\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  </g>\n</svg>",
