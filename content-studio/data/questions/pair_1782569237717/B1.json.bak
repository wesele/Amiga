  {
    "id": "pair_1782569237717-B1-U05-S04-007",
    "type": "T10",
    "typeName": "翻译输入",
    "language": "en",
    "cefr": "B1",
    "unit": "U05",
    "unitTheme": "Planning Career Goals and Development Paths",
    "difficulty": 3,
    "tags": [
      "career",
      "goals",
      "gerunds",
      "infinitives",
      "specialize",
      "talent",
      "unemployment"
    ],
    "sourceText": "我决定在人工智能领域专攻，因为这是我最强的才能，并且我打算避免在退休前失业。",
    "sourceLang": "zh",
    "acceptedAnswers": [
      "I decided to specialize in artificial intelligence because it is my strongest talent, and I intend to avoid being unemployed before I retire.",
      "I have decided to specialize in AI as it is my greatest talent, and I intend to avoid becoming unemployed before retiring.",
      "I decided to specialize in the field of artificial intelligence, because it is where my greatest talent lies, and I plan to avoid losing my job before retirement."
    ],
    "hint": "注意'decide to'后接不定式；'intend to/plan to'表示打算；'avoid'后接动名词；介词前常用动名词（如before retiring）。",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U05-S04"
  },
  {
