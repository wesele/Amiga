      {
        "desc": "一个人在湖上钓鱼",
        "prompt": "person sitting by a calm green lake holding a fishing rod, wearing a brown hat, sunny outdoor scene, fish in water",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Sun -->\n  <circle cx=\"340\" cy=\"60\" r=\"25\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"295\" y1=\"60\" x2=\"305\" y2=\"60\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"340\" y1=\"105\" x2=\"340\" y2=\"115\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"308\" y1=\"92\" x2=\"315\" y2=\"85\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Cloud -->\n  <path d=\"M 50 75 A 15 15 0 0 1 70 55 A 20 20 0 0 1 105 55 A 15 15 0 0 1 125 75 A 12 12 0 0 1 115 90 H 60 A 12 12 0 0 1 50 75 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Lake (Water) -->\n  <rect x=\"0\" y=\"270\" width=\"400\" height=\"130\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Water Ripples -->\n  <path d=\"M 180 290 L 220 290\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 230 320 L 280 320\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 160 360 L 210 360\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 310 380 L 360 380\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Grassy Bank -->\n  <path d=\"M -10 250 Q 80 250 115 275 T 125 410 L -10 410 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Grass Tufts -->\n  <path d=\"M 30 240 L 25 225 M 30 240 L 35 228\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 80 240 L 75 225 M 80 240 L 85 228\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Reeds / Cattails -->\n  <path d=\"M 140 330 Q 150 290 142 260\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"138\" y=\"250\" width=\"8\" height=\"18\" rx=\"4\" fill=\"#795548\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <path d=\"M 155 340 Q 162 300 157 275\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"153\" y=\"265\" width=\"8\" height=\"18\" rx=\"4\" fill=\"#795548\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Wooden Stool -->\n  <rect x=\"55\" y=\"220\" width=\"40\" height=\"32\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Person Legs (Sitting) -->\n  <rect x=\"115\" y=\"220\" width=\"16\" height=\"42\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"85\" y=\"210\" width=\"40\" height=\"16\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Person Torso -->\n  <rect x=\"60\" y=\"140\" width=\"38\" height=\"80\" rx=\"10\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Person Head & Face -->\n  <circle cx=\"80\" cy=\"122\" r=\"18\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"88\" cy=\"120\" r=\"2.5\" fill=\"#333333\"/>\n  <path d=\"M 86 128 Q 90 131 94 128\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n  <!-- Brown Hat -->\n  <path d=\"M 62 108 C 62 86 98 86 98 108 Z\" fill=\"#795548\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"80\" cy=\"108\" rx=\"28\" ry=\"7\" fill=\"#795548\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Arm & Sleeve -->\n  <rect x=\"78\" y=\"155\" width=\"25\" height=\"16\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"95\" y=\"157\" width=\"28\" height=\"12\" rx=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Fishing Rod -->\n  <line x1=\"105\" y1=\"172\" x2=\"280\" y2=\"82\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n\n  <!-- Hand (gripping rod) -->\n  <circle cx=\"123\" cy=\"163\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke