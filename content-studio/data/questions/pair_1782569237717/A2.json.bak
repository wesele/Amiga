        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Sun -->\n  <circle cx=\"340\" cy=\"60\" r=\"30\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Cloud -->\n  <path d=\"M 60 90 C 60 75 80 70 90 80 C 100 65 125 70 125 85 C 135 85 145 95 135 105 L 65 105 C 55 105 55 90 60 90 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Background Trees (Behind Hill) -->\n  <rect x=\"90\" y=\"120\" width=\"12\" height=\"120\" rx=\"6\" fill=\"#333333\"/>\n  <circle cx=\"96\" cy=\"100\" r=\"45\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <rect x=\"270\" y=\"140\" width=\"12\" height=\"110\" rx=\"6\" fill=\"#333333\"/>\n  <circle cx=\"276\" cy=\"120\" r=\"45\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Green Hill -->\n  <path d=\"M -20 240 Q 200 180 420 200 L 420 420 L -20 420 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Winding Path -->\n  <path d=\"M -20 390 C 80 370 150 350 185 325 C 220 300 270 280 420 230\" fill=\"none\" stroke=\"#333333\" stroke-width=\"90\" stroke-linecap=\"round\"/>\n  <path d=\"M -20 390 C 80 370 150 350 185 325 C 220 300 270 280 420 230\" fill=\"none\" stroke=\"#E0E0E0\" stroke-width=\"80\" stroke-linecap=\"round\"/>\n  \n  <!-- Foreground Tree & Bush -->\n  <rect x=\"40\" y=\"270\" width=\"12\" height=\"80\" rx=\"6\" fill=\"#333333\"/>\n  <circle cx=\"46\" cy=\"250\" r=\"35\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"370\" cy=\"290\" r=\"30\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Grass Details -->\n  <path d=\"M 150 260 L 150 250 M 153 260 L 157 252\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 280 270 L 280 260 M 283 270 L 287 262\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Motion Lines -->\n  <line x1=\"80\" y1=\"150\" x2=\"110\" y2=\"150\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"70\" y1=\"180\" x2=\"105\" y2=\"180\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"90\" y1=\"210\" x2=\"120\" y2=\"210\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Runner: Left Arm (Background) -->\n  <path d=\"M 170 160 L 130 150 L 110 175\" fill=\"none\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M 170 160 L 130 150 L 110 175\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <polygon points=\"174,166 163,151 143,148 147,166\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Runner: Left Leg (Background) -->\n  <path d=\"M 165 220 L 205 260 L 230 315\" fill=\"none\" stroke=\"#333333\" stroke-width=\"26\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M 165 220 L 205 260 L 230 315\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"14\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <polygon points=\"156,220 182,215 195,245 169,250\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <ellipse cx=\"236\" cy=\"320\" rx=\"18\" ry=\"11\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 220 324 L 252 322\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Runner: Hips (Shorts Waist) -->\n  <polygon points=\"156,205 196,205 190,225 150,225\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Runner: Right Leg (Foreground) -->\n  <path d=\"M 180 220 L 145 275 L 110 280\" fill=\"none\" stroke=\"#333333\" stroke-width=\"26\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M 180 220 L 145 275 L 110 280