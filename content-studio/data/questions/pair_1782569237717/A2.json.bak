    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- STAIRS (drawn from back to front) -->\n  <!-- Step 3 (Top) -->\n  <rect x=\"40\" y=\"192\" width=\"110\" height=\"168\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"30\" y=\"180\" width=\"130\" height=\"12\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Step 2 (Middle) -->\n  <rect x=\"130\" y=\"252\" width=\"110\" height=\"108\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"120\" y=\"240\" width=\"130\" height=\"12\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Step 1 (Bottom) -->\n  <rect x=\"220\" y=\"312\" width=\"150\" height=\"48\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"210\" y=\"300\" width=\"160\" height=\"12\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Ground Line -->\n  <line x1=\"20\" y1=\"360\" x2=\"380\" y2=\"360\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- MAN CHARACTER -->\n  <!-- Back Arm (Supporting) -->\n  <path d=\"M135 175 L110 215 L95 240\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M135 175 L120 199\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M135 175 L110 215 L95 240\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M135 175 L120 199\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"12\" stroke-linecap=\"round\"/>\n  <circle cx=\"95\" cy=\"240\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Left Leg (Bottom leg, with shoe) -->\n  <path d=\"M155 245 L220 275 L260 330\" fill=\"none\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M155 245 L220 275 L260 330\" fill=\"none\" stroke=\"#4CAF50\" stroke-width=\"16\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <!-- Shoe On -->\n  <path d=\"M260 330 L280 345\" fill=\"none\" stroke=\"#333333\" stroke-width=\"24\" stroke-linecap=\"round\"/>\n  <path d=\"M260 330 L280 345\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M262 344 L278 354\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Right Leg (Injured leg, bare ankle) -->\n  <path d=\"M205 215 L250 300\" fill=\"none\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M205 215 L250 300\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"16\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <!-- Bare Foot -->\n  <path d=\"M250 300 L280 305\" fill=\"none\" stroke=\"#333333\" stroke-width=\"20\" stroke-linecap=\"round\"/>\n  <path d=\"M250 300 L280 305\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n  <!-- Pants part of injured leg -->\n  <path d=\"M155 245 L205 215 L230 262\" fill=\"none\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M155 245 L205 215 L230 262\" fill=\"none\" stroke=\"#4CAF50\" stroke-width=\"16\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n  <!-- Torso -->\n  <path d=\"M120 245 L110 175 C110 165 160 160 160 175 L155 245 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Head & Face -->\n  <circle cx=\"125\" cy=\"130\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Hair -->\n  <path d=\"M97 130 C97 105 115 100 125 100 C140 100 153 110 153 130 C145 127 140 130 135 125 C130 130 120 125 115 130 C110 125 102 127 97 130 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n  <!-- Grimacing Eyes -->\n  <path d=\"M112 133 L118 129 L122 133\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M128 133 L134 129 L138 133\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <!-- Pained Mouth -->\n  <path d=\"M115 146 L131 146 C131 153 115 153 115 146 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- Front Arm (Clutching Ankle) -->\n  <path d=\"M145 185 L195 245 L250 295\" fill=\"none\" stroke=\"#333333\" stroke-width=\"20\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M145 185 L165 209\" fill=\"none\" stroke=\"#333333\" stroke-width=\"20\" stroke-linecap=\"round\"/>\n  <path d=\"M145 185 L195 245 L250 295\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"14\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M145 185 L165 209\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n  <circle cx=\"250\" cy=\"295\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- DETACHED SHOE -->\n  <rect x=\"312\" y=\"292\" width=\"40\" height=\"8\" rx=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M315 292 C315 277 328 272 345 275 C353 277 355 285 355 292 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <ellipse cx=\"323\" cy=\"280\" rx=\"3\" ry=\"6\" fill=\"#333333\" transform=\"rotate(-20, 323, 280)\"/>\n\n  <!-- PAIN INDICATORS (Ankle Sparks) -->\n  <path d=\"M228 294 Q222 297 226 303\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M268 292 Q274 296 271 302\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"235\" y1=\"282\"