    "imageDesc": "一个人站在众人面前，手指向自己，正在做自我介绍，背景是简洁的室内环境",
    "imagePrompt": "young person standing in front of small group, pointing to themselves with one hand, slight smile, casual clothes, simple indoor background, name tag on chest",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Wall -->\n  <rect x=\"0\" y=\"0\" width=\"400\" height=\"280\" fill=\"#F1F5F9\"/>\n  \n  <!-- Floor -->\n  <rect x=\"0\" y=\"280\" width=\"400\" height=\"120\" fill=\"#E2E8F0\"/>\n  \n  <!-- Baseboard -->\n  <line x1=\"0\" y1=\"280\" x2=\"400\" y2=\"280\" stroke=\"#CBD5E1\" stroke-width=\"4\"/>\n  \n  <!-- Door (Background Element) -->\n  <rect x=\"320\" y=\"80\" width=\"60\" height=\"200\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Shadow under subject -->\n  <ellipse cx=\"200\" cy=\"330\" rx=\"70\" ry=\"12\" fill=\"#CBD5E1\" opacity=\"0.6\"/>\n  \n  <!-- Cap Top -->\n  <path d=\"M 155 105 C 155 70, 245 70, 245 105 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Cap Brim -->\n  <path d=\"M 160 105 Q 200 120 250 105 L 250 115 Q 200 130 155 115 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Head -->\n  <ellipse cx=\"200\" cy=\"135\" rx=\"45\" ry=\"48\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Eyes -->\n  <circle cx=\"180\" cy=\"130\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"220\" cy=\"130\" r=\"5\" fill=\"#333333\"/>\n  \n  <!-- Eyebrows -->\n  <path d=\"M 170 115 Q 180 110 190 115\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 210 115 Q 220 110 230 115\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Slight Smile -->\n  <path d=\"M 185 150 Q 200 160 215 150\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Shirt Body -->\n  <rect x=\"150\" y=\"180\" width=\"100\" height=\"100\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Collar -->\n  <path d=\"M 170 180 Q 190 210 210 180\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Left Sleeve (Relaxed) -->\n  <path d=\"M 240 185 L 285 225 L 270 240 L 230 200 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Left Hand -->\n  <circle cx=\"278\" cy=\"233\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Right Sleeve (Pointing) -->\n  <path d=\"M 145 185 L 140 225 L 155 230 L 160 190 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Right Hand Base -->\n  <circle cx=\"150\" cy=\"230\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Pointing Finger (gesturing towards name tag) -->\n  <path d=\"M 155 225 L 175 215 L 178 220 L 158 230 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Name Tag Background -->\n  <rect x=\"165\" y=\"205\" width=\"35\" height=\"22\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Name Tag Clip -->\n  <rect x=\"165\" y=\"205\" width=\"35\" height=\"7\" rx=\"2\" fill=\"#FFC107\"/>\n  \n  <!-- Name Tag Text Line 1 -->\n  <line x1=\"170\" y1=\"218\" x2=\"195\" y2=\"218\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  \n  <!-- Name Tag Text Line 2 -->\n  <line x1=\"170\" y1=\"223\" x2=\"185\" y2=\"223\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  \n  <!-- Left Pant Leg -->\n  <rect x=\"155\" y=\"270\" width=\"35\" height=\"60\" rx=\"4\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Right Pant Leg -->\n  <rect x=\"210\" y=\"270\" width=\"35\" height=\"60\" rx=\"4\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Left Shoe -->\n  <rect x=\"150\" y=\"325\" width=\"40\" height=\"15\" rx=\"4\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"2\"/>\n  \n  <!-- Right Shoe -->\n  <rect x=\"210\" y=\"325\" 