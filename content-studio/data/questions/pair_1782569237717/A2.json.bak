        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Speed/Wind Lines -->\n  <path d=\"M 40 140 L 90 125\" stroke=\"#E0E0E0\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 70 90 L 110 78\" stroke=\"#E0E0E0\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 310 110 L 350 98\" stroke=\"#E0E0E0\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Snowy Slope -->\n  <path d=\"M -20 330 Q 180 300 420 200 L 420 420 L -20 420 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Slope Contour Lines -->\n  <path d=\"M 220 330 L 350 280\" stroke=\"#E0E0E0\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 50 370 L 150 335\" stroke=\"#E0E0E0\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Skier Group (angled dynamically down the slope) -->\n  <g transform=\"translate(175, 165) rotate(-22)\">\n    <!-- Ski Shadow -->\n    <ellipse cx=\"10\" cy=\"123\" rx=\"110\" ry=\"5\" fill=\"#E0E0E0\"/>\n\n    <!-- Background Ski Pole -->\n    <line x1=\"-45\" y1=\"-50\" x2=\"55\" y2=\"50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <circle cx=\"45\" cy=\"40\" r=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n    <!-- Background Ski -->\n    <rect x=\"-120\" y=\"98\" width=\"220\" height=\"12\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n    <!-- Background Leg -->\n    <path d=\"M -30 98 L -50 45 L -10 5\" fill=\"none\" stroke=\"#333333\" stroke-width=\"20\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M -30 98 L -50 45 L -10 5\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n    <!-- Background Boot -->\n    <rect x=\"-42\" y=\"80\" width=\"30\" height=\"20\" rx=\"4\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n    <!-- Background Arm -->\n    <path d=\"M -55 -45 L -45 -25 L -25 -30\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M -55 -45 L -45 -25 L -25 -30\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"10\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <circle cx=\"-25\" cy=\"-30\" r=\"7\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n    <!-- Torso (Blue Jacket) -->\n    <rect x=\"-65\" y=\"-45\" width=\"80\" height=\"50\" rx=\"22\" transform=\"rotate(15, -25, -20)\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <path d=\"M -60 -38 L -48 -28\" stroke=\"#E53935\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n\n    <!-- Head & Helmet -->\n    <circle cx=\"-72\" cy=\"-58\" r=\"18\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <path d=\"M -90 -62 C -90 -85 -54 -85 -54 -62 C -54 -56 -62 -54 -72 -54 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Goggles -->\n    <g transform=\"rotate(10, -79, -65)\">\n      <rect x=\"-90\" y=\"-72\" width=\"22\" height=\"13\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n      <path d=\"M -84 -68 L -81 -64 M -79 -67 L -77 -64\" stroke=\"#FFFFFF\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n    </g>\n\n    <!-- Front Leg -->\n    <path d=\"M -10 111 L -30 50 L 10 5\" fill=\"none\" stroke=\"#333333\" stroke-width=\"20\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M -10 111 L -30 50 L 10 5\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n    <!-- Front Boot -->\n    <rect x=\"-28\" y=\"93\" width=\"32\" height=\"20\" rx=\"4\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <rect x=\"-20\" y=\"99\" width=\"10\" height=\"3\" fill=\"#FFC107\"/>\n\n    <!-- Front Ski -->\n    <rect x=\"-100\" y=\"111\" width=\"220\" height=\"12\" rx=\"6\" fill=\"#F