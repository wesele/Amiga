    "imageDesc": "一名学生站在黑板前，黑板上画满了化学分子结构式和元素周期表，学生手持试管，穿着实验服，站在实验室中",
    "imagePrompt": "student in lab coat holding test tube, chalkboard with chemical formulas and periodic table behind, laboratory setting, beakers on table",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Chalkboard Frame & Board -->\n  <rect x=\"46\" y=\"36\" width=\"308\" height=\"178\" rx=\"10\" fill=\"#333333\"/>\n  <rect x=\"52\" y=\"42\" width=\"296\" height=\"166\" rx=\"6\" fill=\"#4CAF50\"/>\n  \n  <!-- Chalkboard Drawings (Molecular Structure) -->\n  <polygon points=\"80,75 95,65 110,75 110,95 95,105 80,95\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\"/>\n  <line x1=\"85\" y1=\"78\" x2=\"95\" y2=\"70\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <line x1=\"110\" y1=\"75\" x2=\"125\" y2=\"65\" stroke=\"#FFFFFF\" stroke-width=\"3\"/>\n  <circle cx=\"129\" cy=\"62\" r=\"4\" fill=\"#FFFFFF\"/>\n  \n  <!-- Chalkboard Drawings (Periodic Table Grid) -->\n  <path d=\"M265 70 L275 70 L275 80 L310 80 L310 70 L320 70 L320 110 L265 110 Z\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <line x1=\"265\" y1=\"95\" x2=\"320\" y2=\"95\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <line x1=\"283\" y1=\"80\" x2=\"283\" y2=\"110\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <line x1=\"301\" y1=\"80\" x2=\"301\" y2=\"110\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  \n  <!-- Chalkboard Drawings (Chemical Equation) -->\n  <circle cx=\"270\" cy=\"135\" r=\"5\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <path d=\"M280 135 L290 135 M285 130 L285 140\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <rect x=\"298\" y=\"130\" width=\"10\" height=\"10\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <path d=\"M315 135 L325 135 M322 131 L326 135 L322 139\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <polygon points=\"334,130 342,138 334,138\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n\n  <!-- Student Back Hair -->\n  <path d=\"M168 140 C165 110, 235 110, 232 140 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Student Neck & Body -->\n  <rect x=\"193\" y=\"160\" width=\"14\" height=\"20\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Student Arms (Background Shadows/Outlines + Fills) -->\n  <path d=\"M170 195 Q152 220 155 285\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M170 195 Q152 220 155 285\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"12\" stroke-linecap=\"round\"/>\n  \n  <path d=\"M230 195 Q255 195 250 170\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M230 195 Q255 195 250 170\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"12\" stroke-linecap=\"round\"/>\n\n  <!-- Student Lab Coat Torso -->\n  <path d=\"M165 180 L235 180 L245 320 L155 320 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <polygon points=\"197,180 203,180 204,205 200,210 196,205\" fill=\"#E53935\"/>\n  <path d=\"M185 180 L200 215 L215 180\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Lab Coat Pocket Details -->\n  <rect x=\"172\" y=\"225\" width=\"16\" height=\"18\" rx=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"176\" y=\"217\" width=\"3\" height=\"10\" rx=\"1\" fill=\"#4A90D9\"/>\n  <rect x=\"181\" y=\"215\" width=\"3\" height=\"12\" rx=\"1\" fill=\"#E53935\"/>\n\n  <!-- Right Hand -->\n  <circle cx=\"156\" cy=\"292\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Student Head & Face Details -->\n  <circle cx=\"200\" cy=\"140\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M170 135 Q200 110 230 135 C235 110 165 110 170 135 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <circle cx=\"190\" cy=\"138\" r=\"3.5\" fill=\"#333333\"/>\n  <circle cx=\"210\" cy=\"138\" r=\"3.5\" fill=\"#333333\"/>\n  <path d=\"M200 144 L200 148\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  <path d=\"M192 152 Q200 160 208 152\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Safety Goggles -->\n  <rect x=\"178\" y=\"128\" width=\"44\" height=\"16\" rx=\"8\" fill=\"#4A90D9\" fill-opacity=\"0.4\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"184\" y1=\"134\" x2=\"190\" y2=\"140\" stroke=\"#FFFFFF\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <line x1=\"210\" y1=\"134\" x2=\"216\" y2=\"140\" stroke=\"#FFFFFF\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n\n  <!-- Held Test Tube (Behind Fingers, In Front of Sleeve) -->\n  <path d=\"M254 142 L254 169 C254 174, 262 174, 262 169 L262 142 Z\" fill=\"#E53935\"/>\n  <path d=\"M252 125 L252 170 C252 178, 264 178, 264 170 L264 125 Z\" fill=\"#FFFFFF\" fill-opacity=\"0.3\" stroke=\"#333333\" stroke-width=\"3.5\" stroke-linejoin=\"round\"/>\n  <ellipse cx=\"258\" cy=\"125\" rx=\"6\" ry=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Left Hand (Grasping) -->\n  <circle cx=\"249\" cy=\"162\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"246\" y=\"156\" width=\"12\" height=\"5\" rx=\"2\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2.5\"/>\n  <rect x=\"246\" y=\"163\" width=\"12\" height=\"5\" rx=\"2\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2.5\"/>\n\n  <!-- Lab Table (Foreground) -->\n  <rect x=\"-10\" y=\"310\" width=\"420\" height=\"100\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Beaker (Left) -->\n  <path d=\"M77 275 Q90 272 102 275 T123 275 L123 308 L77 308 Z\" fill=\"#4A90D9\"/>\n  <path d=\"M75 250 L75 310 L125 310 L125 250 Z\" fill=\"#FFFFFF\" fill-opacity=\"0.2\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M71 250 L129 250\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"115\" y1=\"265\" x2=\"120\" y2=\"265\" stroke=\"#333333\" stroke-width=\"2