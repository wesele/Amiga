      {
        "desc": "研究员在实验室使用科学仪器做实验",
        "prompt": "researcher in white lab coat using scientific equipment in a laboratory, test tubes and microscope on table, orange and grey color scheme",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Instrument Shadows -->\n  <ellipse cx=\"125\" cy=\"340\" rx=\"22\" ry=\"4\" fill=\"#E0E0E0\"/>\n  <ellipse cx=\"180\" cy=\"340\" rx=\"28\" ry=\"4\" fill=\"#E0E0E0\"/>\n  <ellipse cx=\"265\" cy=\"340\" rx=\"35\" ry=\"4\" fill=\"#E0E0E0\"/>\n  <ellipse cx=\"342\" cy=\"340\" rx=\"32\" ry=\"4\" fill=\"#E0E0E0\"/>\n\n  <!-- Lab Workbench Line -->\n  <line x1=\"15\" y1=\"340\" x2=\"385\" y2=\"340\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n\n  <!-- ========================================== -->\n  <!-- ROUND-BOTTOM FLASK (Left) -->\n  <!-- ========================================== -->\n  <!-- Flask Liquid -->\n  <path d=\"M 107 325 A 20 20 0 0 0 143 325 Z\" fill=\"#4CAF50\"/>\n  <!-- Flask Neck & Lip -->\n  <rect x=\"121\" y=\"280\" width=\"8\" height=\"25\" fill=\"#E1F5FE\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"125\" cy=\"280\" rx=\"7\" ry=\"2.5\" fill=\"#E1F5FE\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Flask Body Outline -->\n  <circle cx=\"125\" cy=\"320\" r=\"20\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Flask Highlight -->\n  <path d=\"M 112 310 A 15 15 0 0 1 125 302\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- ========================================== -->\n  <!-- BEAKER (Center) -->\n  <!-- ========================================== -->\n  <!-- Beaker Body -->\n  <rect x=\"155\" y=\"285\" width=\"50\" height=\"55\" rx=\"4\" fill=\"#E1F5FE\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Beaker Liquid -->\n  <path d=\"M 157 305 L 203 305 L 203 336 Q 203 338 201 338 L 159 338 Q 157 338 157 336 Z\" fill=\"#E53935\"/>\n  <!-- Re-outline Beaker for clean edges -->\n  <rect x=\"155\" y=\"285\" width=\"50\" height=\"55\" rx=\"4\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Beaker Spout Detail -->\n  <polygon points=\"155,288 149,285 155,292\" fill=\"#E1F5FE\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Measurement Marks -->\n  <line x1=\"195\" y1=\"298\" x2=\"189\" y2=\"298\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"195\" y1=\"308\" x2=\"189\" y2=\"308\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"195\" y1=\"318\" x2=\"189\" y2=\"318\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"195\" y1=\"328\" x2=\"189\" y2=\"328\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <!-- Beaker Highlight -->\n  <line x1=\"162\" y1=\"292\" x2=\"162\" y2=\"330\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- ========================================== -->\n  <!-- RESEARCHER (Left profile) -->\n  <!-- ========================================== -->\n  <!-- Lab Coat Torso -->\n  <path d=\"M 20 340 L 20 245 Q 55 225 75 245 L 95 340 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Inner Shirt (Yellow) & Tie -->\n  <polygon points=\"73 245 83 245 80 265\" fill=\"#FFC107\"/>\n  <!-- Coat Collar -->\n  <path d=\"M 70 245 L 82 275\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Neck -->\n  <rect x=\"65\" y=\"205\" width=\"20\" height=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Face & Nose Profile -->\n  <circle cx=\"75\" cy=\"180\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <polygon points=\"100,172 112,180 100,185\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Hide nose-to-face seam -->\n  <ellipse cx=\"98\" cy=\"179\" rx=\"4\" ry=\"7\" fill=\"#FFD1A9\" stroke=\"none\"/>\n\n  <!-- Eye (focused/happy curve) -->\n  <path d=\"M 88 178 Q 93 181 98 178\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Glasses -->\n  <r