=\"110\" y1=\"293\" x2=\"220\" y2=\"293\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"105\" y1=\"299\" x2=\"225\" y2=\"299\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Laptop Screen -->\n  <rect x=\"110\" y=\"170\" width=\"110\" height=\"115\" rx=\"6\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"117\" y=\"177\" width=\"96\" height=\"98\" fill=\"#4A90D9\"/>\n  \n  <!-- Laptop Screen Content (Teacher) -->\n  <rect x=\"125\" y=\"192\" width=\"35\" height=\"25\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <path d=\"M 130,202 L 135,197 M 135,207 L 142,200 M 148,204 L 152,199\" stroke=\"#FFFFFF\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n  <path d=\"M 140,275 C 140,245 190,245 190,275 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"165\" cy=\"228\" r=\"14\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 152,228 C 152,210 178,210 178,228 C 178,232 173,231 165,231 C 157,231 152,232 152,228 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"160\" cy=\"226\" r=\"1.5\" fill=\"#333333\"/>\n  <circle cx=\"170\" cy=\"226\" r=\"1.5\" fill=\"#333333\"/>\n  <path d=\"M 162,233 Q 165,236 168,233\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  \n  <!-- Screen UI elements -->\n  <rect x=\"117\" y=\"177\" width=\"96\" height=\"10\" fill=\"#333333\"/>\n  <circle cx=\"123\" cy=\"182\" r=\"2\" fill=\"#E53935\"/>\n  <circle cx=\"129\" cy=\"182\" r=\"2\" fill=\"#FFC107\"/>\n  <circle cx=\"135\" cy=\"182\" r=\"2\" fill=\"#4CAF50\"/>\n  <path d=\"M 195,183 A 6,6 0 0,1 205,183\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n  <path d=\"M 197,186 A 3,3 0 0,1 203,186\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n  <circle cx=\"200\" cy=\"189\" r=\"1\" fill=\"#FFFFFF\"/>\n  \n  <!-- Notebook -->\n  <polygon points=\"190,315 265,310 255,345 180,350\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"192,318 227,316 220,344 185,346\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <polygon points=\"227,316 262,313 252,342 220,344\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <line x1=\"193\" y1=\"325\" x2=\"222\" y2=\"323\" stroke=\"#90A4AE\" stroke-width=\"2\"/>\n  <line x1=\"191\" y1=\"332\" x2=\"220\" y2=\"330\" stroke=\"#90A4AE\" stroke-width=\"2\"/>\n  <line x1=\"189\" y1=\"339\" x2=\"218\" y2=\"337\" stroke=\"#90A4AE\" stroke-width=\"2\"/>\n  <line x1=\"231\" y1=\"323\" x2=\"259\" y2=\"321\" stroke=\"#90A4AE\" stroke-width=\"2\"/>\n  <line x1=\"229\" y1=\"330\" x2=\"257\" y2=\"328\" stroke=\"#90A4AE\" stroke-width=\"2\"/>\n  <line x1=\"227\" y1=\"337\" x2=\"255\" y2=\"335\" stroke=\"#90A4AE\" stroke-width=\"2\"/>\n  <path d=\"M 223,344 C 223,355 218,360 220,365\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Student Body -->\n  <path d=\"M 230,400 C 230,350 250,330 290,330 C 330,330 380,350 380,400 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Writing Arm -->\n  <path d=\"M 330,365 Q 290,365 262,342\" fill=\"none\" stroke=\"#333333\" stroke-width=\"28\" stroke-linecap=\"round\"/>\n  <path d=\"M 330,365 Q 290,365 262,342\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"20\" stroke-linecap=\"round\"/>\n  <circle cx=\"252\" cy=\"332\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"245\" y1=\"340\" x2=\"260\" y2=\"320\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <line x1=\"245\" y1=\"340\" x2=\"260\" y2=\"320\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Student Head & Neck -->\n  <path d=\"M 280,335 L 280,310 L 305,310 L 305,335 Z\" fill=\"#FFD1A9\" stroke=\"#333333\