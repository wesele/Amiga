    "imagePrompt": "customer in clothing store holding two jackets side by side, one thick heavy coat with wooden buttons, one thin light jacket with plastic zipper, comparing thickness",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  <ellipse cx=\"200\" cy=\"390\" rx=\"160\" ry=\"6\" fill=\"#E0E0E0\"/>\n\n  <!-- Minimalist Clothing Rack in Background -->\n  <path d=\"M 40 140 L 360 140\" stroke=\"#4CAF50\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 60 140 L 60 380\" stroke=\"#4CAF50\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 340 140 L 340 380\" stroke=\"#4CAF50\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 40 380 L 80 380\" stroke=\"#4CAF50\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 320 380 L 360 380\" stroke=\"#4CAF50\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- LEFT SIDE: Heavy Coat (#4A90D9) - Positioned Low -->\n  <!-- Left Hanger -->\n  <path d=\"M 115 245 C 115 235, 125 235, 125 240 C 125 245, 115 248, 115 255\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <polygon points=\"115,255 85,265 145,265\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Left Coat Body (Thick, Bulky) -->\n  <path d=\"M 85 265 L 65 290 L 60 365 C 60 372, 70 375, 80 375 L 150 375 C 160 375, 170 372, 170 365 L 165 290 L 145 265 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Thick Collar/Lapels -->\n  <ellipse cx=\"115\" cy=\"275\" rx=\"22\" ry=\"10\" fill=\"#3B78B8\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 98 275 L 115 295 L 132 275\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Wooden Buttons -->\n  <circle cx=\"102\" cy=\"310\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"99\" y1=\"310\" x2=\"105\" y2=\"310\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"128\" cy=\"310\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"125\" y1=\"310\" x2=\"131\" y2=\"310\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"102\" cy=\"335\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"99\" y1=\"335\" x2=\"105\" y2=\"335\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"128\" cy=\"335\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"125\" y1=\"335\" x2=\"131\" y2=\"335\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <!-- Pockets -->\n  <rect x=\"68\" y=\"342\" width=\"22\" height=\"12\" rx=\"2\" fill=\"#3B78B8\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"140\" y=\"342\" width=\"22\" height=\"12\" rx=\"2\" fill=\"#3B78B8\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n\n  <!-- RIGHT SIDE: Light Jacket (#FFC107) - Positioned High -->\n  <!-- Right Hanger -->\n  <path d=\"M 285 150 C 285 140, 295 140, 295 145 C 295 150, 285 153, 285 160\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <polygon points=\"285,160 260,170 310,170\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Right Jacket Body (Thin, Creased) -->\n  <path d=\"M 260 170 L 245 190 L 250 245 C 250 250, 260 252, 270 252 L 300 252 C 310 252, 320 250, 320 245 L 325 190 L 310 170 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Thin Zipper -->\n  <line x1=\"285\" y1=\"170\" x2=\"285\" y2=\"252\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"282\" y=\"185\" width=\"6\" height=\"9\" rx=\"1\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <!-- Crease/Fold Lines (showing lightness/thin fabric) -->\n  <path d=\"M 253 205 L 268 210\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 317 215 L 302 220\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 260 235 L 275 230\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n\n  <!-- CUSTOMER (Center) -->\n  <!-- Left Arm (Stretched Downwards) -->\n  <line x1=\"170\" y1=\"160\" x2=\"115\" y2=\"240\" stroke=\"#333333\" stroke-width=\"24\" stroke-linecap=\"round\"/>\n  <line x1=\"170\" y1=\"160\" x2=\"115\" y2=\"240\" stroke=\"#E53935\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n  \n  <!-- Right Arm (Raised / Curved) -->\n  <path d=\"M 230 160 Q 260 135 285 150\" fill=\"none\" stroke=\"#333333\" stroke-width=\"24\" stroke-linecap=\"round\"/>\n  <path d=\"M 230 160 Q 260 135 285 150\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n\n  <!-- Torso -->\n  <path d=\"M 165 160 L 235 160 L 225 230 L 175 230 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 190 160 Q 200 172 210 160\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Left Hand (Holding Heavy Coat) -->\n  <circle cx=\"115\" cy=\"245\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Right Hand (Holding Light Jacket) -->\n  <circle cx=\"285\" cy=\"150\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Head & Face -->\n  <rect x=\"192\" y=\"125\" width=\"16\" height=\"20\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"200\" cy=\"110\" r=\"32\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Hair -->\n  <path d=\"M 168 110 C 168 75, 232 75, 232 110 C 220 98, 180 98, 168 110 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Thoughtful Eyes (Looking from side to side) -->\n  <ellipse cx=\"188\" cy=\"114\" rx=\"4\" ry=\"5\" fill=\"#333333\"/>\n  <ellipse cx=\"212\" cy=\"114\" rx=\"4\" ry=\"5\" fill=\"#333333\"/>\n  \n  <!-- Eyebrows (One curved up, one flat - evaluating) -->\n  <path d=\"M 180 105 Q 188 100 194 106\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 206 106 Q 