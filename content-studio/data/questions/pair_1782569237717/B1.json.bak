  {
    "id": "pair_1782569237717-B1-U06-S05-008",
    "type": "T11",
    "typeName": "语音跟读",
    "language": "en",
    "cefr": "B1",
    "unit": "U06",
    "unitTheme": "Recommending Performances and Cultural Events",
