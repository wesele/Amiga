    "imagePrompt": "young person sitting at desk, hands on face showing distress, large pile of books and papers on desk, cluttered workspace, worried expression, simple flat illustration style",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Ground Shadow -->\n  <ellipse cx=\"200\" cy=\"380\" rx=\"160\" ry=\"8\" fill=\"#E0E0E0\"/>\n\n  <!-- Desk Legs -->\n  <line x1=\"70\" y1=\"280\" x2=\"70\" y2=\"375\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"330\" y1=\"280\" x2=\"330\" y2=\"375\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Torso / Shoulders -->\n  <path d=\"M 130 280 L 135 225 C 135 200, 265 200, 265 225 L 270 280 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Head -->\n  <circle cx=\"200\" cy=\"170\" r=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Hair -->\n  <path d=\"M 165 170 C 165 125, 235 125, 235 170 C 220 160, 180 160, 165 170 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Frown Mouth -->\n  <path d=\"M 192 198 Q 200 190 208 198\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Sweat Droplets (Distress Indicators) -->\n  <path d=\"M 158 188 Q 153 193 158 198 Q 163 193 158 188 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <path d=\"M 242 188 Q 247 193 242 198 Q 237 193 242 188 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Desk Top -->\n  <rect x=\"25\" y=\"275\" width=\"350\" height=\"15\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" rx=\"4\"/>\n\n  <!-- Papers on Desk -->\n  <polygon points=\"110,275 145,275 140,260 115,260\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"220,275 255,275 260,262 230,262\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Crumpled Paper Ball -->\n  <path d=\"M 255 268 L 260 263 L 265 266 L 268 261 L 263 256 L 255 258 L 250 263 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Upper Arms (Sleeves) -->\n  <!-- Left Upper Arm -->\n  <line x1=\"135\" y1=\"230\" x2=\"150\" y2=\"275\" stroke=\"#333333\" stroke-width=\"28\" stroke-linecap=\"round\"/>\n  <line x1=\"135\" y1=\"230\" x2=\"150\" y2=\"275\" stroke=\"#4A90D9\" stroke-width=\"20\" stroke-linecap=\"round\"/>\n  <!-- Right Upper Arm -->\n  <line x1=\"265\" y1=\"230\" x2=\"250\" y2=\"275\" stroke=\"#333333\" stroke-width=\"28\" stroke-linecap=\"round\"/>\n  <line x1=\"265\" y1=\"230\" x2=\"250\" y2=\"275\" stroke=\"#4A90D9\" stroke-width=\"20\" stroke-linecap=\"round\"/>\n\n  <!-- Forearms & Hands (Covering Face) -->\n  <!-- Left Forearm Outer -->\n  <line x1=\"150\" y1=\"275\" x2=\"185\" y2=\"175\" stroke=\"#333333\" stroke-width=\"24\" stroke-linecap=\"round\"/>\n  <!-- Left Forearm Inner -->\n  <line x1=\"150\" y1=\"275\" x2=\"185\" y2=\"175\" stroke=\"#FFD1A9\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n  <!-- Right Forearm Outer -->\n  <line x1=\"250\" y1=\"275\" x2=\"215\" y2=\"175\" stroke=\"#333333\" stroke-width=\"24\" stroke-linecap=\"round\"/>\n  <!-- Right Forearm Inner -->\n  <line x1=\"250\" y1=\"275\" x2=\"215\" y2=\"175\" stroke=\"#FFD1A9\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n\n  <!-- Fingers Details -->\n  <line x1=\"180\" y1=\"172\" x2=\"177\" y2=\"182\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"185\" y1=\"170\" x2=\"183\" y2=\"182\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"220\" y1=\"172\" x2=\"223\" y2=\"182\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"215\" y1=\"170\" x2=\"217\" y2=\"182\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Books Stack -->\n  <!-- Book 1 (Red) -->\n  <rect x=\"50\" y=\"255\" width=\"80\" height=\"20\" rx=\"3\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"65\" y1=\"257\" x2=\"65\" y2=\"273\" stroke=\"#FFFFFF\" stroke-width=\"3\"/>\n  <!-- Book 2