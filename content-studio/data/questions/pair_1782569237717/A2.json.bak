        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Distant Background Trees (Green Silhouettes) -->\n  <rect x=\"110\" y=\"160\" width=\"12\" height=\"190\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" rx=\"2\"/>\n  <rect x=\"270\" y=\"170\" width=\"12\" height=\"180\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" rx=\"2\"/>\n\n  <!-- Main Tree Trunks -->\n  <rect x=\"140\" y=\"130\" width=\"24\" height=\"220\" rx=\"4\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"230\" y=\"140\" width=\"26\" height=\"210\" rx=\"4\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"180\" y=\"110\" width=\"34\" height=\"245\" rx=\"5\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Bark Details (Vertical Lines) -->\n  <path d=\"M 152 170 L 152 210 M 148 250 L 148 280\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 243 180 L 243 230 M 239 270 L 239 300\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 197 150 L 197 200 M 193 240 L 193 290\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Tree Branches -->\n  <path d=\"M 140 200 Q 110 190 100 170\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 256 210 Q 280 200 295 180\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 214 170 Q 240 160 245 145\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Cute Red Bird on Center Branch -->\n  <polygon points=\"225,150 220,154 227,156\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n  <ellipse cx=\"233\" cy=\"152\" rx=\"10\" ry=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"242\" cy=\"145\" r=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"248,142 254,145 248,148\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"243\" cy=\"144\" r=\"1\" fill=\"#333333\"/>\n\n  <!-- Diagonal Sunbeams (Translucent Light Rays) -->\n  <polygon points=\"90,80 130,80 220,350 180,350\" fill=\"#FFC107\" opacity=\"0.3\"/>\n  <polygon points=\"170,80 210,80 290,350 250,350\" fill=\"#FFC107\" opacity=\"0.3\"/>\n  <polygon points=\"260,90 290,90 355,320 325,320\" fill=\"#FFC107\" opacity=\"0.25\"/>\n\n  <!-- Floating Glowing Dust Motes -->\n  <circle cx=\"140\" cy=\"200\" r=\"5\" fill=\"#FFFFFF\"/>\n  <circle cx=\"210\" cy=\"240\" r=\"4\" fill=\"#FFFFFF\"/>\n  <circle cx=\"250\" cy=\"170\" r=\"6\" fill=\"#FFFFFF\"/>\n  <circle cx=\"280\" cy=\"260\" r=\"4\" fill=\"#FFFFFF\"/>\n  <circle cx=\"170\" cy=\"290\" r=\"5\" fill=\"#FFFFFF\"/>\n\n  <!-- Dense Upper Canopy (Overlapping Green Foliage) -->\n  <circle cx=\"120\" cy=\"120\" r=\"45\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"95\" cy=\"150\" r=\"35\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"190\" cy=\"100\" r=\"55\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"245\" cy=\"110\" r=\"45\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"300\" cy=\"135\" r=\"40\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"265\" cy=\"150\" r=\"30\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"160\" cy=\"140\" r=\"35\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"215\" cy=\"145\" r=\"35\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Hanging Vines -->\n  <path d=\"M 100 155 Q 105 200 95 230\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <circle cx=\"97\" cy=\"180\" r=\"5\" f