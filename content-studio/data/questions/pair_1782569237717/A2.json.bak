        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Circular Town Square Plaza (High-Angle Ellipse) -->\n  <ellipse cx=\"200\" cy=\"245\" rx=\"160\" ry=\"110\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Paving Patterns -->\n  <ellipse cx=\"200\" cy=\"245\" rx=\"120\" ry=\"80\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-dasharray=\"10 15\"/>\n  <ellipse cx=\"200\" cy=\"245\" rx=\"80\" ry=\"50\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-dasharray=\"8 12\"/>\n\n  <!-- Ground Shadows (Drawn before objects) -->\n  <!-- Shop Shadows -->\n  <ellipse cx=\"102\" cy=\"200\" rx=\"40\" ry=\"6\" fill=\"#BDBDBD\"/>\n  <ellipse cx=\"200\" cy=\"175\" rx=\"40\" ry=\"6\" fill=\"#BDBDBD\"/>\n  <ellipse cx=\"297\" cy=\"200\" rx=\"40\" ry=\"6\" fill=\"#BDBDBD\"/>\n  <!-- Bench Shadows -->\n  <ellipse cx=\"82\" cy=\"253\" rx=\"22\" ry=\"5\" fill=\"#BDBDBD\"/>\n  <ellipse cx=\"317\" cy=\"253\" rx=\"22\" ry=\"5\" fill=\"#BDBDBD\"/>\n  <!-- Person Shadow -->\n  <ellipse cx=\"200\" cy=\"314\" rx=\"20\" ry=\"6\" fill=\"#BDBDBD\"/>\n  <!-- Pigeon Shadows -->\n  <ellipse cx=\"138\" cy=\"282\" rx=\"8\" ry=\"3\" fill=\"#BDBDBD\"/>\n  <ellipse cx=\"260\" cy=\"287\" rx=\"8\" ry=\"3\" fill=\"#BDBDBD\"/>\n  <ellipse cx=\"178\" cy=\"327\" rx=\"8\" ry=\"3\" fill=\"#BDBDBD\"/>\n  <ellipse cx=\"225\" cy=\"327\" rx=\"8\" ry=\"3\" fill=\"#BDBDBD\"/>\n\n  <!-- Left Shop (Red Facade) -->\n  <rect x=\"65\" y=\"130\" width=\"75\" height=\"70\" rx=\"4\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"92\" y=\"155\" width=\"26\" height=\"45\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"72\" y=\"150\" width=\"16\" height=\"16\" rx=\"2\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"60,130 145,130 150,150 55,150\" fill=\"#F