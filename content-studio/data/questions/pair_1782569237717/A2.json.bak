225, 155 210, 197 205\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"165\" y1=\"187\" x2=\"165\" y2=\"238\" stroke=\"#FFD54F\" stroke-width=\"5\"/>\n  <line x1=\"127\" y1=\"210\" x2=\"198\" y2=\"210\" stroke=\"#FFD54F\" stroke-width=\"5\"/>\n  <circle cx=\"165\" cy=\"210\" r=\"5\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Directional Signpost -->\n  <rect x=\"70\" y=\"90\" width=\"10\" height=\"240\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"75\" cy=\"90\" rx=\"7\" ry=\"4\" fill=\"#333333\"/>\n  <!-- Sign 1 (pointing Left, green) -->\n  <path d=\"M25 105 L75 105 L75 125 L25 125 L15 115 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Sign 2 (pointing Right, yellow) -->\n  <path d=\"M75 135 L125 135 L135 145 L125 155 L75 155 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Sign 3 (pointing Left, red) -->\n  <path d=\"M30 165 L75 165 L75 185 L30 185 L20 175 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Traveler Character -->\n  <!-- Shoes -->\n  <ellipse cx=\"235\" cy=\"333\" rx=\"14\" ry=\"8\" fill=\"#333333\"/>\n  <ellipse cx=\"270\" cy=\"333\" rx=\"14\" ry=\"8\" fill=\"#333333\"/>\n  <!-- Legs -->\n  <rect x=\"226\" y=\"270\" width=\"18\" height=\"60\" rx=\"3\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"261\" y=\"270\" width=\"18\" height=\"60\" rx=\"3\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Backpack -->\n  <rect x=\"215\" y=\"195\" width=\"22\" height=\"75\" rx=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Torso -->\n  <rect x=\"225\" y=\"195\" width=\"55\" height=\"80\" rx=\"10\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Neck -->\n  <rect x=\"245\" y=\"175\" width=\"14\" height=\"25\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Head -->\n  <circle cx=\"252\" cy=\"150\" r=\"