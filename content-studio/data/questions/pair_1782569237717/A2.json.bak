    "imageOptions": [
      {
        "desc": "一位记者坐在桌前用电脑写在线评论，屏幕显示评论网站，蓝色调",
        "prompt": "a journalist sitting at a desk typing on a laptop, review website on screen, blue color scheme, indoor office",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Ambient Backdrop Glow -->\n  <circle cx=\"200\" cy=\"225\" r=\"120\" fill=\"#EBF3FC\"/>\n  \n  <!-- Chair Base & Wheels -->\n  <path d=\"M 290 370 L 330 370 M 310 310 L 310 370\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n  <circle cx=\"290\" cy=\"374\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"330\" cy=\"374\" r=\"5\" fill=\"#333333\"/>\n  \n  <!-- Chair Backrest & Support -->\n  <path d=\"M 315 305 L 335 305 M 335 305 L 337 280\" fill=\"none\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <rect x=\"332\" y=\"215\" width=\"10\" height=\"70\" rx=\"5\" fill=\"#333333\"/>\n\n  <!-- Far Arm (Background Layer) -->\n  <path d=\"M 300 235 L 260 275 L 212 298\" fill=\"none\" stroke=\"#333333\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n  <!-- Legs / Pants -->\n  <path d=\"M 285 305 L 250 305 L 250 365\" fill=\"none\" stroke=\"#333333\" stroke-width=\"14\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n  <!-- Torso (Blue Shirt) -->\n  <path d=\"M 285 305 C 285 260 290 230 325 230 L 335 230 L 335 305 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Neck & Head -->\n  <path d=\"M 305 210 L 305 230 L 315 230 L 315 210 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"310\" cy=\"180\" r=\"24\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Hair -->\n  <path d=\"M 292 173 C 292 155 322 155 330 168 C 335 178 332 195 325 195 C 318 195 318 185 308 185 C 298 185 292 178 292 173 Z\" fill=\"#333333\"/>\n\n  <!-- Glasses -->\n  <rect x=\"284\" y=\"172\" width=\"15\" height=\"12\" rx=\"2\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"299\" y1=\"178\" x2=\"313\" y2=\"178\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Near Arm & Hand (Foreground Layer) -->\n  <path d=\"M 310 235 L 270 275 L 222 305\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M 310 235 L 270 275\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n  <path d=\"M 270 275 L 222 305\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n\n  <!-- Desk Legs -->\n  <line x1=\"60\" y1=\"330\" x2=\"60\" y2=\"380\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <line x1=\"340\" y1=\"330\" x2=\"340\" y2=\"380\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n\n  <!-- Desk Surface -->\n  <rect x=\"30\" y=\"320\" width=\"340\" height=\"10\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Potted Plant -->\n  <polygon points=\"352,305 368,305 365,320 355,320\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 360 305 Q 350 280 360 270 Q 370 280 360 305\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Coffee Mug -->\n  <rect x=\"90\" y=\"298\" width=\"16\" height=\"22\" rx=\"3\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 90 303 H 85 V 315 H 90\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 98 292 Q 100 286 96 282\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n\n  <!-- Laptop Base -->\n  <polygon points=\"120,310 210,305 230,320 140,326\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <line x1=\"155\" y1=\"318\" x2=\"205\" y2=\"314\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Laptop Screen (Bezel & Display) -->\n  <polygon points=\"120,310 210,305 190,215 100,220\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"125,305 205,299 187,220 107,225\" fill=\"#EBF3FC\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Mock Review Website Layout -->\n  <line x1=\"112\" y1=\"234\" x2=\"182\" y2=\"229\" stroke=\"#4A90D9\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <circle cx=\"123\" cy=\"252\" r=\"5\" fill=\"#4CAF50\"/>\n  <line x1=\"133\" y1=\"250\" x2=\"173\" y2=\"247\" stroke=\"#90A4AE\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"133\" y1=\"256\" x2=\"163\" y2=\"254\" stroke=\"#90A4AE\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Abstract Stars -->\n  <circle cx=\"123\" cy=\"268\" r=\"2.5\" fill=\"#FFC107\"/>\n  <circle cx=\"131\" cy=\"266\" r=\"2.5\" fill=\"#FFC107\"/>\n  <circle cx=\"139\" cy=\"264\" r=\"2.5\" fill=\"#FFC107\"/>\n  <circle cx=\"147\" cy=\"262\" r=\"2.5\" fill=\"#FFC107\"/>\n  <circle cx=\"155\" cy=\"260\" r=\"2.5\" fill=\"#CCCCCC\"/>\n\n  <!-- Abstract Review Text -->\n  <line x1=\"121\" y1=\"278\" x2=\"176\" y2=\"274\" stroke=\"#90A4AE\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"121\" y1=\"285\" x2=\"166\" y2=\"282\" stroke=\"#90A4AE\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Desk Lamp -->\n  <path d=\"M 75 320 Q 60 230 100 180\" fill=\"none\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <path d=\"M 90 170 L 115 190 L 103 204 L 78 184 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U07-S03-003-opt0.jpg?v=1783892605960"
