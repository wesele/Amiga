        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <defs>\n    <clipPath id=\"lake-clip\">\n      <rect x=\"40\" y=\"50\" width=\"320\" height=\"300\" rx=\"40\"/>\n    </clipPath>\n  </defs>\n\n  <g clip-path=\"url(#lake-clip)\">\n    <!-- Sky & Water Base -->\n    <rect x=\"40\" y=\"50\" width=\"320\" height=\"300\" fill=\"#4A90D9\"/>\n    \n    <!-- Sun -->\n    <circle cx=\"200\" cy=\"115\" r=\"35\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Sun Rays -->\n    <path d=\"M 200 68 L 200 55 M 200 162 L 200 175 M 153 115 L 140 115 M 247 115 L 260 115 M 167 82 L 157 72 M 233 82 L 243 72 M 167 148 L 157 158 M 233 148 L 243 158\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    \n    <!-- Clouds -->\n    <path d=\"M 75 135 C 75 125, 85 120, 95 120 C 102 108, 118 108, 125 120 C 135 120, 140 125, 140 135 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 265 115 C 265 105, 275 100, 285 100 C 292 88, 308 88, 315 100 C 325 100, 330 105, 330 115 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    \n    <!-- Background Hills -->\n    <ellipse cx=\"90\" cy=\"210\" rx=\"90\" ry=\"30\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <ellipse cx=\"310\" cy=\"205\" rx=\"100\" ry=\"35\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Water Overlay (Covers bottom of background hills) -->\n    <rect x=\"40\" y=\"210\" width=\"320\" height=\"140\" fill=\"#4A90D9\"/>\n    \n    <!-- Horizon Line -->\n    <line x1=\"40\" y1=\"210\" x2=\"360\" y2=\"210\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Sun Reflection on Calm Water -->\n    <path d=\"M 170 220 L 230 220 M 165 235 L 235 235 M 175 250 L 225 250 M 180 265 L 220 265 M 185 280 L 215 280 M 190 295 L 210 295 M 192 310 L 208 310 M 195 325 L 205 325\" stroke=\"#FFC107\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n    \n    <!-- Water Sheen Lines -->\n    <path d=\"M 70 230 L 120 230 M 280 225 L 320 225 M 240 265 L 280 265\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    \n    <!-- Foreground Grassy Banks -->\n    <ellipse cx=\"50\" cy=\"335\" rx=\"100\" ry=\"75\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <ellipse cx=\"350\" cy=\"335\" rx=\"110\" ry=\"80\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Grass Details -->\n    <path d=\"M 65 295 L 65 285 M 70 295 L 72 287 M 335 290 L 335 280 M 340 290 L 342 282\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n    <!-- Tree Trunks -->\n    <path d=\"M 75 270 L 75 205 M 40 270 L 40 225 M 325 265 L 325 200 M 360 275 L 360 225\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n    \n    <!-- Tree Foliage -->\n    <circle cx=\"75\" cy=\"205\" r=\"24\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <circle cx=\"90\" cy=\"195\" r=\"16\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <circle cx=\"40\" cy=\"220\" r=\"18\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <circle cx=\"325\" cy=\"200\" r=\"25\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <circle cx=\"310\" cy=\"190\" r=\"16\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <circle cx=\"360\" cy=\"220\" r=\"18\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  </g>\n\n  <!-- Outer Frame Border -->\n  <rect x=\"40\" y=\"50\" width=\"320\" height=\"300\" rx=\"40\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n</svg>",
