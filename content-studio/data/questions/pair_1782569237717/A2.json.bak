    "imageDesc": "一个人看着手机屏幕，屏幕上显示红色警告图标，旁边有一个带叉号的下载箭头，表示正在避免下载某个有问题的文件",
    "imagePrompt": "person holding smartphone, red warning icon on screen, download arrow with X symbol, worried facial expression, white background",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Torso / Shirt -->\n  <path d=\"M 100 400 C 100 220, 300 220, 300 400 Z\" fill=\"#F5F5F5\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Neck -->\n  <rect x=\"185\" y=\"145\" width=\"30\" height=\"30\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Head -->\n  <circle cx=\"200\" cy=\"115\" r=\"55\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Hair -->\n  <path d=\"M 142 115 C 140 60, 260 60, 258 115 C 270 100, 250 75, 200 70 C 150 75, 130 100, 142 115 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Worried Face Details -->\n  <circle cx=\"180\" cy=\"115\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"220\" cy=\"115\" r=\"5\" fill=\"#333333\"/>\n  <path d=\"M 165 105 Q 180 97 190 107\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 235 105 Q 220 97 210 107\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 190 140 Q 200 130 210 140\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Sweat Droplet -->\n  <path d=\"M 238 100 Q 238 108 233 108 Q 228 108 228 100 Q 233 92 238 100 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Smartphone Body -->\n  <rect x=\"120\" y=\"170\" width=\"160\" height=\"220\" rx=\"18\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Left Hand (Gripping Phone) -->\n  <rect x=\"98\" y=\"230\" width=\"30\" height=\"16\" rx=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"95\" y=\"260\" width=\"33\" height=\"16\" rx=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Phone Screen -->\n  <rect x=\"132\" y=\"182\" width=\"136\" height=\"196\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"180\" y1=\"368\" x2=\"220\" y2=\"368\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"185\" y1=\"176\" x2=\"215\" y2=\"176\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Screen Content: Warning Icon (Left) -->\n  <circle cx=\"172\" cy=\"250\" r=\"20\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"172\" y1=\"240\" x2=\"172\" y2=\"252\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <circle cx=\"172\" cy=\"260\" r=\"2.5\" fill=\"#FFFFFF\"/>\n\n  <!-- Screen Content: Crossed-out Download Arrow (Right) -->\n  <line x1=\"228\" y1=\"232\" x2=\"228\" y2=\"258\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 218 248 L 228 259 L 238 248\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <line x1=\"216\" y1=\"266\" x2=\"240\" y2=\"266\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 212 232 L 244 264 M 244 232 L 212 264\" stroke=\"#E53935\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n\n  <!-- Right Hand (Hesitating/Hovering) -->\n  <!-- Sleeve -->\n  <path d=\"M 335 340 L 400 310 L 400 400 L 370 400 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Hand Base -->\n  <path d=\"M 335 295 C 315 295, 305 315, 305 330 C 305 345, 325 355, 345 355 C 365 355, 375 335, 375 315 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Thumb -->\n  <path d=\"M 325 295 Q 315 275 325 265 Q 335 260 340 280 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Folded Fingers -->\n  <rect x=\"270\" y=\"300\" width=\"45\" height=\"16\" rx=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"285\" y=\"318\" width=\"35\" height=\"16\" rx=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Index Finger (Pointing and Hesitating) -->\n  <rect x=\"255\" y=\"280\" width=\"60\" height=\"18\" rx=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Warning Highlights (Alert Sparks) -->\n  <path d=\"M 245 275 L 235 270 M 240 289 L 225 289 M 245 303 L 235 308\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Shaking / Tremble Lines -->\n  <path d=\"M 320 265 Q 315 260 320 255 M 305 315 Q 300 320 305 325\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n</svg>",
