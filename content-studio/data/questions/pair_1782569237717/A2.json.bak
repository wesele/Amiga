        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Rain (back layer) -->\n  <line x1=\"80\" y1=\"60\" x2=\"60\" y2=\"100\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"150\" y1=\"50\" x2=\"130\" y2=\"90\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"330\" y1=\"70\" x2=\"310\" y2=\"110\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Clouds (Back) -->\n  <path d=\"M 230 100 C 230 75, 260 65, 280 80 C 295 70, 320 80, 315 105 Z\" fill=\"#333333\"/>\n\n  <!-- Clouds (Main & Left) -->\n  <path d=\"M 70 145 C 60 125, 80 105, 100 115 C 110 100, 135 105, 140 120 C 150 120, 155 130, 150 140 Z\" fill=\"#555555\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 140 140 C 130 110, 170 90, 190 100 C 210 70, 270 70, 290 95 C 320 80, 350 100, 340 130 C 355 140, 350 155, 330 155 Z\" fill=\"#555555\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Rain (mid layer) -->\n  <line x1=\"120\" y1=\"120\" x2=\"100\" y2=\"160\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"180\" y1=\"110\" x2=\"160\" y2=\"150\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"260\" y1=\"100\" x2=\"240\" y2=\"140\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"300\" y1=\"120\" x2=\"280\" y2=\"160\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Sea Background Wave -->\n  <path d=\"M 45 350 Q 120 300 200 320 T 355 310 L 355 350 L 45 350 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 115 305 Q 125 295 135 305\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 265 315 Q 275 305 285 315\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Wave Left (surging right) -->\n  <path d=\"M 50 350 C 100 350, 120 220, 220 220 C 250 220, 260 250, 230 270 C 190 300, 130 320, 50 350 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Wave Right (surging left) -->\n  <path d=\"M 350 350 C 300 350, 280 240, 180 240 C 150 240, 140 270, 170 290 C 210 320, 270 320, 350 350 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Foam Circles on Wave Left -->\n  <circle cx=\"220\" cy=\"220\" r=\"14\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"240\" cy=\"235\" r=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"205\" cy=\"215\" r=\"11\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Foam Circles on Wave Right -->\n  <circle cx=\"180\" cy=\"240\" r=\"14\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"160\" cy=\"255\" r=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"195\" cy=\"235\" r=\"11\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Central Crash Splash -->\n  <path d=\"M 175 290 L 155 230 L 185 250 L 200 160 L 215 250 L 245 230 L 225 290 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Splash Droplets -->\n  <circle cx=\"200\" cy=\"130\" r=\"6\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"140\" cy=\"210\" r=\"5\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"260\" cy=\"210\" r=\"5\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"180\" cy=\"150\" r=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"220\" cy=\"150\" r=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Foreground Rain (crosses everything) -->\n  <line x1=\"100\" y1=\"220\" x2=\"80\" y2=\"260\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"290\" y1=\"210\" x2=\"270\" y2=\"250\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"220\" y1=\"280\" x2=\"200\" y2=\"320\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"360\" y1=\"250\" x2=\"340\" y2=\"290\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"50\" y1=\"280\" x2=\"30\" y2=\"320\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n</svg>",
