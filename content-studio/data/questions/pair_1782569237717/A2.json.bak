        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n<rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n<!-- Bright Sun -->\n<circle cx=\"310\" cy=\"70\" r=\"28\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n<!-- Cloud -->\n<path d=\"M 50 90 L 110 90 A 10 10 0 0 0 110 70 A 15 15 0 0 0 85 60 A 12 12 0 0 0 55 75 A 10 10 0 0 0 50 90 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<!-- Ocean -->\n<rect x=\"-10\" y=\"220\" width=\"420\" height=\"190\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n<!-- Ocean Waves -->\n<path d=\"M 180 250 Q 200 245 220 250\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n<path d=\"M 230 310 Q 255 302 280 310\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n<!-- Sailboat in the Bay -->\n<path d=\"M 175 255 L 195 255 L 200 250 L 170 250 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n<polygon points=\"185,235 185,250 197,250\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n<!-- Right Cliff (Castle Rock) -->\n<polygon points=\"210,410 250,230 410,210 410,410\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<path d=\"M 250 230 L 280 320 M 310 220 L 330 350\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n<!-- Castle Keep (Center Wall) -->\n<path d=\"M 290 210 L 290 150 L 305 150 L 305 160 L 320 160 L 320 150 L 335 150 L 335 160 L 350 160 L 350 150 L 360 150 L 360 210 Z\" fill=\"#CFD8DC\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<!-- Castle Towers & Roofs -->\n<rect x=\"265\" y=\"110\" width=\"25\" height=\"100\" fill=\"#90A4AE\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<polygon points=\"260,110 277.5,70 295,110\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<rect x=\"360\" y=\"110\" width=\"25\" height=\"100\" fill=\"#90A4AE\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<polygon points=\"355,110 372.5,70 390,110\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<!-- Castle Gate & Windows -->\n<path d=\"M 312 210 L 312 185 A 13 13 0 0 1 338 185 L 338 210 Z\" fill=\"#333333\"/>\n<rect x=\"272\" y=\"130\" width=\"11\" height=\"20\" rx=\"3\" fill=\"#333333\"/>\n<rect x=\"367\" y=\"130\" width=\"11\" height=\"20\" rx=\"3\" fill=\"#333333\"/>\n<!-- Left Cliff (Foreground Lookout) -->\n<polygon points=\"-10,410 160,410 130,270 -10,270\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<path d=\"M -10 270 L 130 270 C 110 285 90 285 -10 285 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n<circle cx=\"135\" cy=\"275\" r=\"14\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n<circle cx=\"123\" cy=\"283\" r=\"10\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n<!-- Traveler Legs & Boots -->\n<rect x=\"81\" y=\"267\" width=\"16\" height=\"8\" rx=\"2\" fill=\"#5D4037\" stroke=\"#333333\" stroke-width=\"3\"/>\n<rect x=\"99\" y=\"267\" width=\"16\" height=\"8\" rx=\"2\" fill=\"#5D4037\" stroke=\"#333333\" stroke-width=\"3\"/>\n<rect x=\"71\" y=\"235\" width=\"9\" height=\"35\" rx=\"2\" fill=\"#333333\"/>\n<rect x=\"87\" y=\"235\" width=\"9\" height=\"35\" rx=\"2\" fill=\"#333333\"/>\n<!-- Traveler Backpack -->\n<rect x=\"46\" y=\"172\" width=\"16\" height=\"55\" rx=\"5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n<!-- Traveler Jacket (Body) -->\n<rect x=\"60\" y=\"165\" width=\"42\" height=\"75\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n<!-- Traveler Head & Cap -->\n<circle cx=\"83\" cy=\"140\" r=\"16\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n<path d=\"M 67 140 A 16 16 0 0 1 99 140 L 105 140 A