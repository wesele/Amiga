  {
    "id": "pair_1782569237717-B1-U10-S02-010",
    "type": "T12",
    "typeName": "Scenario Response",
    "language": "en",
    "cefr": "B1",
    "unit": "U10",
    "unitTheme": "Expressing Opinions on Global Trends and Economy",
    "difficulty": 3,
    "tags": [
