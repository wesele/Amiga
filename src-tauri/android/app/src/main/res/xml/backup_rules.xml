<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules for Android API 23–30 (Android 6.0–11).

  Back up the entire app's internal storage so user data (SQLite database,
  settings, vocabulary mastery) can be restored via Auto Backup.

  Uninstall retention on the same device is handled separately by
  android:hasFragileUserData on the <application> tag (see
  scripts/android-patch.cjs).

  See also data_extraction_rules.xml for API 31+.
-->
<full-backup-content>
    <include domain="file" path="." />
</full-backup-content>
