9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Tension Zigzag Lines -->\n  <path d=\"M 160 170 L 175 160 L 165 185 L 180 175\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M 240 170 L 225 160 L 235 185 L 220 175\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n</svg>",
