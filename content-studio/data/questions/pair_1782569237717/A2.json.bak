=\"M218 150 L204 195 L195 165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Head & Neck -->\n  <rect x=\"189\" y=\"133\" width=\"12\" height=\"18\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"195\" cy=\"110\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M167 110 C167 75 223 75 223 110 C223 95 210 92 195 92 C180 92 167 95 167 110 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Face Details -->\n  <circle cx=\"187\" cy=\"112\" r=\"3\" fill=\"#333333\"/>\n  <circle cx=\"203\" cy=\"112\" r=\"3\" fill=\"#333333\"/>\n  <path d=\"M188 123 Q195 128 202 123\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Left Arm & Yellow Document Folder -->\n  <path d=\"M158 152 L132 205 C132 205 142 220 152 215 L175 160 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Folder Back Flap -->\n  <polygon points=\"105,210 145,195 150,245 110,260\" fill=\"#FFA000\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Folder Papers -->\n  <polygon points=\"110,200 140,190 145,235 115,245\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Folder Front Flap -->\n  <polygon points=\"110,215 145,202 150,245 115,258\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Left Hand (holding folder) -->\n  <circle cx=\"140\" cy=\"222\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Right Arm (Gesturing/Pointing) -->\n  <path d=\"M230 155 L280 130 L290 148 L238 175 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Right Hand -->\n  <circle cx=\"288\" cy=\"135\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Pointing Finger -->\n  <path d=\"M294 131 L309 123\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Office Desk (Foreground divider) -->\n  <rect x=\"-10\" y=\"325\" width=\"420\" height=\"85\" fill=\"#F5F5F5\" str