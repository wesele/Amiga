        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Tech Aura/Security Rings -->\n  <circle cx=\"200\" cy=\"200\" r=\"170\" fill=\"none\" stroke=\"#E3F2FD\" stroke-width=\"3\" stroke-dasharray=\"10,10\"/>\n  <circle cx=\"200\" cy=\"200\" r=\"145\" fill=\"none\" stroke=\"#E3F2FD\" stroke-width=\"3\" stroke-dasharray=\"8,8\"/>\n  \n  <!-- Shadow Under Phone -->\n  <ellipse cx=\"200\" cy=\"350\" rx=\"70\" ry=\"10\" fill=\"#E0E0E0\"/>\n  \n  <!-- Smartphone Body -->\n  <rect x=\"120\" y=\"60\" width=\"160\" height=\"280\" rx=\"20\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Smartphone Screen -->\n  <rect x=\"132\" y=\"76\" width=\"136\" height=\"248\" rx=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Phone Details -->\n  <line x1=\"185\" y1=\"68\" x2=\"215\" y2=\"68\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"180\" y1=\"312\" x2=\"220\" y2=\"312\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Green Security Shield -->\n  <path d=\"M 160 155 Q 200 165 240 155 L 240 205 Q 240 240 200 255 Q 160 240 160 205 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Prominent White Checkmark on Shield -->\n  <path d=\"M182 205 L197 220 L222 190\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  \n  <!-- Connection Lines (Files to Screen) -->\n  <path d=\"M105 132 Q130 120 145 135\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-dasharray=\"5,5\" stroke-linecap=\"round\"/>\n  <path d=\"M295 122 Q270 110 255 125\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-dasharray=\"5,5\" stroke-linecap=\"round\"/>\n  <path d=\"M100 237 Q125 235 140 220\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-dasharray=\"5,5\" stroke-linecap=\"round\"/>\n  <path d=\"M295 242 Q270 240 255 225\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-dasharray=\"5,5\" stroke-linecap=\"round\"/>\n  \n  <!-- File 1 (Top Left) -->\n  <g>\n    <polygon points=\"70,110 95,110 105,120 105,155 70,155\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <polygon points=\"95,110 95,120 105,120\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=\"77\" y1=\"130\" x2=\"98\" y2=\"130\" stroke=\"#B0BEC5\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <line x1=\"77\" y1=\"140\" x2=\"91\" y2=\"140\" stroke=\"#B0BEC5\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <circle cx=\"105\" cy=\"155\" r=\"10\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <path d=\"M101 155 L104 158 L109 152\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  </g>\n  \n  <!-- File 2 (Top Right) -->\n  <g>\n    <polygon points=\"295,100 320,100 330,110 330,145 295,145\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <polygon points=\"320,100 320,110 330,110\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=\"302\" y1=\"120\" x2=\"323\" y2=\"120\" stroke=\"#B0BEC5\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <line x1=\"302\" y1=\"130\" x2=\"316\" y2=\"130\" stroke=\"#B0BEC5\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <circle cx=\"330\" cy=\"145\" r=\"10\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <path d=\"M326 145 L329 148 L334 142\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  </g>\n  \n  <!-- File 3 (Bottom Left) -->\n  <g>\n    <polygon points=\"65,215 90,215 100,225 100,260 65,260\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <polygon points=\"90,215 90,225 100,225\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=