    location /llm/dashscope/ {
        limit_conn amiga_llm_global 24;
        limit_conn amiga_per_ip 4;
        proxy_pass https://dashscope.aliyuncs.com/;
        proxy_set_header Host dashscope.aliyuncs.com;
        proxy_ssl_server_name on;
        proxy_ssl_name dashscope.aliyuncs.com;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        proxy_connect_timeout 10s;
        proxy_read_timeout 300s;
    }

    location /llm/gemini/ {
        limit_conn amiga_llm_global 24;
        limit_conn amiga_per_ip 4;
        proxy_pass https://generativelanguage.googleapis.com/;
        proxy_set_header Host generativelanguage.googleapis.com;
        proxy_ssl_server_name on;
        proxy_ssl_name generativelanguage.googleapis.com;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        proxy_connect_timeout 10s;
        proxy_read_timeout 300s;
    }

    # Fixed news aliases. The browser never supplies an upstream URL.
    location = /news/rtve/rss.xml {
        limit_conn amiga_news_global 10;
        limit_conn amiga_per_ip 4;
        proxy_pass https://www.rtve.es/rss/tag_noticias.xml;
        proxy_set_header Host www.rtve.es;
        proxy_ssl_server_name on;
        proxy_ssl_name www.rtve.es;
        proxy_buffering off;
        proxy_connect_timeout 8s;
        proxy_read_timeout 20s;
    }

    location = /news/elmundo/rss.xml {
        limit_conn amiga_news_global 10;
        limit_conn amiga_per_ip 4;
        proxy_pass https://e00-elmundo.uecdn.es/elmundo/rss/portada.xml;
        proxy_set_header Host e00-elmundo.uecdn.es;
        proxy_ssl_server_name on;
        proxy_ssl_name e00-elmundo.uecdn.es;
        proxy_buffering off;
        proxy_connect_timeout 8s;
        proxy_read_timeout 20s;
    }

    location = /news/abc/rss.xml {
        limit_conn amiga_news_global 10;
        limit_conn amiga_per_ip 4;
        proxy_pass https://www.abc.es/rss/2.xml;
        proxy_set_header Host www.abc.es;
        proxy_ssl_server_name on;
        proxy_ssl_name www.abc.es;
        proxy_buffering off;
        proxy_connect_timeout 8s;
        proxy_read_timeout 20s;
    }

    location = /news/npr/rss.xml {
        limit_conn amiga_news_global 10;
        limit_conn amiga_per_ip 4;
        proxy_pass https://feeds.npr.org/1001/rss.xml;
        proxy_set_header Host feeds.npr.org;
        proxy_ssl_server_name on;
        proxy_ssl_name feeds.npr.org;
        proxy_buffering off;
        proxy_connect_timeout 8s;
        proxy_read_timeout 20s;
    }

    location = /news/nyt/rss.xml {
        limit_conn amiga_news_global 10;
        limit_conn amiga_per_ip 4;
        proxy_pass https://rss.nytimes.com/services/xml/rss/nyt/World.xml;
        proxy_set_header Host rss.nytimes.com;
        proxy_ssl_server_name on;
        proxy_ssl_name rss.nytimes.com;
        proxy_buffering off;
        proxy_connect_timeout 8s;
        proxy_read_timeout 20s;
    }

    location = /news/chinadaily/rss.xml {
        limit_conn amiga_news_global 10;
        limit_conn amiga_per_ip 4;
        proxy_pass https://www.chinadaily.com.cn/rss/world_rss.xml;
        proxy_set_header Host www.chinadaily.com.cn;
        proxy_ssl_server_name on;
        proxy_ssl_name www.chinadaily.com.cn;
        proxy_buffering off;
        proxy_connect_timeout 8s;
        proxy_read_timeout 20s;
