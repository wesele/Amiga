        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Stairs -->\n  <path d=\"M 10 400 L 10 180 L 90 180 L 90 235 L 170 235 L 170 290 L 250 290 L 250 400 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Stairs Tread Lines (Step Tops) -->\n  <line x1=\"10\" y1=\"195\" x2=\"90\" y2=\"195\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"90\" y1=\"250\" x2=\"170\" y2=\"250\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"170\" y1=\"305\" x2=\"250\" y2=\"305\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Wood Grain Details -->\n  <path d=\"M 30 215 L 70 215\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 110 270 L 150 270\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 190 340 L 230 340\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Slip Action/Skid Marks on Step 2 -->\n  <path d=\"M 115 230 Q 105 210 90 215\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"/>\n  <path d=\"M 135 230 Q 145 210 160 215\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"/>\n  <path d=\"M 125 230 Q 125 205 125 200\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"/>\n  <path d=\"M 105 232 L 135 232\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Motion Lines -->\n  <path d=\"M 70 160 Q 110 145 150 160\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\"/>\n  <path d=\"M 110 215 Q 140 205 170 220\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"/>\n  <path d=\"M 160 120 Q 200 110 240 125\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\"/>\n\n  <!-- Tumbling Girl Group -->\n  <g transform=\"translate(230, 195) rotate(35)\">\n    <!-- Left Leg (Flying Up) -->\n    <path d=\"M -15 35 Q -40 70 -70 65\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" fill=\"none\"/>\n    <path d=\"M -15 35 Q -40 70 -70 65\" stroke=\"#4A90D9\" stroke-width=\"14\" stroke-linecap=\"round\" fill=\"none\"/>\n    <path d=\"M -60 67 L -70 65\" stroke=\"#FFD1A9\" stroke-width=\"14\" stroke-linecap=\"round\" fill=\"none\"/>\n    <circle cx=\"-75\" cy=\"65\" r=\"10\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n    <!-- Right Leg (Slipping) -->\n    <path d=\"M 15 35 Q 35 70 20 95\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" fill=\"none\"/>\n    <path d=\"M 15 35 Q 35 70 20 95\" stroke=\"#4A90D9\" stroke-width=\"14\" stroke-linecap=\"round\" fill=\"none\"/>\n    <path d=\"M 23 85 L 20 95\" stroke=\"#FFD1A9\" stroke-width=\"14\" stroke-linecap=\"round\" fill=\"none\"/>\n    <circle cx=\"18\" cy=\"103\" r=\"10\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n    <!-- Neck -->\n    <rect x=\"-8\" y=\"-62\" width=\"16\" height=\"20\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n    <!-- Torso -->\n    <rect x=\"-24\" y=\"-50\" width=\"48\" height=\"85\" rx=\"16\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n    <!-- Left Upper Arm (Injured) -->\n    <path d=\"M -22 -40 L -32 -10\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\" fill=\"none\"/>\n    <path d=\"M -22 -40 L -32 -10\" stroke=\"#4A90D9\" stroke-width=\"10\" stroke-linecap=\"round\" fill=\"none\"/>\n\n    <!-- Red Sling Pouch -->\n    <path d=\"M -6 -55 L -28 -18 L 10 -14 L 6 -55 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n    <!-- Plaster Cast -->\n    <g transform=\"translate(-10, -5) rotate(-10)\">\n      <rect x=\"-25\" y=\"-12\" width=\"60\" height=\"24\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n      <!-- Bandage Lines -->\n      <line x1=\"-12\" y1=\"-1