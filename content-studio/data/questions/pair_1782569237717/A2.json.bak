        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Overall Field Shadow (Sticker effect) -->\n  <polygon points=\"40,108 360,108 390,308 10,308\" fill=\"#E0E0E0\"/>\n\n  <!-- Red Running Track Border -->\n  <polygon points=\"40,100 360,100 390,300 10,300\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Track Lanes (White lines) -->\n  <polygon points=\"50,110 350,110 378,290 22,290\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n  <polygon points=\"60,120 340,120 366,280 34,280\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n\n  <!-- Green Field -->\n  <polygon points=\"70,130 330,130 354,270 46,270\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Field White Markings -->\n  <polygon points=\"82,142 318,142 340,258 60,258\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <!-- Center Line -->\n  <line x1=\"200\" y1=\"142\" x2=\"200\" y2=\"258\" stroke=\"#FFFFFF\" stroke-width=\"3\"/>\n  <!-- Center Circle -->\n  <ellipse cx=\"200\" cy=\"200\" rx=\"35\" ry=\"15\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\"/>\n  <!-- Penalty Box Left -->\n  <polygon points=\"82,175 115,177 112,223 66,225\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2.5\" stroke-linejoin=\"round\"/>\n  <!-- Penalty Box Right -->\n  <polygon points=\"318,175 285,177 288,223 334,225\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"2.5\" stroke-linejoin=\"round\"/>\n\n  <!-- Soccer Goals -->\n  <path d=\"M 77 185 L 60 185 L 56 215 L 70 215\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <path d=\"M 323 185 L 340 185 L 344 215 L 330 215\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linejo