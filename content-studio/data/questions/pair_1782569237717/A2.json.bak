      {
        "desc": "图表显示50%的在线犯罪风险百分比柱状图",
        "prompt": "bar chart showing fifty percent crime risk percentage, orange and yellow bars on white background, simple infographic style",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Canvas Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Card Shadow -->\n  <rect x=\"56\" y=\"86\" width=\"300\" height=\"240\" rx=\"12\" fill=\"#E0E0E0\"/>\n\n  <!-- Main Card Body -->\n  <rect x=\"50\" y=\"80\" width=\"300\" height=\"240\" rx=\"12\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Header Bar -->\n  <path d=\"M 50 120 L 50 92 A 12 12 0 0 1 62 80 L 338 80 A 12 12 0 0 1 350 92 L 350 120 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Window controls -->\n  <circle cx=\"75\" cy=\"100\" r=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"93\" cy=\"100\" r=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"111\" cy=\"100\" r=\"6\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Header Placeholder Text -->\n  <rect x=\"135\" y=\"96\" width=\"80\" height=\"8\" rx=\"4\" fill=\"#FFFFFF\" opacity=\"0.8\"/>\n\n  <!-- Shield Icon (representing Security/Risk) -->\n  <path d=\"M 310 92 L 320 92 L 320 100 C 320 107 315 112 315 112 C 315 112 310 107 310 100 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Chart Grid Lines -->\n  <line x1=\"75\" y1=\"150\" x2=\"80\" y2=\"150\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"75\" y1=\"210\" x2=\"80\" y2=\"210\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"75\" y1=\"270\" x2=\"80\" y2=\"270\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <line x1=\"80\" y1=\"150\" x2=\"215\" y2=\"150\" stroke=\"#E0E0E0\" stroke-width=\"2\" stroke-dasharray=\"4 4\"/>\n  <line x1=\"80\" y1=\"210\" x2=\"215\" y2=\"210\" stroke=\"#333333\" stroke-width=\"2\" stroke-dasharray=\"4 4\"/>\n  \n  <!-- Y & X Axes -->\n  <line x1=\"80\" y1=\"140\" x2=\"80\" y2=\"270\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"80\" y1=\"270\" x2=\"215\" y2=\"270\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Bar 1 (Active, 50% filled) -->\n  <!-- Background/Inactive Outer Bar -->\n  <rect x=\"95\" y=\"150\" width=\"40\" height=\"120\" rx=\"4\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Active Bottom Fill (50%) -->\n  <path d=\"M 95 210 L 135 210 L 135 266 C 135 268.2 133.2 270 131 270 L 99 270 C 96.8 270 95 268.2 95 266 Z\" fill=\"#FFC107\"/>\n  <!-- Middle Divider Line -->\n  <line x1=\"95\" y1=\"210\" x2=\"135\" y2=\"210\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Bar 2 (Baseline, 100% Inactive/Baseline Fill) -->\n  <rect x=\"155\" y=\"150\" width=\"40\" height=\"120\" rx=\"4\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Labels under Bars -->\n  <rect x=\"95\" y=\"282\" width=\"40\" height=\"8\" rx=\"4\" fill=\"#D0D0D0\"/>\n  <rect x=\"155\" y=\"282\" width=\"40\" height=\"8\" rx=\"4\" fill=\"#D0D0D0\"/>\n\n  <!-- Progress Ring (50% filled) -->\n  <!-- Outer Ring Background (Inactive) -->\n  <circle cx=\"275\" cy=\"210\" r=\"45\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Active Ring Overlay (Right Half - 50%) -->\n  <path d=\"M 275 165 A 45 45 0 0 1 275 255 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Inner Cutout (making it a ring) -->\n  <circle cx=\"275\" cy=\"210\" r=\"22\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Label under Progress Ring -->\n  <rect x=\"255\" y=\"282\" width=\"40\" height=\"8\" rx=\"4\" fill=\"#D0D0D0\"/>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U07-S04-003-opt3.jpg?v=1783893598484"
      }
