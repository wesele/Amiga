        "desc": "一个人在超市货架前阅读商品标签",
        "prompt": "person standing in supermarket aisle reading a product label, colorful shelves, bright fluorescent lighting",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Background Shelves & Items -->\n  <!-- Upper Shelf -->\n  <rect x=\"20\" y=\"160\" width=\"360\" height=\"10\" fill=\"#D7CCC8\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Upper Shelf Items -->\n  <rect x=\"40\" y=\"110\" width=\"25\" height=\"50\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" rx=\"3\"/>\n  <rect x=\"70\" y=\"100\" width=\"30\" height=\"60\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" rx=\"3\"/>\n  <rect x=\"300\" y=\"105\" width=\"22\" height=\"55\" rx=\"5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"330\" y=\"120\" width=\"20\" height=\"40\" rx=\"2\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Price Tag Upper -->\n  <rect x=\"75\" y=\"170\" width=\"15\" height=\"10\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Lower Shelf -->\n  <rect x=\"20\" y=\"280\" width=\"360\" height=\"10\" fill=\"#D7CCC8\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Lower Shelf Items -->\n  <rect x=\"35\" y=\"230\" width=\"30\" height=\"50\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" rx=\"3\"/>\n  <rect x=\"75\" y=\"225\" width=\"22\" height=\"55\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"300\" y=\"220\" width=\"35\" height=\"60\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" rx=\"3\"/>\n  <rect x=\"345\" y=\"240\" width=\"20\" height=\"40\" rx=\"2\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Price Tags Lower -->\n  <rect x=\"40\" y=\"290\" width=\"15\" height=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"310\" y=\"290\" width=\"15\" height=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Pants / Lower Body -->\n  <path d=\"M 188 320 L 262 330 L 255 400 L 180 400 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Right Arm (Background Arm) -->\n  <path d=\"M 210 240 L 160 220\" stroke=\"#333333\" stroke-width=\"24\" stroke-linecap=\"round\" fill=\"none\"/>\n  <path d=\"M 210 240 L 160 220\" stroke=\"#4A90D9\" stroke-width=\"16\" stroke-linecap=\"round\" fill=\"none\"/>\n  <circle cx=\"145\" cy=\"215\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Torso (Shirt) -->\n  <path d=\"M 195 240 L 270 260 L 262 330 L 188 320 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Neck -->\n  <path d=\"M 205 245 L 210 180 L 225 180 L 235 248 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 195 245 L 220 265 L 245 250\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Head & Face Profile -->\n  <circle cx=\"205\" cy=\"155\" r=\"32\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 175 155 L 158 162 L 175 168 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <circle cx=\"225\" cy=\"160\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Hair -->\n  <path d=\"M 180 140 C 175 120, 205 110, 230 120 C 242 128, 240 152, 236 158 C 234 150, 230 144, 222 144 C 210 144, 195 148, 180 140 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Eyes & Eyebrow -->\n  <path d=\"M 188 144 L 178 147\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 185 153 Q 179 156 177 152\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Glasses (Reading closely) -->\n  <circle cx=\"178\" cy=\"158\" r=\"11\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 189 158 Q