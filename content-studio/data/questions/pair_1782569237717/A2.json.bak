    "imagePrompt": "person sitting at desk, holding certificate, checklist with checkmarks on table, satisfied expression, simple office background",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Chair Back -->\n  <rect x=\"125\" y=\"150\" width=\"150\" height=\"150\" rx=\"20\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Torso / Clothes -->\n  <path d=\"M 110 300 C 110 230, 290 230, 290 300 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 180 230 Q 200 245 220 230\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Neck -->\n  <rect x=\"185\" y=\"198\" width=\"30\" height=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Head -->\n  <circle cx=\"200\" cy=\"165\" r=\"42\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Hair -->\n  <path d=\"M 155 170 Q 200 110 245 170\" fill=\"none\" stroke=\"#333333\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n  <path d=\"M 160 170 Q 200 115 240 170 Z\" fill=\"#333333\"/>\n  \n  <!-- Face Details -->\n  <path d=\"M 178 165 Q 187 157 192 165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 208 165 Q 213 157 222 165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 188 182 Q 200 194 212 182\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>\n  \n  <!-- Arms (Behind Certificate) -->\n  <path d=\"M 120 245 L 95 260 L 115 275 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 280 245 L 305 260 L 285 275 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Desk -->\n  <rect x=\"-10\" y=\"300\" width=\"420\" height=\"110\" fill=\"#ECEFF1\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Certificate (Held by Person) -->\n  <rect x=\"120\" y=\"205\" width=\"160\" height=\"110\" rx=\"6\" fill=\"#FFFFFF\" stroke=\"#33