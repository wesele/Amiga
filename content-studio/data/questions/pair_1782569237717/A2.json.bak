        "prompt": "girl in white lab coat standing at lab bench with test tubes and beakers, indoor laboratory, blue and white colors",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Background Sparkles / Chemistry Magic -->\n  <path d=\"M 140 102 L 143 107 L 148 110 L 143 113 L 140 118 L 137 113 L 132 110 L 137 107 Z\" fill=\"#FFC107\"/>\n  <path d=\"M 270 112 L 273 117 L 278 120 L 273 123 L 270 128 L 267 123 L 262 120 L 267 117 Z\" fill=\"#4CAF50\"/>\n  <path d=\"M 345 177 L 348 182 L 353 185 L 348 188 L 345 193 L 342 188 L 337 185 L 342 182 Z\" fill=\"#E53935\"/>\n  <path d=\"M 75 167 L 78 172 L 83 175 L 78 178 L 75 183 L 72 178 L 67 175 L 72 172 Z\" fill=\"#4A90D9\"/>\n\n  <!-- Character Hair Back -->\n  <path d=\"M 160 145 C 150 110, 160 80, 200 80 C 240 80, 250 110, 240 145 C 248 165, 235 180, 235 180 L 165 180 C 165 180, 152 165, 160 145 Z\" fill=\"#333333\"/>\n  <circle cx=\"155\" cy=\"85\" r=\"18\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"245\" cy=\"85\" r=\"18\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Character Head & Neck -->\n  <rect x=\"188\" y=\"160\" width=\"24\" height=\"25\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"162\" cy=\"142\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"238\" cy=\"142\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"200\" cy=\"138\" r=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Character Hair Front -->\n  <path d=\"M 165 125 C 175 110, 185 110, 200 120 C 215 110, 225 110, 235 125 C 235 125, 235 100, 200 100 C 165 100, 165 125, 165 125 Z\" fill=\"#333333\"/>\n\n  <!-- Face Details -->\n  <path d=\"M 199 142 L 199 148\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 195 156 Q 200 160 205 156\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Safety Goggles -->\n  <rect x=\"171\" y=\"125\" width=\"25\" height=\"22\" rx=\"6\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n  <rect x=\"204\" y=\"125\" width=\"25\" height=\"22\" rx=\"6\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n  <rect x=\"196\" y=\"133\" width=\"8\" height=\"4\" fill=\"#333333\" rx=\"1\"/>\n  <line x1=\"162\" y1=\"135\" x2=\"171\" y2=\"135\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n  <line x1=\"229\" y1=\"135\" x2=\"238\" y2=\"135\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n  <line x1=\"175\" y1=\"130\" x2=\"181\" y2=\"140\" stroke=\"#FFFFFF\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  <line x1=\"208\" y1=\"130\" x2=\"214\" y2=\"140\" stroke=\"#FFFFFF\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n  <!-- Eyes (Visible behind goggles) -->\n  <path d=\"M 177 137 Q 183 141 189 137\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 211 137 Q 217 141 223 137\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Shirt (V-neck) -->\n  <polygon points=\"175,180 225,180 200,220\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Lab Coat Body -->\n  <path d=\"M 150 280 L 165 180 C 165 180, 180 180, 180 180 L 200 215 L 220 180 L 235 180 L 250 280 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 165 180 L 185 225 L 200 215 L 180 180 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 235 180 L 215 225 L 200 215 L 220 180 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"200\" y1=\"215\" x2=\"200\" y2=\"280\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"200\" cy=\"245\" r=\"4\" fill=\"#333333\"/>\n  <circle cx=\"200\" cy=\"270\" r=\"4\" fill=\"#333333\"/>\n\n  <!-- Lab Bench Support Legs (Behind table top) -->\n  <line x1=\"70\" y1=\"295\" x2=\"70\" y2=\"390\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <line x1=\"330\" y1=\"295\" x2=\"330\" y2=\"390\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n\n  <!-- Lab Bench Table Top -->\n  <rect x=\"20\" y=\"285\" width=\"360\" height=\"15\" rx=\"4\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Test Tube Rack (Left) -->\n  <!-- Back pillars & shelf -->\n  <line x1=\"53\" y1=\"245\" x2=\"53\" y2=\"275\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"117\" y1=\"245\" x2=\"117\" y2=\"275\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"50\" y=\"275\" width=\"70\" height=\"10\" rx=\"2\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Tubes in Rack -->\n  <!-- Tube 1 (Red) -->\n  <path d=\"M 62 230 L 62 275 C 62 280, 72 280, 72 275 L 72 230 Z\" fill=\"#FFFFFF\"/>\n  <path d=\"M 64 250 L 64 274 C 64 278, 70 278, 70 274 L 70 250 Z\" fill=\"#E53935\"/>\n  <path d=\"M 62 230 L 62 275 C 62 280, 72 280, 72 275 L 72 230\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <ellipse cx=\"67\" cy=\"230\" rx=\"6\" ry=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Tube 2 (Green) -->\n  <path d=\"M 80 230 L 80 275 C 80 280, 90 280, 90 275 L 90 230 Z\" fill=\"#FFFFFF\"/>\n  <path d=\"M 82 255 L 82 274 C 82 278, 88 278, 88 274 L 88 255 Z\" fill=\"#4CAF50\"/>\n  <path d=\"M 80 230 L 80 275 C 80 280, 90 280, 90 275 L 90 230\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <ellipse cx=\"85\" cy=\"230\" rx=\"6\" ry=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Tube 3 (Blue) -->\n  <path d=\"M 98 230 L 98 275 C 98 280, 108 280, 108 275 L 108 230 Z\" fill=\"#FFFFFF\"/>\n  <path d=\"M 100 260 L 100 274 C 100 278, 106 278, 106 274 L 106 260 Z\" fill=\"#4A90D9\"/>\n  <path d=\"M 98 230 L 98 275 C 98 280, 108 280, 108 275 L 108 230\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <ellipse cx=\"103\" cy=\"230\" rx=\"6\" ry=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Rack Front Bar -->\n  <rect x=\"50\" y=\"245\" width=\"70\" height=\"8\" rx=\"2\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Beaker (Center-Right, receiving liquid) -->\n  <path d=\"M 185 225 L 185 282 A 3 3 0 0 0 188 285 L 232 285 A 3 3 0 0 0 235 282 L 235 225 Z\" fill=\"#FFFFFF\"/>\n  <path d=\"M 185.5 255 L 234.5 255 L 234.5 282 C 234.5 284, 232 284, 230 284 L 190 284 C 188 284 185.5 284 185.5 282 Z\" fill=\"#4CAF50\"/>\n  <path d=\"M 185 225 L 185 282 A 3 3 0 0 0 188 285 L 232 285 A 3 3 0 0 0 235 282 L 235 225\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 181 225 L 185 225 M 235 225 L 239 225\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <!-- Beaker Markings -->\n  <line x1=\"220\" y1=\"240\" x2=\"228\" y2=\"240\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"220\" y1=\"250\" x2=\"225\" y2=\"250\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"220\" y1=\"260\" x2=\"228\" y2=\"260\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <line x1=\"220\" y1=\"270\" x2=\"225\" y2=\"270\" stroke=\"#FFFFFF\" stroke-width=\"2\"/>\n  <!-- Bubbles in Beaker -->\n  <circle cx=\"205\" cy=\"245\" r=\"4.5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n  <circle cx=\"220\" cy=\"237\" r=\"3.5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n  <circle cx=\"195\" cy=\"233\" r=\"2.5\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"1\"/>\n\n  <!-- Erlenmeyer Flask (Right) -->\n  <path d=\"M 303 230 L 317 230 L 317 245 L 333 280 C 335 285, 285 285, 287 280 L 303 245 Z\" fill=\"#FFFFFF\"/>\n  <path d=\"M 297 263 L 323 263 L 331 280 C 332.5 283, 287.5 283, 289 280 Z\" fill=\"#E53935\"/>\n  <path d=\"M 303 230 L 317 230 L 317 245 L 333 280 C 335 285, 285 285, 287 280 L 303 245 Z\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"310\" cy=\"230\" rx=\"8\" ry=\"2.5\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"315\" y1=\"274\"