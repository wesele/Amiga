    "imageDesc": "一位记者坐在桌前，手持话筒，正在对着摄像机进行采访报道，桌上放着笔记本和新闻稿",
    "imagePrompt": "journalist sitting at desk, holding microphone, facing camera, notepad and papers on desk, professional studio background",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Studio Screen (Green Screen Backdrop) -->\n  <rect x=\"40\" y=\"40\" width=\"320\" height=\"210\" rx=\"12\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"70\" cy=\"70\" r=\"7\" fill=\"#E53935\"/>\n  <path d=\"M60 90 L60 60 L90 60\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>\n  <path d=\"M340 90 L340 60 L310 60\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>\n\n  <!-- Journalist Behind the Desk -->\n  <!-- Hair Back -->\n  <circle cx=\"200\" cy=\"146\" r=\"38\" fill=\"#333333\"/>\n  \n  <!-- Neck -->\n  <rect x=\"186\" y=\"175\" width=\"28\" height=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Suit Body -->\n  <path d=\"M120 260 C120 205, 280 205, 280 260 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <polygon points=\"182 205, 218 205, 200 232\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"196 232, 204 232, 207 260, 200 266, 193 260\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- Head & Face -->\n  <ellipse cx=\"200\" cy=\"165\" rx=\"32\" ry=\"36\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M168 150 C180 135, 200 135, 205 150 C210 135, 230 135, 232 150 C235 140, 225 130, 200 130 C175 130, 165 140, 168 150 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"188\" cy=\"165\" r=\"4.5\" fill=\"#333333\"/>\n  <circle cx=\"212\" cy=\"165\" r=\"4.5\" fill=\"#333333\"/>\n  <path d=\"M200 165 L200 173 Q200 176 197 176\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M190 182 Q200 195 210 182 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Left Arm & Hand (Gesturing) -->\n  <path d=\"M120 260 L95 205 L118 195 L140 240 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <circle cx=\"106\" cy=\"198\" r=\"14\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M96 194 Q88 198 96 206\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Microphone (Behind the hand) -->\n  <rect x=\"246\" y=\"175\" width=\"10\" height=\"45\" rx=\"2\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Right Arm & Hand (Holding Mic) -->\n  <path d=\"M280 260 L245 210 L268 200 L295 240 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <circle cx=\"251\" cy=\"202\" r=\"14\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Microphone Top (In front of hand) -->\n  <rect x=\"236\" y=\"148\" width=\"30\" height=\"22\" rx=\"4\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"251\" cy=\"133\" rx=\"18\" ry=\"20\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Desk -->\n  <path d=\"M30 275 L370 275 L350 400 L50 400 Z\" fill=\"#F5F5F5\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"15\" y=\"260\" width=\"370\" height=\"18\" rx=\"5\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Desk Accessories -->\n  <!-- Notepad -->\n  <rect x=\"70\" y=\"290\" width=\"100\" height=\"70\" rx=\"5\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"75\" y=\"295\" width=\"90\" height=\"60\" rx=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"120\" y1=\"295\" x2=\"120\" y2=\"355\" stroke=\"#333333\" stroke-width=\"3\" stroke-dasharray=\"3 5\"/>\n\n  <!-- Pen -->\n  <path d=\"M150 340 L180 310\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n  <path d=\"M150 340 L180 310\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Coffee Mug -->\n  <rect x=\"185\" y=\"295\" width=\"30\" height=\"35\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M215 303 C223 303 223 322 215 322\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Loose Sheets of Paper -->\n  <polygon points=\"260 310, 315 295, 330 350, 270 365\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"270 305, 325 315, 315 370, 260 360\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n</svg>",
