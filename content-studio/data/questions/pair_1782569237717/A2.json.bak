      {
        "desc": "一个人在海上扬帆",
        "prompt": "person sailing on blue ocean water, white sailboat with large sail, bright sky, waves visible around boat",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Sun -->\n  <circle cx=\"320\" cy=\"80\" r=\"25\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"320\" y1=\"45\" x2=\"320\" y2=\"35\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"320\" y1=\"115\" x2=\"320\" y2=\"125\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"285\" y1=\"80\" x2=\"275\" y2=\"80\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"355\" y1=\"80\" x2=\"365\" y2=\"80\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"295\" y1=\"55\" x2=\"288\" y2=\"48\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"345\" y1=\"105\" x2=\"352\" y2=\"112\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Clouds -->\n  <path d=\"M 50 95 L 110 95 A 15 15 0 0 0 100 70 A 20 20 0 0 0 80 70 A 15 15 0 0 0 50 95 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 220 125 L 270 125 A 10 10 0 0 0 262 105 A 15 15 0 0 0 240 105 A 10 10 0 0 0 220 125 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Seagull -->\n  <path d=\"M 140 70 Q 148 62 155 70 Q 162 62 170 70\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  \n  <!-- Background Waves -->\n  <path d=\"M -10 300 Q 50 275 110 300 T 230 300 T 350 300 T 410 300 L 410 410 L -10 410 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Sailboat & Sailor Group (Tilted to represent wind/motion) -->\n  <g transform=\"translate(195, 265) rotate(-8)\">\n    <!-- Rudder -->\n    <path d=\"M -85 10 L -98 15 L -98 32 L -88 27 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    \n    <!-- Tiller -->\n    <path d=\"M -90 5 L -55 5\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    \n    <!-- Mast -->\n    <line x1=\"0\" y1=\"-15\" x2=\"0\" y2=\"-190\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n    \n    <!-- Main Sail -->\n    <path d=\"M 0 -180 Q -65 -110 -80 -40 Q -35 -30 0 -30 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M 0 -130 Q -42 -90 -55 -55 Q -25 -48 0 -48 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n    \n    <!-- Jib Sail -->\n    <path d=\"M 3 -155 Q 45 -85 75 -20 Q 40 -20 15 -30 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    \n    <!-- Hull -->\n    <path d=\"M -90 -15 L 75 -15 C 95 -15 105 -5 110 10 L 85 25 L -80 25 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <path d=\"M -83 5 L 91 5 C 93 5 95 7 96 9 L 89 17 L -77 17 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n    \n    <!-- Sailor (Leaning Out) -->\n    <!-- Hips/Pants -->\n    <ellipse cx=\"-35\" cy=\"-15\" rx=\"10\" ry=\"6\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Torso (Lifejacket) -->\n    <path d=\"M -45 -15 L -65 -28 L -57 -40 L -30 -22 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    <!-- Head -->\n    <circle cx=\"-64\" cy=\"-44\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Cap -->\n    <path d=\"M -72 -47 C -72 -56 -56 -54 -56 -45 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=\"-56\" y1=\"-46\" x2=\"-49\" y2=\"-44\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <!-- Face details -->\n    <circle cx=\"-61\" cy=\"-44\" r=\"1.2\" fill=\"#333333\"/>\n    <path d=\"M -63 -40 Q -61 -38 -59 -41\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n    <!-- Arm holding tiller -->\n    <path d=\"M -48 -28 L -40 -18 L -55 5\" fill=\"none\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M -48 -28 L -40 -18 L -55 5\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    \n    <!-- Water Splashes at Bow -->\n    <path d=\"M 105 10 C 120 -5 135 -10 130 10 C 125 20 115 20 105 10 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <path d=\"M 120 15 C 135 5 145 5 140 20 C 135 30 125 25 120 15 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n  \n  <!-- Foreground Waves -->\n  <path d=\"M -10 315 Q 60 295 130 315 T 270 315 T 410 315 L 410 410 L -10 410 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Wave Lines for Texture -->\n  <path d=\"M 40 345 Q 80 335 120 345\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 280 355 Q 320 345 360 355\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 150 375 Q 190 365 230 375\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n</svg>",
