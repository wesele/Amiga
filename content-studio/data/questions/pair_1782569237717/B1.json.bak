  {
    "id": "pair_1782569237717-B1-U10-S03-004",
    "type": "T08",
    "typeName": "听力选择",
    "language": "en",
    "cefr": "B1",
    "unit": "U10",
    "unitTheme": "Respectful Disagreement and Persuasion",
    "difficulty": 3,
    "tags": [
      "modal verbs",
      "conditionals",
      "disagreement",
      "persuasion",
      "debate"
    ],
    "audioText": "I understand your claim, but I strongly doubt that rejecting the proposal is the best move. If we reject it without a backup plan, we might lose the supporters we have. We ought to consider a compromise instead. What do you think we should do?",
    "question": "根据听力内容，说话者建议采取什么行动？",
    "options": [
      "立即接受该提案",
      "寻求妥协方案",
      "完全拒绝该提案"
    ],
    "answerIdx": 1,
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U10-S03"
  },
  {
    "id": "pair_1782569237717-B1-U10-S03-005",
    "type": "T07",
    "typeName": "翻译选择",
    "language": "en",
    "cefr": "B1",
    "unit": "U10",
    "unitTheme": "Respectful Disagreement and Persuasion",
    "difficulty": 3,
    "tags": [
      "modal verbs",
      "conditionals",
      "persuasion",
      "respectful disagreement"
    ],
    "sourceText": "如果我们想说服对方，我们应该尊重他们的观点，并用合理的理由支持我们的主张。",
    "sourceLang": "zh",
    "options": [
      "If we want to persuade them, we would respect their views and support our claim with reasonable reasons.",
      "If we want to persuade them, we ought to respect their views but reject their claim with reasonable reasons.",
      "If we want to persuade them, we should respect their views and support our claim with reasonable reasons.",
      "If we want to persuade them, we could respect their views and support our claim with reasonable reasons."
    ],
    "answerIdx": 2,
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U10-S03"
  },
  {
    "id": "pair_1782569237717-B1-U10-S03-006",
