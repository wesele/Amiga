n  <circle cx=\"310\" cy=\"290\" r=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 275 290 Q 275 250 315 250 Q 350 250 345 290 Q 330 270 310 270 Q 290 270 275 290 Z\" fill=\"#D84315\" stroke=\"#333333\" stroke-width=\"4\"/> <!-- Front hair -->\n  <circle cx=\"295\" cy=\"285\" r=\"4.5\" fill=\"#333333\"/>\n  <path d=\"M 302 276 Q 294 274 286 280\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <path d=\"M 295 298 Q 285 300 292 308 Q 295 308 295 298\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"2\"/> <!-- Talking mouth -->\n\n  <!-- Woman's Pointing Arm -->\n  <path d=\"M 295 350 L 255 322\" stroke=\"#333333\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n  <path d=\"M 295 350 L 255 322\" stroke=\"#4A90D9\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n  <path d=\"M 250 315 L 220 295\" stroke=\"#333333\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n  <path d=\"M 250 315 L 220 295\" stroke=\"#FFD1A9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <circle cx=\"250\" cy=\"315\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Speech Bubble -->\n  <rect x=\"150\" y=\"50\" width=\"180\" height=\"110\" rx=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <polygon points=\"270,158 290,205 295,158\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"268\" y=\"150\" width=\"30\" height=\"10\" fill=\"#FFFFFF\"/> <!-- Seam cover -->\n\n  <!-- Graphic inside Speech Bubble -->\n  <rect x=\"200\" y=\"115\" width=\"12\" height=\"30\" rx=\"5\" transform=\"rotate(-15 206 130)\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"208\" y=\"116\" width=\"25\" height=\"8\" rx=\"4\" transform=\"rotate(-10 208 120)\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"206\" cy=\"104\" r=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <rect x=\"250\" y=\"115\" width=\"12\" height=\"30\" rx