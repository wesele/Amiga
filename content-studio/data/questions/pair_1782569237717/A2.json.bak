      {
        "desc": "一位摄影师在户外拍摄广告照片，手持相机，阳光明媚，橙色调",
        "prompt": "a photographer outdoors taking photos for an advertisement, holding camera, sunny background, orange color scheme",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Sun & Rays -->\n  <circle cx=\"320\" cy=\"80\" r=\"28\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M320 40 L320 28 M320 120 L320 132 M280 80 L268 80 M360 80 L372 80 M292 52 L283 43 M348 108 L357 117 M292 108 L283 117 M348 52 L357 43\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Distant Hill -->\n  <path d=\"M100 380 Q250 290 400 340 L400 400 L100 400 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Foreground Hill -->\n  <path d=\"M0 350 Q120 320 260 370 T400 360 L400 400 L0 400 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Plant -->\n  <path d=\"M335 400 L340 365 L375 365 L380 400 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M358 365 Q335 325 315 335 Q340 355 358 365 Q370 305 385 315 Q375 345 358 365 Q395 340 390 355 Q375 368 358 365 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Reflector Stand -->\n  <path d=\"M290 340 L290 400 M275 400 L290 385 L305 400\" stroke=\"#333333\" stroke-width=\"4\" fill=\"none\" stroke-linejoin=\"round\"/>\n  \n  <!-- Reflector Disk -->\n  <ellipse cx=\"290\" cy=\"320\" rx=\"30\" ry=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"290\" cy=\"320\" rx=\"22\" ry=\"14\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Reflected Light Rays -->\n  <path d=\"M260 290 L210 270 M265 310 L215 295\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-dasharray=\"6 6\" stroke-linecap=\"round\"/>\n\n  <!-- Photographer Background Arm (Left Arm) -->\n  <path d=\"M110 260 L160 250 L175 275 L120 285 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M150 260 L230 172 L245 182 L165 275 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Photographer Body & Head -->\n  <path d=\"M60 250 L120 250 L130 400 L40 400 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M135 190 L135 220 L155 220 L155 190 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"150\" cy=\"160\" r=\"30\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M175 158 L185 163 L175 168 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M122 150 C120 120 150 120 165 130 C175 138 175 150 170 155 C160 150 145 150 135 165 C130 165 124 160 122 150 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M165 156 L172 156\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Camera Body & Details -->\n  <rect x=\"175\" y=\"140\" width=\"45\" height=\"35\" rx=\"5\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"185\" cy=\"148\" r=\"3\" fill=\"#E53935\"/>\n\n  <!-- Camera Lens -->\n  <path d=\"M220 145 L275 140 L275 170 L220 165 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"235\" y=\"142\" width=\"10\" height=\"25\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M275 137 L290 132 L290 178 L275 173 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M290 137 Q283 155 290 173\" fill=\"none\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Photographer Left Hand (supporting lens) -->\n  <circle cx=\"238\" cy=\"175\" r=\"9\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Photographer Foreground Arm (Right Arm) -->\n  <path d=\"M80 250 L120 190 L140 205 L95 270 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M120 195 L180 135 L195 145 L135 210 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <circle cx=\"190\" cy=\"140\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Camera Strap -->\n  <path d=\"M100 255 Q130 300 115 340\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Lens Sparkles / Flash -->\n  <path d=\"M310 160 L313 150 L316 160 L326 163 L316 166 L313 176 L310 166 L300 163 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M325 185 L327 178 L329 185 L336 187 L329 189 L327 196 L325 189 L318 187 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U07-S03-003-opt1.jpg?v=1783892619901"
