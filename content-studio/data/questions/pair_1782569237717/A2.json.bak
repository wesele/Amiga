        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Scanning Beam Effect -->\n  <polygon points=\"194 143 250 194 250 236 160 237\" fill=\"#E3F2FD\"/>\n  <line x1=\"194\" y1=\"143\" x2=\"250\" y2=\"194\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-dasharray=\"6,4\" stroke-linecap=\"round\"/>\n  <line x1=\"160\" y1=\"237\" x2=\"250\" y2=\"236\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-dasharray=\"6,4\" stroke-linecap=\"round\"/>\n\n  <!-- Checkout Counter -->\n  <rect x=\"40\" y=\"280\" width=\"320\" height=\"85\" rx=\"8\" fill=\"#F0F0F0\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"30\" y=\"270\" width=\"340\" height=\"15\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- QR Code Stand -->\n  <!-- Acrylic Base -->\n  <path d=\"M220 280 L320 280 L310 295 L230 295 Z\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Stand Card -->\n  <rect x=\"240\" y=\"160\" width=\"65\" height=\"110\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Green Header Accent -->\n  <rect x=\"246\" y=\"166\" width=\"53\" height=\"16\" rx=\"3\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- QR Code Grid Pattern -->\n  <!-- Top-Left Finder Pattern -->\n  <rect x=\"251\" y=\"193\" width=\"14\" height=\"14\" fill=\"#333333\"/>\n  <rect x=\"254\" y=\"196\" width=\"8\" height=\"8\" fill=\"#FFFFFF\"/>\n  <rect x=\"256\" y=\"198\" width=\"4\" height=\"4\" fill=\"#333333\"/>\n  <!-- Top-Right Finder Pattern -->\n  <rect x=\"281\" y=\"193\" width=\"14\" height=\"14\" fill=\"#333333\"/>\n  <rect x=\"284\" y=\"196\" width=\"8\" height=\"8\" fill=\"#FFFFFF\"/>\n  <rect x=\"286\" y=\"198\" width=\"4\" height=\"4\" fill=\"#333333\"/>\n  <!-- Bottom-Left Finder Pattern -->\n  <rect x=\"251\" y=\"221\" width=\"14\" height=\"14\" fill=\"#333333\"/>\n  <rect x=\"254\" y=\"224\" width=\"8\" height=\"8\" fill=\"#FFFFFF\"/>\n  <rect x=\"256\" y=\"226\" width=\"4\" height=\"4\" fill=\"#333333\"/>\n  <!-- Abstract QR Pixels -->\n  <rect x=\"269\" y=\"193\" width=\"4\" height=\"8\" fill=\"#333333\"/>\n  <rect x=\"269\" y=\"205\" width=\"8\" height=\"4\" fill=\"#333333\"/>\n  <rect x=\"281\" y=\"211\" width=\"4\" height=\"6\" fill=\"#333333\"/>\n  <rect x=\"269\" y=\"221\" width=\"8\" height=\"4\" fill=\"#333333\"/>\n  <rect x=\"281\" y=\"227\" width=\"10\" height=\"4\" fill=\"#333333\"/>\n  <rect x=\"269\" y=\"231\" width=\"4\" height=\"4\" fill=\"#333333\"/>\n\n  <!-- Phone & Hand Group (rotated for natural scanning angle) -->\n  <g transform=\"rotate(20 150 180)\">\n    <!-- Sleeve -->\n    <path d=\"M 50 280 L 95 230 L 115 250 L 70 300 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Hand Palm -->\n    <path d=\"M 95 230 Q 125 195 135 220 L 115 250 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Phone Body -->\n    <rect x=\"115\" y=\"110\" width=\"70\" height=\"140\" rx=\"10\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Phone Screen -->\n    <rect x=\"121\" y=\"116\" width=\"58\" height=\"128\" rx=\"6\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Thumb Wrapping Front -->\n    <path d=\"M 108 175 C 114 175, 122 180, 122 188 C 122 195, 114 200, 108 200 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Fingers Wrapping Back-to-Front -->\n    <path d=\"M 183 140 C 187 140, 192 145, 192 150 C 192 155, 187 160, 183 160 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <path d=\"M 183 165 C 187 165, 192 170, 192 175 C 192 180, 187 185, 183 185 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <path d=\"M 183 190 C 187 190, 192 195, 192 200 C 192 205, 187 210, 183 210 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Phone UI Elements -->\n    <!-- Scanning Finder Frame -->\n    <rect x=\"128\" y=\"145\" width=\"44\" height=\"44\" rx=\"4\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\"/>\n    <!-- Green Success Checkmark -->\n    <path d=\"M142 169 L148 175 L158 163\" fill=\"none\" stroke=\"#4CAF50\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Red Laser Line -->\n    <line x1=\"125\" y1=\"167\" x2=\"175\" y2=\"167\" stroke=\"#E53935\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  </g>\n\n  <!-- Floating Success & Payment Decorators -->\n  <!-- Gold Coin 1 -->\n  <circle cx=\"110\" cy=\"90\" r=\"16\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"110\" cy=\"90\" r=\"8\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Gold Coin 2 -->\n  <circle cx=\"330\" cy=\"140\" r=\"12\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"330\" cy=\"140\" r=\"6\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <!-- Green Sparkle 1 -->\n  <path d=\"M 330 190 Q 330 200 340 200 Q 330 200 330 210 Q 330 200 320 200 Q 330 200 330 190 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <!-- Green Sparkle 2 -->\n  <path d=\"M 90 140 Q 90 148 98 148 Q 90 148 90 156 Q 90 148 82 148 Q 90 148 90 140 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"2\"/>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U03-S05-002-opt0.jpg?v=1783893230562"
