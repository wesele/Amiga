      {
        "desc": "一个人将垃圾分类投入绿色回收箱",
        "prompt": "person sorting waste and placing paper into a green recycling bin, indoors, bright room, clear labels on bin",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Shadows -->\n  <ellipse cx=\"70\" cy=\"342\" rx=\"22\" ry=\"5\" fill=\"#EAEAEA\"/>\n  <ellipse cx=\"155\" cy=\"346\" rx=\"42\" ry=\"8\" fill=\"#EAEAEA\"/>\n  <ellipse cx=\"280\" cy=\"322\" rx=\"45\" ry=\"10\" fill=\"#EAEAEA\"/>\n\n  <!-- Potted Plant (Left Background) -->\n  <path d=\"M 65 290 C 40 270 35 240 45 225 C 55 235 65 260 70 290 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 70 290 C 65 260 70 230 80 215 C 90 230 85 260 75 290 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 75 290 C 85 270 95 240 90 225 C 80 235 75 260 70 290 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"50,290 90,290 82,338 58,338\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <line x1=\"51\" y1=\"290\" x2=\"89\" y2=\"290\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Recycling Bin (Inside & Back Lip) -->\n  <ellipse cx=\"280\" cy=\"207\" rx=\"40\" ry=\"7\" fill=\"#388E3C\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Falling Paper 2 (Partially inside the bin) -->\n  <g transform=\"translate(262, 195) rotate(35)\">\n    <rect x=\"0\" y=\"0\" width=\"16\" height=\"22\" rx=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <line x1=\"3\" y1=\"6\" x2=\"13\" y2=\"6\" stroke=\"#B0BEC5\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n    <line x1=\"3\" y1=\"12\" x2=\"13\" y2=\"12\" stroke=\"#B0BEC5\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  </g>\n\n  <!-- Recycling Bin (Body & Front Lip) -->\n  <polygon points=\"240,207 252,320 308,320 320,207\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"235