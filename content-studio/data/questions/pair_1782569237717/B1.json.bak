  },
  {
    "id": "pair_1782569237717-B1-U10-S03-009",
    "type": "T03",
    "typeName": "双向配对",
    "language": "en",
    "cefr": "B1",
    "unit": "U10",
    "unitTheme": "Respectful Disagreement and Persuasion",
    "difficulty": 3,
    "tags": [
      "modal verbs",
      "conditionals",
      "disagreement",
      "persuasion",
      "vocabulary"
    ],
    "pairs": [
      {
        "left": "You should listen to other opinions before you reject them.",
        "right": "你在拒绝别人的意见之前应该先倾听。"
      },
      {
        "left": "If you want to persuade someone, you could show more respect.",
        "right": "如果你想说服某人，你可以表现出更多的尊重。"
      },
      {
        "left": "We ought to be responsible for our claims in a debate.",
        "right": "我们在辩论中应该对自己的主张负责。"
      },
      {
        "left": "Would you change your attitude if the evidence was strong enough?",
        "right": "如果证据足够充分，你会改变态度吗？"
      }
    ],
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U10-S03"
  },
  {
    "id": "pair_1782569237717-B1-U10-S03-010",
    "type": "T12",
    "typeName": "情景回应",
    "language": "en",
    "cefr": "B1",
    "unit": "U10",
    "unitTheme": "Respectful Disagreement and Persuasion",
    "difficulty": 3,
    "tags": [
      "modal verbs",
      "conditionals",
      "polite disagreement",
      "persuasion",
      "group discussion"
    ],
    "scenario": "小组辩论中，一位同学强烈主张取消期末考试，认为这对学生不公平。你不同意，但想礼貌地表达反对意见，并提出替代建议。你会怎么说？",
    "options": [
      "I understand your point, but I think we should consider the consequences. If we cancel the exam, how would we assess the learning outcomes fairly?",
      "I strongly reject your idea. If you don't like exams, you could just not study. It's your responsibility to pass.",
      "That claim is totally wrong. You ought to accept that exams are necessary and stop complaining about fairness."
    ],
    "answerIdx": 0,
    "pragmaticsNote": "正确选项使用 'I understand your point, but...' 表示尊重和部分认同，结合 'should consider' 给出建议，并用第二条件句 'If we cancel..., how would we...' 探讨假设后果，语气礼貌且具说服力。干扰项 B 使用 'totally wrong' 和 'stop complaining' 过于攻击性，缺乏尊重；干扰项 C 使用 'strongly reject' 和讽刺性建议 'not study'，破坏了合作氛围。",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U10-S03"
  },
