    "type": "T10",
    "typeName": "翻译输入",
    "language": "en",
    "cefr": "B1",
    "unit": "U07",
    "unitTheme": "Describing Symptoms and Seeing a Doctor",
    "difficulty": 3,
    "tags": [
      "cause-consequence",
      "symptoms",
      "doctor",
      "translation"
    ],
    "sourceText": "我因为伤到了胸部肌肉，所以呼吸时感到疼痛。",
    "sourceLang": "zh",
    "acceptedAnswers": [
      "I felt pain when breathing because I injured my chest muscles.",
      "I injured my chest muscles, so I felt pain when breathing.",
