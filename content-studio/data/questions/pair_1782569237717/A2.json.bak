        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Floor Shadows -->\n  <ellipse cx=\"285\" cy=\"360\" rx=\"95\" ry=\"10\" fill=\"#E0E0E0\"/>\n  <ellipse cx=\"135\" cy=\"368\" rx=\"35\" ry=\"8\" fill=\"#E0E0E0\"/>\n  <ellipse cx=\"65\" cy=\"360\" rx=\"25\" ry=\"6\" fill=\"#E0E0E0\"/>\n\n  <!-- Background Wall Clock -->\n  <circle cx=\"280\" cy=\"80\" r=\"25\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"280\" y1=\"80\" x2=\"280\" y2=\"65\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"280\" y1=\"80\" x2=\"295\" y2=\"80\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Suitcase (Left) -->\n  <!-- Handle -->\n  <path d=\"M 53 235 L 53 195 C 53 190 77 190 77 195 L 77 235\" fill=\"none\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <!-- Wheels -->\n  <circle cx=\"50\" cy=\"354\" r=\"8\" fill=\"#333333\"/>\n  <circle cx=\"80\" cy=\"354\" r=\"8\" fill=\"#333333\"/>\n  <circle cx=\"50\" cy=\"354\" r=\"3\" fill=\"#FFFFFF\"/>\n  <circle cx=\"80\" cy=\"354\" r=\"3\" fill=\"#FFFFFF\"/>\n  <!-- Suitcase Body -->\n  <rect x=\"40\" y=\"235\" width=\"50\" height=\"115\" rx=\"10\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Suitcase Details -->\n  <rect x=\"48\" y=\"260\" width=\"34\" height=\"70\" rx=\"5\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"40\" y1=\"280\" x2=\"90\" y2=\"280\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"40\" y1=\"310\" x2=\"90\" y2=\"310\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Receptionist (Right - Behind Desk) -->\n  <!-- Hair Back -->\n  <circle cx=\"280\" cy=\"154\" r=\"23\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"280\" cy=\"126\" r=\"10\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Torso -->\n  <rect x=\"250\" y=\"185\" width=\"60\" height=\"70\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Neck -->\n  <rect x=\"274\" y=\"172\" width=\"12\" height=\"16\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Collar & Tie -->\n  <polygon points=\"272,185 288,185 280,197\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"278,185 282,185 280,205\" fill=\"#E53935\"/>\n  <!-- Head -->\n  <circle cx=\"280\" cy=\"158\" r=\"20\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Hair Front / Bangs -->\n  <path d=\"M 262 150 Q 280 136 298 150 Q 280 144 262 150 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Face (Friendly Smile) -->\n  <path d=\"M 269 157 Q 274 153 277 157\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  <path d=\"M 283 157 Q 288 153 291 157\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  <path d=\"M 273 167 Q 280 174 287 167\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Reception Desk -->\n  <!-- Desk Body -->\n  <rect x=\"190\" y=\"220\" width=\"165\" height=\"135\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Desk Front Panel -->\n  <rect x=\"210\" y=\"250\" width=\"125\" height=\"80\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"230\" y1=\"280\" x2=\"315\" y2=\"280\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <line x1=\"250\" y1=\"300\" x2=\"295\" y2=\"300\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <!-- Desk Top Counter Slab -->\n  <rect x=\"175\" y=\"212\" width=\"190\" height=\"12\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Receptionist's Arms / Hands on Counter -->\n  <path d=\"M 251 195 L 261 220 L 271 220 L 261 195 Z\" fill=\"#4A90D9\" stroke=\"#33