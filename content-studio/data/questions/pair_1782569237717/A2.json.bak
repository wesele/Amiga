      {
        "desc": "一名旅行者向警察报告包被盗，警察站在室外街道上",
        "prompt": "traveler talking to a police officer outdoors on a street, traveler pointing to empty hands looking worried, officer in uniform with badge, bright daytime city background, blue and white color tones",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Background Cloud -->\n  <path d=\"M 310 90 Q 325 75 340 90 Q 355 80 365 95 L 305 95 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- Ground Line -->\n  <line x1=\"10\" y1=\"350\" x2=\"390\" y2=\"350\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Lamppost -->\n  <rect x=\"32\" y=\"80\" width=\"8\" height=\"270\" fill=\"#333333\"/>\n  <path d=\"M 36 90 C 50 70 80 80 80 100\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <polygon points=\"72 100 88 100 84 120 76 120\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- TRAVELER -->\n  <!-- Legs -->\n  <path d=\"M 100 300 L 100 348 L 118 348 L 118 315 L 132 315 L 132 348 L 150 348 L 150 300 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Torso -->\n  <path d=\"M 94 300 L 104 205 L 144 205 L 154 300 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Neck -->\n  <rect x=\"120\" y=\"185\" width=\"8\" height=\"25\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Head -->\n  <circle cx=\"124\" cy=\"165\" r=\"24\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Hair -->\n  <path d=\"M 99 160 C 94 125 154 125 149 160 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 104 150 Q 119 160 124 150 Q 134 160 144 150\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Left Arm & Hand (Viewer's Left) -->\n  <polygon points=\"104 210 74 240 64 230 94 205\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"67\" cy=\"237\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"67\" y1=\"229\" x2=\"63\" y2=\"220\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  <line x1=\"72\" y1=\"230\" x2=\"75\" y2=\"221\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n  <!-- Right Arm & Hand (Viewer's Right) -->\n  <polygon points=\"144 210 174 240 184 230 154 205\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"181\" cy=\"237\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"181\" y1=\"229\" x2=\"177\" y2=\"220\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  <line x1=\"186\" y1=\"230\" x2=\"189\" y2=\"221\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n  <!-- Face Expression (Worried) -->\n  <circle cx=\"115\" cy=\"162\" r=\"3\" fill=\"#333333\"/>\n  <circle cx=\"133\" cy=\"162\" r=\"3\" fill=\"#333333\"/>\n  <path d=\"M 110 154 L 118 150\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 138 154 L 130 150\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 118 178 Q 124 172 130 178 Q 124 185 118 178 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 94 152 Q 90 160 94 164 Q 98 160 94 152 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n\n  <!-- POLICE OFFICER -->\n  <!-- Legs -->\n  <path d=\"M 246 300 L 246 348 L 264 348 L 264 315 L 278 315 L 278 348 L 296 348 L 296 300 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Torso -->\n  <path d=\"M 240 300 L 250 205 L 290 205 L 300 300 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Belt & Buckle -->\n  <rect x=\"242\" y=\"285\" width=\"56\" height=\"15\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"263\" y=\"282\" width=\"14\" height=\"21\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" rx=\"2\"/>\n\n  <!-- Uniform Details (Collar & Badge) -->\n  <polygon points=\"260 205 270 217 280 205\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"282 212 290 212 292 218 286 224 280 218\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  \n  <!-- Neck -->\n  <rect x=\"266\" y=\"185\" width=\"8\" height=\"25\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Head -->\n  <circle cx=\"270\" cy=\"165\" r=\"24\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Officer Left Arm & Hand (Viewer's Left) -->\n  <polygon points=\"250 210 230 245 240 255 260 220\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"236\" cy=\"251\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Officer Right Arm & Hand (Viewer's Right) -->\n  <polygon points=\"290 210 310 245 300 255 280 220\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"304\" cy=\"251\" r=\"8\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Police Cap -->\n  <path d=\"M 246 142 C 241 118 299 118 294 142 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 246 142 L 294 142 L 290 148 L 250 148 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <path d=\"M 247 142 C 255 139 285 139 293 142\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"4\"/>\n  <circle cx=\"270\" cy=\"129\" r=\"5\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Face Expression (Friendly/Listening) -->\n  <path d=\"M 258 163 Q 262 160 266 163\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 274 163 Q 278 160 282 163\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 264 174 Q 270 179 276 174\" fil