      {
        "desc": "一个人坐在沙发上，表情惊讶，手捂嘴，眼睛睁大，看着电视屏幕",
        "prompt": "person sitting on sofa indoors, wide eyes, hands covering mouth in shock, looking at TV screen, warm living room lighting, surprised expression",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Warm-colored rug -->\n  <ellipse cx=\"190\" cy=\"350\" rx=\"140\" ry=\"22\" fill=\"#FF8F00\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- TV Stand -->\n  <rect x=\"360\" y=\"290\" width=\"45\" height=\"70\" rx=\"5\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Glowing light beam from TV -->\n  <polygon points=\"375,80 120,40 160,370 375,320\" fill=\"#FFC107\" fill-opacity=\"0.25\"/>\n\n  <!-- Sofa Legs -->\n  <line x1=\"80\" y1=\"305\" x2=\"75\" y2=\"335\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n  <line x1=\"220\" y1=\"305\" x2=\"225\" y2=\"335\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n\n  <!-- Sofa Backrest -->\n  <rect x=\"60\" y=\"160\" width=\"180\" height=\"110\" rx=\"15\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Sofa Cushions & Seat Base -->\n  <rect x=\"55\" y=\"260\" width=\"190\" height=\"45\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"70\" y=\"235\" width=\"80\" height=\"30\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"150\" y=\"235\" width=\"80\" height=\"30\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Sofa Left Armrest -->\n  <rect x=\"40\" y=\"200\" width=\"35\" height=\"90\" rx=\"10\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Green Throw Pillow -->\n  <rect x=\"75\" y=\"205\" width=\"35\" height=\"45\" rx=\"6\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Person's Legs (Dark Pants) -->\n  <path d=\"M150,250 L205,250 C215,250 220,260 215,270 L200,315 C198,322 190,322 188,315 L180,272 L150,272 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Shoe -->\n  <path d=\"M188,315 L180,325 L195,330 L203,315 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- Torso (Red Shirt) -->\n  <rect x=\"125\" y=\"195\" width=\"60\" height=\"65\" rx=\"12\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Collar -->\n  <path d=\"M148,195 L158,195 L153,201 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Neck -->\n  <rect x=\"146\" y=\"175\" width=\"14\" height=\"22\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Head -->\n  <circle cx=\"153\" cy=\"140\" r=\"28\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Hair -->\n  <path d=\"M132,135 C128,115 148,107 168,117 C178,125 178,140 168,144 C168,144 160,134 150,140 C145,136 135,140 132,135 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Shocked Wide Eyes -->\n  <circle cx=\"160\" cy=\"136\" r=\"6\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"174\" cy=\"136\" r=\"6\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"161\" cy=\"136\" r=\"2\" fill=\"#333333\"/>\n  <circle cx=\"175\" cy=\"136\" r=\"2\" fill=\"#333333\"/>\n\n  <!-- Raised Eyebrows -->\n  <path d=\"M155,124 Q160,118 165,124\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M169,124 Q174,118 179,124\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Left Arm (Outline & Red Sleeve) -->\n  <path d=\"M120,220 Q135,225 152,165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M120,220 Q135,225 152,165\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n\n  <!-- Right Arm (Outline & Red Sleeve) -->\n  <path d=\"M140,220 Q162,220 168,165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M140,220 Q162,220 168,165\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n\n  <!-- Hands Covering Mouth -->\n  <ellipse cx=\"156\" cy=\"151\" rx=\"9\" ry=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <ellipse cx=\"168\" cy=\"151\" rx=\"9\" ry=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"153\" y1=\"143\" x2=\"153\" y2=\"153\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <line x1=\"157\" y1=\"141\" x2=\"157\" y2=\"153\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <line x1=\"167\" y1=\"141\" x2=\"167\" y2=\"153\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <line x1=\"171\" y1=\"143\" x2=\"171\" y2=\"153\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n\n  <!-- Sofa Right Armrest (Foreground) -->\n  <rect x=\"225\" y=\"200\" width=\"35\" height=\"90\" rx=\"10\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- TV Screen (Off-camera right) -->\n  <rect x=\"375\" y=\"90\" width=\"30\" height=\"190\" rx=\"6\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"383\" y=\"100\" width=\"20\" height=\"170\" rx=\"3\" fill=\"#FFC107\"/>\n\n  <!-- Surprise Sparks (Action lines) -->\n  <path d=\"M190,110 L200,100\" stroke=\"#FF9800\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M196,123 L210,123\" stroke=\"#FF9800\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M192,138 L202,146\" stroke=\"#FF9800\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U08-S03-002-opt2.jpg?v=1783892842100"
