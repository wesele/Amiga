on points=\"70,370 200,260 200,370\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Right Facet (Shadow) -->\n  <polygon points=\"200,260 330,370 200,370\" fill=\"#D6D6D6\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Rock Details / Ledges -->\n  <path d=\"M 130 320 L 150 310\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 250 310 L 230 335\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 180 280 L 195 285\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Traveler standing on the summit (feet at Y=260) -->\n  <!-- Left Arm (in background) -->\n  <path d=\"M 190 198 L 180 208 L 190 215\" fill=\"none\" stroke=\"#333333\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M 190 198 L 180 208 L 190 215\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n  <!-- Legs -->\n  <line x1=\"194\" y1=\"235\" x2=\"194\" y2=\"260\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <line x1=\"206\" y1=\"235\" x2=\"206\" y2=\"260\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n\n  <!-- Jacket Torso -->\n  <rect x=\"187\" y=\"190\" width=\"26\" height=\"46\" rx=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Jacket Hood -->\n  <path d=\"M 187 195 C 180 195, 180 210, 187 215\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Head -->\n  <circle cx=\"200\" cy=\"172\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Nose (Looking Right) -->\n  <polygon points=\"210,168 217,172 210,176\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Nose Mask (hides outline overlap) -->\n  <rect x=\"207\" y=\"169\" width=\"4\" height=\"6\" fill=\"#FFD1A9\"/>\n  <!-- Eye -->\n  <path d=\"M 205 171 L 