      {
        "desc": "一个人对着朋友竖起大拇指，微笑推荐一本小说",
        "prompt": "person smiling and giving thumbs up to a friend outdoors, holding a novel book, sunny park background, cheerful mood",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Sun (Park Setting) -->\n  <g id=\"sun\">\n    <circle cx=\"70\" cy=\"70\" r=\"22\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <line x1=\"70\" y1=\"35\" x2=\"70\" y2=\"20\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <line x1=\"105\" y1=\"70\" x2=\"120\" y2=\"70\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <line x1=\"95\" y1=\"45\" x2=\"105\" y2=\"35\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <line x1=\"95\" y1=\"95\" x2=\"105\" y2=\"105\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <line x1=\"70\" y1=\"105\" x2=\"70\" y2=\"120\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  </g>\n\n  <!-- Foliage / Leaves -->\n  <g id=\"foliage\">\n    <!-- Top Right Leaves -->\n    <path d=\"M 360 40 C 340 10, 300 20, 320 50 C 340 70, 380 60, 360 40 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <path d=\"M 390 80 C 370 60, 340 70, 350 95 C 360 110, 400 100, 390 80 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Bottom Left Leaves -->\n    <path d=\"M -10 330 Q 30 300 60 330 Q 90 310 110 350 Q 70 410 -10 400 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <line x1=\"25\" y1=\"330\" x2=\"45\" y2=\"350\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <line x1=\"75\" y1=\"340\" x2=\"85\" y2=\"365\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  </g>\n\n  <!-- Friend (Right side, profile view, listening) -->\n  <g id=\"friend\">\n    <!-- Friend's Shoulder -->\n    <path d=\"M 345 230 C 320 250, 310 300, 310 400 L 400 400 L 400 230 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Friend's Neck -->\n    <rect x=\"335\" y=\"210\" width=\"18\" height=\"25\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Friend's Head -->\n    <circle cx=\"340\" cy=\"180\" r=\"35\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Friend's Nose -->\n    <path d=\"M 310 180 L 302 185 L 310 190 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <!-- Friend's Smile -->\n    <path d=\"M 312 195 Q 320 202 328 194\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <!-- Friend's Eye -->\n    <path d=\"M 318 175 Q 323 170 327 176\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <!-- Friend's Hair -->\n    <path d=\"M 325 158 C 340 145, 380 145, 375 185 C 370 210, 350 215, 345 214 L 348 190 C 348 175, 335 165, 325 158 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <!-- Friend's Ear -->\n    <circle cx=\"348\" cy=\"188\" r=\"7\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n\n  <!-- Main Character (Left side, recommending) -->\n  <g id=\"main-character\">\n    <!-- Hair Back -->\n    <path d=\"M 115 160 C 110 110, 210 110, 205 160 C 215 165, 210 180, 200 175 C 190 140, 130 140, 120 175\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <!-- Neck -->\n    <rect x=\"145\" y=\"205\" width=\"25\" height=\"25\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Torso / Blue Clothing -->\n    <path d=\"M 80 400 C 80 300, 200 300, 210 400 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Head -->\n    <circle cx=\"160\" cy=\"165\" r=\"42\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Eyes -->\n    <path d=\"M 145 165 Q 152 157 157 165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <path d=\"M 173 165 Q 180 157 185 165\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <!-- Nose -->\n    <path d=\"M 165 170 Q 162 175 166 177\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <!-- Smile -->\n    <path d=\"M 152 182 Q 165 200 178 182\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <!-- Left Arm (Holding Book) -->\n    <path d=\"M 150 360 L 195 295 L 210 305 L 165 370 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  </g>\n\n  <!-- Novel / Book (Rotated) -->\n  <g id=\"book\" transform=\"rotate(-12 240 250)\">\n    <!-- Book Pages / Thickness -->\n    <rect x=\"215\" y=\"215\" width=\"60\" height=\"85\" rx=\"5\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Book Cover -->\n    <rect x=\"210\" y=\"210\" width=\"60\" height=\"85\" rx=\"5\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Cover Design (Circle & Star) -->\n    <circle cx=\"240\" cy=\"252\" r=\"16\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <polygon points=\"240,244 243,250 249,250 244,254 246,260 240,256 234,260 236,254 231,250 237,250\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n    <!-- Bookmark Ribbon -->\n    <path d=\"M 235 295 L 235 315 L 242 308 L 249 315 L 249 295 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n\n  <!-- Left Hand (Holding the Book Cover) -->\n  <path d=\"M 195 290 Q 215 285 220 300 Q 210 315 195 305 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Right Arm & Thumbs-Up Hand (Foreground) -->\n  <g id=\"thumbs-up\">\n    <!-- Right Sleeve -->\n    <path d=\"M 190 280 L 250 250 L 260 268 L 200 298 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Fist Base -->\n    <ellipse cx=\"274\" cy=\"250\" rx=\"14\" ry=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Thumb (Pointing Up) -->\n    <path d=\"M 266 242 Q 262 210 274 210 Q 278 230 278 242\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Curled Fingers -->\n    <path d=\"M 285 235 Q 295 235 295 241 Q 295 247 285 247\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <path d=\"M 285 243 Q 295 243 295 249 Q 295 255 285 255\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <path d=\"M 283 251 Q 293 251 293 257 Q 293 263 283 263\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n\n  <!-- Decorative Sparkles (Recommending / Excitement) -->\n  <g id=\"sparkles\">\n    <!-- Sparkle 1 -->\n    <path d=\"M 290 190 L 293 198 L 301 201 L 293 204 L 290 212 L 287 204 L 279 201 L 287 198 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <!-- Sparkle 2 -->\n    <path d=\"M 260 140 L 262 145 L 267 147 L 262 149 L 260 154 L 258 149 L 253 147 L 258 145 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <!-- Small Dots -->\n    <circle cx=\"220\" cy=\"180\" r=\"3\" fill=\"#FFC107\"/>\n    <circle cx=\"305\" cy=\"230\" r=\"4\" fill=\"#FFC107\"/>\n  </g>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U08-S03-002-opt1.jpg?v=1783892823720"
