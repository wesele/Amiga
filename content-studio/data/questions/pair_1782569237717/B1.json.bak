  {
    "id": "pair_1782569237717-B1-U05-S02-009",
    "type": "T12",
    "typeName": "情景回应",
    "language": "en",
    "cefr": "B1",
    "unit": "U05",
    "unitTheme": "Study, Work, and Career Development",
    "difficulty": 3,
    "tags": [
      "job applications",
      "interviews",
      "gerunds",
      "infinitives",
      "intentions",
      "career"
    ],
    "scenario": "你看到一份很适合你的工作广告。一位朋友问你是否有申请打算。你该如何回答？",
    "options": [
      "I intend to apply for this job. I think I am a suitable candidate.",
      "I apply for this job because it's suitable for me.",
      "I hope applying for this job."
    ],
    "answerIdx": 0,
    "pragmaticsNote": "使用 'intend to' 可以正式地表达计划或意图，在求职场景中显得专业。避免使用一般现在时来表示将来的打算，同时注意 hope 后应接 to do 形式。",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U05-S02"
