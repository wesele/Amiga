  {
    "id": "pair_1782569237717-B1-U06-S02-010",
    "type": "T12",
    "typeName": "情景回应",
    "language": "en",
    "cefr": "B1",
    "unit": "U06",
    "unitTheme": "Film Stories and Mysteries",
    "difficulty": 3,
    "tags": [
      "narrative tenses",
      "past perfect",
      "film",
      "mystery"
    ],
    "scenario": "你和朋友在讨论一部悬疑电影《真实之谜》。朋友不明白为什么编剧对电影的结局感到震惊。你解释道：编剧意识到制片人之前已经把剧本基于一宗真实的谋杀案，并且工作室改变了受害者的身份。请选择最合适的回应。",
    "options": [
      "He realized that the producer based the script on a real murder case and the studio changed the victim's identity.",
      "He realized that the producer had based the script on a real murder case and the studio had changed the victim's identity.",
      "He realizes that the producer bases the script on a real murder case and the studio changes the victim's identity."
    ],
    "answerIdx": 1,
    "pragmaticsNote": "在叙述过去事件时，要表达一个动作发生在另一个过去动作之前，需要使用过去完成时（had+过去分词）。选项A正确使用了过去完成时来强调「基于真实案件」和「改变身份」这两个动作发生在「意识到」之前。选项B使用一般过去时，没有明确时间先后顺序，可能造成歧义；选项C使用现在时，完全不符合叙述过去故事的要求。",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U06-S02"
  },
