00 70 L 215 55 L 230 70 L 245 75 Q 250 95 245 120 C 240 110, 160 110, 155 120 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\" />\n\n  <!-- Surprised Eyes -->\n  <circle cx=\"182\" cy=\"122\" r=\"12\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" />\n  <circle cx=\"218\" cy=\"122\" r=\"12\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\" />\n  <circle cx=\"182\" cy=\"122\" r=\"3.5\" fill=\"#333333\" />\n  <circle cx=\"218\" cy=\"122\" r=\"3.5\" fill=\"#333333\" />\n\n  <!-- High Eyebrows -->\n  <path d=\"M 168 100 Q 182 88 194 98\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" />\n  <path d=\"M 206 98 Q 218 88 232 100\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" />\n\n  <!-- Gaping Mouth & Tongue -->\n  <ellipse cx=\"200\" cy=\"152\" rx=\"12\" ry=\"18\" fill=\"#333333\" />\n  <path d=\"M 191 155 Q 200 148 209 155 Q 209 168 200 168 Q 191 168 191 155\" fill=\"#E53935\" />\n\n  <!-- Hands Pressed to Cheeks -->\n  <g transform=\"rotate(-15 160 148)\">\n    <ellipse cx=\"160\" cy=\"148\" rx=\"10\" ry=\"16\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\" />\n    <line x1=\"158\" y1=\"136\" x2=\"158\" y2=\"156\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\" />\n    <line x1=\"163\" y1=\"138\" x2=\"163\" y2=\"158\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\" />\n  </g>\n  <g transform=\"rotate(15 240 148)\">\n    <ellipse cx=\"240\" cy=\"148\" rx=\"10\" ry=\"16\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\" />\n    <line x1=\"242\" y1=\"136\" x2=\"242\" y2=\"156\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\" />\n    <line x1=\"237\" y1=\"138\" x2=\"237\" y2=\"158\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\" />\n  </g>\n\n  <!-- Sofa Seat Cushions (tucks character in) -->\n  <rect x=\"70\" y=\"240\" width=\"260\" height=\"50\" rx=\"15\" fill=\"#4A90D9\" stroke=\