n  <!-- Dusty atmosphere lines -->\n  <path d=\"M 50,240 Q 80,230 110,245\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 280,220 Q 310,210 340,225\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Barbed Wire Silhouette -->\n  <path d=\"M 360,295 Q 380,280 400,295\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"375\" y1=\"285\" x2=\"385\" y2=\"291\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"385\" y1=\"285\" x2=\"375\" y2=\"291\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Ground (Patrol path) -->\n  <path d=\"M -10,290 Q 200,265 410,290 L 410,410 L -10,410 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <ellipse cx=\"200\" cy=\"370\" rx=\"90\" ry=\"15\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- SOLDIER 2 (Background, Alertly Patrolling) -->\n  <!-- Boots -->\n  <rect x=\"135\" y=\"305\" width=\"16\" height=\"12\" rx=\"4\" fill=\"#333333\"/>\n  <rect x=\"155\" y=\"302\" width=\"16\" height=\"12\" rx=\"4\" fill=\"#333333\"/>\n  <!-- Legs -->\n  <path d=\"M 135,305 L 140,265 L 150,265 L 150,305 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 155,302 L 150,265 L 162,265 L 167,302 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Torso & Vest -->\n  <rect x=\"135\" y=\"210\" width=\"36\" height=\"55\" rx=\"8\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"137\" y=\"218\" width=\"32\" height=\"38\" rx=\"4\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"145\" y1=\"218\" x2=\"145\" y2=\"256\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"161\" y1=\"218\" x2=\"161\" y2=\"256\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <!-- Head & Helmet -->\n  <rect x=\"149\" y=\"197\" width=\"8\" height=\"15\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"153\" cy=\"19