        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Desk Surface -->\n  <polygon points=\"15,315 385,315 400,400 0,400\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\" />\n\n  <!-- Coffee Mug on the Left -->\n  <path d=\"M 35 287 C 20 287 20 308 35 308\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" />\n  <rect x=\"35\" y=\"280\" width=\"25\" height=\"35\" rx=\"3\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" />\n  <path d=\"M 42 272 Q 45 265 42 258 M 50 274 Q 53 267 50 260\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\" />\n\n  <!-- Potted Plant on the Right -->\n  <polygon points=\"345,295 365,295 360,315 350,315\" fill=\"#CFD8DC\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\" />\n  <path d=\"M 355 295 Q 345 280 340 282 Q 345 290 355 295\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\" />\n  <path d=\"M 355 295 Q 355 273 358 273 Q 361 285 355 295\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\" />\n  <path d=\"M 355 295 Q 365 280 370 285 Q 365 290 355 295\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\" />\n\n  <!-- Cloud Signal Waves (Background) -->\n  <path d=\"M 125 65 A 25 25 0 0 0 125 85\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\" />\n  <path d=\"M 115 55 A 40 40 0 0 0 115 95\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\" />\n  <path d=\"M 275 65 A 25 25 0 0 1 275 85\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\" />\n  <path d=\"M 285 55 A 40 40 0 0 1 285 95\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"3\" stroke-linecap=\"round\" />\n\n  <!-- Network Dotted Connection Lines -