        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Table Surface -->\n  <rect x=\"0\" y=\"220\" width=\"400\" height=\"180\" fill=\"#F3F3F3\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Tablet Shadow -->\n  <ellipse cx=\"220\" cy=\"235\" rx=\"140\" ry=\"15\" fill=\"#D0D0D0\"/>\n  \n  <!-- Tablet Body -->\n  <rect x=\"100\" y=\"55\" width=\"240\" height=\"175\" rx=\"16\" fill=\"#D0D0D0\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Screen -->\n  <rect x=\"112\" y=\"67\" width=\"216\" height=\"151\" rx=\"8\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Blue Search Interface Header -->\n  <rect x=\"122\" y=\"77\" width=\"196\" height=\"50\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Search Input Field -->\n  <rect x=\"132\" y=\"87\" width=\"145\" height=\"30\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Magnifying Glass Icon -->\n  <circle cx=\"147\" cy=\"102\" r=\"5\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2.5\"/>\n  <line x1=\"151\" y1=\"106\" x2=\"157\" y2=\"112\" stroke=\"#333333\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n  \n  <!-- Abstract Typed Text & Cursor -->\n  <line x1=\"167\" y1=\"102\" x2=\"210\" y2=\"102\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"215\" y1=\"94\" x2=\"215\" y2=\"110\" stroke=\"#4A90D9\" stroke-width=\"2.5\"/>\n  \n  <!-- Go/Search Button -->\n  <rect x=\"284\" y=\"87\" width=\"26\" height=\"30\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2.5\"/>\n  <path d=\"M 292 102 L 302 102 M 298 97 L 303 102 L 298 107\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"2.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n  \n  <!-- Keyboard Area -->\n  <rect x=\"122\" y=\"137\" width=\"196\" height=\"71\" rx=\"6\" fill=\"#F0F4F8\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Keyboard Keys (Combined Path for Cleanliness) -->\n  <path d=\"M 130 145 h 22 v 12 h -22 z M 157 145 h 22 v 12 h -22 z M 184 145 h 22 v 12 h -22 z M 211 145 h 22 v 12 h -22 z M 238 145 h 22 v 12 h -22 z M 265 145 h 22 v 12 h -22 z M 292 145 h 22 v 12 h -22 z M 140 162 h 22 v 12 h -22 z M 167 162 h 66 v 12 h -66 z M 238 162 h 22 v 12 h -22 z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n  \n  <!-- Blue Enter Key -->\n  <rect x=\"265\" y=\"162\" width=\"49\" height=\"12\" rx=\"2\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2\"/>\n  \n  <!-- User's Shoulder & Torso (Over-the-shoulder perspective) -->\n  <path d=\"M -20 410 C 10 350, 50 330, 120 370 C 150 390, 180 400, 180 410 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Neck -->\n  <path d=\"M 70 345 L 80 325 L 95 332 L 85 352 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Head / Hair (Back view) -->\n  <path d=\"M 45 290 C 45 245, 115 245, 115 290 C 115 325, 95 335, 80 335 C 65 335, 45 325, 45 290 Z\" fill=\"#5A3825\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 110 290 C 115 290, 117 298, 113 303 C 110 305, 108 298, 110 290 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Left Arm (Green Sleeve) -->\n  <path d=\"M -20 390 L 80 260 L 105 245 L 20 410 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Left Hand Holding Tablet Edge -->\n  <path d=\"M 80 250 C 75 220 90 175 108 175 C 120 175 110 220 102 248 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 108 175 C 118 175 125 182 120 192 C 115 200 108 190 108 175 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Right Arm (Green Sleeve) -->\n  <path d=\"M 260 285 L 300 275 L 350 410 L 285 410 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\