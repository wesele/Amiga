        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Chair Back -->\n  <rect x=\"35\" y=\"240\" width=\"15\" height=\"80\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Person: Neck -->\n  <rect x=\"87\" y=\"170\" width=\"16\" height=\"45\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Person: Torso -->\n  <path d=\"M 50 320 L 50 220 C 50 200, 130 200, 130 220 L 130 320 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Person: Collar -->\n  <path d=\"M 83 210 Q 95 225 107 210\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Person: Hair Back -->\n  <path d=\"M 65 150 C 50 110, 80 90, 115 110 C 130 120, 130 150, 125 160\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Person: Head -->\n  <circle cx=\"95\" cy=\"145\" r=\"30\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Person: Hair Front/Bangs -->\n  <path d=\"M 70 125 Q 95 115 120 135 Q 100 135 90 125\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Person: Eyes -->\n  <circle cx=\"95\" cy=\"140\" r=\"6\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"112\" cy=\"142\" r=\"6\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"96\" cy=\"140\" r=\"2.5\" fill=\"#333333\"/>\n  <circle cx=\"113\" cy=\"142\" r=\"2.5\" fill=\"#333333\"/>\n  \n  <!-- Person: Eyebrows (Surprised) -->\n  <path d=\"M 88 128 Q 95 120 102 128\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 106 130 Q 113 122 120 130\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Person: Mouth (Surprised 'O') -->\n  <ellipse cx=\"108\" cy=\"162\" rx=\"7\" ry=\"10\" fill=\"#333333\"/>\n  \n  <!-- Person: Sweat Drop (Panic) -->\n  <path d=\"M 72 120 Q 67 130 75 130 Q 79 125 74 120 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2\"/>\n  \n  <!-- Person: Left Arm (Raised in Shock) -->\n  <line x1=\"65\" y1=\"225\" x2=\"55\" y2=\"185\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\"/>\n  <line x1=\"65\" y1=\"225\" x2=\"55\" y2=\"185\" stroke=\"#4CAF50\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n  <circle cx=\"50\" cy=\"175\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Person: Right Arm (Pointing/Recoiling) -->\n  <line x1=\"115\" y1=\"225\" x2=\"135\" y2=\"200\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\"/>\n  <line x1=\"115\" y1=\"225\" x2=\"135\" y2=\"200\" stroke=\"#4CAF50\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n  <circle cx=\"140\" cy=\"195\" r=\"10\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Desk -->\n  <rect x=\"20\" y=\"310\" width=\"360\" height=\"80\" rx=\"6\" fill=\"#F5F5F5\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Laptop Base -->\n  <polygon points=\"130,320 350,320 330,270 150,270\" fill=\"#3070B0\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"165\" y1=\"285\" x2=\"315\" y2=\"285\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"158\" y1=\"298\" x2=\"322\" y2=\"298\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Laptop Screen Outer -->\n  <rect x=\"150\" y=\"140\" width=\"180\" height=\"130\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Laptop Screen Inner -->\n  <rect x=\"160\" y=\"150\" width=\"160\" height=\"110\" rx=\"4\" fill=\"#E0F2FE\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Warning Dialogue Box -->\n  <rect x=\"175\" y=\"165\" width=\"130\" height=\"80\" rx=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"175\" y1=\"180\" x2=\"305\" y2=\"180\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"295\" c