    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Green Grass Field -->\n  <polygon points=\"120,340 390,340 350,150 160,150\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- White Field Line -->\n  <path d=\"M 145,300 L 365,300\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Background Players (Row 1 - Overlapping) -->\n  <!-- Player 1 (Blue) -->\n  <rect x=\"160\" y=\"175\" width=\"30\" height=\"40\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"175\" cy=\"160\" r=\"11\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Player 2 (Yellow) -->\n  <rect x=\"185\" y=\"165\" width=\"30\" height=\"40\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"200\" cy=\"150\" r=\"11\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Player 3 (Blue) -->\n  <rect x=\"210\" y=\"170\" width=\"30\" height=\"40\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"225\" cy=\"155\" r=\"11\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Player 4 (Yellow) -->\n  <rect x=\"235\" y=\"160\" width=\"30\" height=\"40\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"250\" cy=\"145\" r=\"11\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Player 5 (Blue) -->\n  <rect x=\"260\" y=\"175\" width=\"30\" height=\"40\" rx=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"275\" cy=\"160\" r=\"11\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Upside Down Player Legs (Tumbled in the crowd) -->\n  <path d=\"M 225,145 L 220,110 M 238,150 L 248,115\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n  <circle cx=\"220\" cy=\"104\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <circle cx=\"248\" cy=\"109\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Foreground Players (Row 2 - Packed & Confused) -->\n  <!-- Player 6 (Yellow) -->\n  <rect x=\"170\" y=\"210\" width=\"32\" height=\"45\" rx=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"186\" cy=\"195\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Player 7 (Blue) -->\n  <rect x=\"200\" y=\"200\" width=\"32\" height=\"45\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"216\" cy=\"185\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 211,184 Q 215,187 219,184\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <path d=\"M 221,184 Q 225,187 229,184\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n\n  <!-- Player 8 (Yellow) -->\n  <rect x=\"230\" y=\"205\" width=\"32\" height=\"45\" rx=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"246\" cy=\"190\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 242,190 L 247,190 M 251,190 L 256,190\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n\n  <!-- Player 9 (Blue) -->\n  <rect x=\"260\" y=\"215\" width=\"32\" height=\"45\" rx=\"8\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"276\" cy=\"200\" r=\"12\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Player 10 (Yellow) -->\n  <rect x=\"290\" y=\"200\" width=\"30\" height=\"40\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"305\" cy=\"185\" r=\"11\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Collision Sparks / Impact Lines -->\n  <path d=\"M 195,128 L 190,118 M 205,126 L 210,116\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 270,138 L 275,128 M 280,143 L 290,138\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Scattered Soccer Balls -->\n  <!-- Ball 1 -->\n  <circle cx=\"205\" cy=\"275\" r=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 200,268 L 205,275 L 210,268 M 205,275 L 205,285 M 196,278 L 205,275 L 214,278\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Ball 2 -->\n  <circle cx=\"255\" cy=\"290\" r=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 250,283 L 255,290 L 260,283 M 255,290 L 255,300 M 246,293 L 255,290 L 264,293\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Ball 3 -->\n  <circle cx=\"180\" cy=\"245\" r=\"8\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Scattered Cones -->\n  <polygon points=\"145,290 165,290 155,270\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"280,315 300,315 290,295\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"330,245 345,245 337.5,230\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Disappointed Observer (Foreground Left) -->\n  <!-- Body/Torso -->\n  <path d=\"M -10,410 L -10,325 C -10,275 50,265 75,265 C 100,265 120,280 120,325 L 120,410 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Head -->\n  <circle cx=\"85\" cy=\"180\" r=\"34\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Hair -->\n  <path d=\"M 52,175 C 52,135 118,135 118,175 C 108,165 98,165 85,168 C 72,165 62,165 52,175 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Face Details -->\n  <!-- Grimacing Eye -->\n  <path d=\"M 98,185 Q 104,180 110,185\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <!-- Eyebrow -->\n  <path d=\"M 95,173 L 110,176\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <!-- Frowning Mouth -->\n  <path d=\"M 92,204 Q 102,209 108,198\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <!-- Sweat Drop (Sign of exasperation) -->\n  <path d=\"M 72,165 Q 77,150 82,165 Q 82,173 72,173 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Left Arm: Pointing/Gesturing to the right -->\n  <path d=\"M 110,280 L 155,270 L 150,250 L 100,260 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 152,260 L 195,250 C 205,248 205,258 190,262 L 185,264 C 192,267 187,275 180,272 L 148,270 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Right Arm: Hand to Head (Disappointment/Headache) -->\n  <path d=\"M 35,300 L 25,240 L 50,235 L 60,290 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 37,238 L 60,185 C 65,175 75,175 75,185 L 53,245 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n</svg>",
