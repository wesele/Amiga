        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Background Tree 1 (Left) -->\n  <rect x=\"45\" y=\"150\" width=\"16\" height=\"130\" rx=\"4\" fill=\"#8D6E63\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"53\" cy=\"130\" r=\"40\" fill=\"#388E3C\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"75\" cy=\"120\" r=\"30\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Background Tree 2 (Right) -->\n  <rect x=\"335\" y=\"140\" width=\"14\" height=\"140\" rx=\"3\" fill=\"#8D6E63\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"342\" cy=\"120\" r=\"35\" fill=\"#388E3C\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"320\" cy=\"110\" r=\"25\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Grass Ground -->\n  <path d=\"M -10 270 Q 200 250 410 270 L 410 410 L -10 410 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Park Bench (standing on grass) -->\n  <!-- Backrest support -->\n  <line x1=\"252\" y1=\"230\" x2=\"252\" y2=\"250\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"298\" y1=\"230\" x2=\"298\" y2=\"250\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Backrest -->\n  <rect x=\"242\" y=\"220\" width=\"66\" height=\"12\" rx=\"3\" fill=\"#D7CCC8\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Legs to ground -->\n  <line x1=\"250\" y1=\"248\" x2=\"250\" y2=\"275\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"300\" y1=\"248\" x2=\"300\" y2=\"275\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Seat -->\n  <rect x=\"235\" y=\"244\" width=\"80\" height=\"8\" rx=\"3\" fill=\"#D7CCC8\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Grass Details -->\n  <path d=\"M 215 285 L 218 275 L 223 287\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n  <path d=\"M 365 295 L 368 285 L 373 297\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n\n  <!-- Light Beam from Flashlight -->\n  <path d=\"M 171 244 L 325 285 A 60 45 0 0 1 260 355 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Inner light rays -->\n  <line x1=\"171\" y1=\"244\" x2=\"285\" y2=\"315\" stroke=\"#FFFFFF\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"171\" y1=\"244\" x2=\"260\" y2=\"290\" stroke=\"#FFE082\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n  <!-- Lost Backpack (inside the beam) -->\n  <g transform=\"translate(265, 295) rotate(15)\">\n    <!-- Straps -->\n    <path d=\"M -5 15 Q -15 30 -5 45\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <path d=\"M 45 15 Q 55 30 45 45\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <!-- Handle -->\n    <path d=\"M 12 2 Q 20 -8 28 2\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <!-- Main body -->\n    <rect x=\"0\" y=\"0\" width=\"40\" height=\"50\" rx=\"10\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Outer Pocket -->\n    <rect x=\"6\" y=\"20\" width=\"28\" height=\"24\" rx=\"4\" fill=\"#C62828\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Zipper -->\n    <line x1=\"6\" y1=\"25\" x2=\"34\" y2=\"25\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Yellow badge on pocket -->\n    <rect x=\"16\" y=\"30\" width=\"8\" height=\"8\" rx=\"1.5\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  </g>\n\n  <!-- Grass Detail inside light -->\n  <path d=\"M 255 345 L 258 335 L 263 347\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n\n  <!-- Police Officer -->\n  <!-- Left leg (back leg, kneeling) -->\n  <path d=\"M 75 250 L 95 320 L 70 320\" fill=\"none\" stroke=\"#333333\" stro