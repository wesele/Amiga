  {
    "id": "pair_1782569237717-B1-U03-S01-008",
    "type": "T10",
    "typeName": "翻译输入",
    "language": "en",
    "cefr": "B1",
    "unit": "U03",
    "unitTheme": "Choosing Suitable Goods at the Mall",
    "difficulty": 2,
    "tags": [
