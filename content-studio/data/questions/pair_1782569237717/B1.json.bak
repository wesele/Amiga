  {
    "id": "pair_1782569237717-B1-U09-S04-005",
    "type": "T08",
    "typeName": "听力选择",
    "language": "en",
    "cefr": "B1",
    "unit": "U09",
    "unitTheme": "Energy, Resources, and Environmental Impact",
    "difficulty": 3,
    "tags": [
      "adverbs of degree",
      "adverbs of frequency",
      "environmental vocabulary"
    ],
    "audioText": "Nuclear energy is highly efficient but produces highly dangerous waste that is rarely recycled. Coal plants frequently release carbon dioxide, which regularly damages the atmosphere and increases global heating. Solar power is fairly clean and frequently used as a renewable resource, though its supply can be slightly variable. Wind energy regularly contributes to growth in clean energy, but its impact on wildlife is slightly negative.",
    "question": "根据听力，哪种能源被描述为“经常释放二氧化碳，定期损害大气层并加剧全球变暖”？",
    "options": [
      "太阳能",
      "核能",
      "煤电"
    ],
    "answerIdx": 2,
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U09-S04"
  },
  {
    "id": "pair_1782569237717-B1-U09-S04-006",
    "type": "T07",
    "typeName": "Translation Choice",
