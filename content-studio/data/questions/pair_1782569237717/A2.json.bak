      {
        "desc": "电脑屏幕上显示多个病毒警告图标，红色警报弹窗",
        "prompt": "computer monitor showing multiple red virus warning popups and alert icons on screen, dark background, red and black color theme",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Monitor Base Shadow -->\n  <ellipse cx=\"200\" cy=\"352\" rx=\"100\" ry=\"12\" fill=\"#E0E0E0\"/>\n\n  <!-- Monitor Stand -->\n  <polygon points=\"180,240 220,240 235,335 165,335\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <line x1=\"188\" y1=\"275\" x2=\"212\" y2=\"275\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"185\" y1=\"295\" x2=\"215\" y2=\"295\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Monitor Base -->\n  <ellipse cx=\"200\" cy=\"335\" rx=\"80\" ry=\"14\" fill=\"#B0BEC5\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Monitor Bezel -->\n  <rect x=\"50\" y=\"50\" width=\"300\" height=\"205\" rx=\"12\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Power LED -->\n  <circle cx=\"200\" cy=\"249\" r=\"3.5\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Inner Screen -->\n  <rect x=\"62\" y=\"62\" width=\"276\" height=\"181\" rx=\"4\" fill=\"#263238\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Background Warning Triangle (Digital Hazard Icon) -->\n  <polygon points=\"200,80 165,145 235,145\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M200,98 L200,122\" stroke=\"#333333\" stroke-width=\"4.5\" stroke-linecap=\"round\"/>\n  <circle cx=\"200\" cy=\"133\" r=\"3\" fill=\"#333333\"/>\n\n  <!-- Pop-up 1 (Top Left) -->\n  <g id=\"popup-left\">\n    <rect x=\"72\" y=\"85\" width=\"95\" height=\"65\" rx=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n    <line x1=\"72\" y1=\"102\" x2=\"167\" y2=\"102\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n    <circle cx=\"120\" cy=\"126\" r=\"12\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <line x1=\"120\" y1=\"119\" x2=\"120\" y2=\"126\" stroke=\"#E53935\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n    <circle cx=\"120\" cy=\"131\" r=\"1.5\" fill=\"#E53935\"/>\n  </g>\n\n  <!-- Pop-up 2 (Top Right) -->\n  <g id=\"popup-right\">\n    <rect x=\"230\" y=\"75\" width=\"95\" height=\"65\" rx=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n    <line x1=\"230\" y1=\"92\" x2=\"325\" y2=\"92\" stroke=\"#333333\" stroke-width=\"3.5\"/>\n    <polygon points=\"277,98 262,128 292,128\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n    <line x1=\"277\" y1=\"106\" x2=\"277\" y2=\"117\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n    <circle cx=\"277\" cy=\"122\" r=\"1.2\" fill=\"#333333\"/>\n  </g>\n\n  <!-- Pop-up 3 (Main Foreground Center) -->\n  <g id=\"popup-center\">\n    <rect x=\"105\" y=\"130\" width=\"190\" height=\"100\" rx=\"8\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <line x1=\"105\" y1=\"152\" x2=\"295\" y2=\"152\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <circle cx=\"278\" cy=\"141\" r=\"5\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2\"/>\n    \n    <!-- Hazard Triangle inside Main Pop-up -->\n    <polygon points=\"152,162 122,217 182,217\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n    <line x1=\"152\" y1=\"176\" x2=\"152\" y2=\"198\" stroke=\"#333333\" stroke-width=\"4.5\" stroke-linecap=\"round\"/>\n    <circle cx=\"152\" cy=\"207\" r=\"3\" fill=\"#333333\"/>\n\n    <!-- Status Graphics inside Main Pop-up -->\n    <rect x=\"195\" y=\"165\" width=\"55\" height=\"6\" rx=\"3\" fill=\"#FFFFFF\"/>\n    <rect x=\"195\" y=\"182\" width=\"85\" height=\"16\" rx=\"4\" fill=\"#263238\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <rect x=\"199\" y=\"186\" width=\"60\" height=\"8\" rx=\"2\" fill=\"#4CAF50\"/>\n  </g>\n</svg>",
        "imageUrl": "/api/images/pair_1782569237717-A2-U07-S04-003-opt2.jpg?v=1783893605825"
