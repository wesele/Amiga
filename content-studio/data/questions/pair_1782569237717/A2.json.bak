"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <circle cx=\"0\" cy=\"18\" r=\"8\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n\n  <!-- Scribble Stress Mark (Mental Overload) -->\n  <path d=\"M 175 110 C 175 90, 190 90, 195 110 C 200 130, 215 90, 220 110 C 225 130, 230 100, 225 90\" fill=\"none\" stroke=\"#E53935\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n</svg>",
