        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Ground -->\n  <path d=\"M -20 290 Q 200 270 420 290 L 420 420 L -20 420 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Prison Building (Background Center-Left) -->\n  <rect x=\"142\" y=\"145\" width=\"14\" height=\"60\" fill=\"#90A4AE\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"137\" y=\"125\" width=\"24\" height=\"20\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"134,125 149,112 164,125\" fill=\"#37474F\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <rect x=\"156\" y=\"180\" width=\"70\" height=\"100\" rx=\"4\" fill=\"#B0BEC5\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 152 180 L 165 165 L 217 165 L 230 180 Z\" fill=\"#78909C\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Prison Windows -->\n  <rect x=\"170\" y=\"195\" width=\"14\" height=\"20\" rx=\"2\" fill=\"#333333\"/>\n  <rect x=\"198\" y=\"195\" width=\"14\" height=\"20\" rx=\"2\" fill=\"#333333\"/>\n  <line x1=\"174\" y1=\"195\" x2=\"174\" y2=\"215\" stroke=\"#FFFFFF\" stroke-width=\"1.5\"/>\n  <line x1=\"180\" y1=\"195\" x2=\"180\" y2=\"215\" stroke=\"#FFFFFF\" stroke-width=\"1.5\"/>\n  <line x1=\"202\" y1=\"195\" x2=\"202\" y2=\"215\" stroke=\"#FFFFFF\" stroke-width=\"1.5\"/>\n  <line x1=\"208\" y1=\"195\" x2=\"208\" y2=\"215\" stroke=\"#FFFFFF\" stroke-width=\"1.5\"/>\n\n  <!-- Fence -->\n  <line x1=\"226\" y1=\"280\" x2=\"226\" y2=\"230\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"266\" y1=\"280\" x2=\"266\" y2=\"230\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"226\" y1=\"240\" x2=\"266\" y2=\"240\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"226\" y1=\"255\" x2=\"266\" y2=\"255\" stroke=\"#333333\" stroke-width=\"2\"/>\n  <line x1=\"226\" y1=\"270\" x2=\"266\" y2=\"270\" stroke=\"#