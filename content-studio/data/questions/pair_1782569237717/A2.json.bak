        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Shadows on Desk -->\n  <ellipse cx=\"135\" cy=\"292\" rx=\"110\" ry=\"6\" fill=\"#EBF3FC\"/>\n  <ellipse cx=\"315\" cy=\"292\" rx=\"35\" ry=\"4\" fill=\"#EBF3FC\"/>\n\n  <!-- Desk Line -->\n  <line x1=\"20\" y1=\"292\" x2=\"380\" y2=\"292\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Desk Lamp (Left) -->\n  <ellipse cx=\"50\" cy=\"292\" rx=\"14\" ry=\"4\" fill=\"#333333\"/>\n  <path d=\"M 50 292 Q 40 215 80 185\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <polygon points=\"72,178 98,193 90,206 64,191\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- Books Stack (Right) -->\n  <rect x=\"280\" y=\"274\" width=\"70\" height=\"18\" rx=\"2\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"285\" y=\"258\" width=\"60\" height=\"16\" rx=\"2\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Woman (Back Layers) -->\n  <!-- Bun -->\n  <circle cx=\"240\" cy=\"92\" r=\"14\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Hair Back -->\n  <circle cx=\"240\" cy=\"125\" r=\"25\" fill=\"#333333\"/>\n  <!-- Face -->\n  <circle cx=\"238\" cy=\"132\" r=\"18\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Bangs -->\n  <path d=\"M 220 122 Q 235 115 254 125 C 248 132 235 130 220 122\" fill=\"#333333\"/>\n  <!-- Eye -->\n  <path d=\"M 225 134 Q 229 138 233 134\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <!-- Cheek Blush -->\n  <circle cx=\"228\" cy=\"142\" r=\"3.5\" fill=\"#FF8A80\"/>\n  <!-- Neck -->\n  <rect x=\"237\" y=\"147\" width=\"8\" height=\"16\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Torso -->\n  <path d=\"M 215 162 L 265 162 L 275 270 L 210 270 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n\n  <!-- Laptop Base (Drawn before hands to allow typing pose) -->\n  <polygon points=\"40,270 230,270 250,292 20,292\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"65,274 210,274 218,282 57,282\" fill=\"#333333\"/>\n  <polygon points=\"125,284 145,284 147,289 123,289\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"1.5\"/>\n\n  <!-- Arms & Hands (Drawn over Torso and Laptop Base) -->\n  <!-- Left Arm -->\n  <path d=\"M 225 175 C 215 210, 185 245, 145 268 L 153 276 C 195 250, 225 215, 235 175 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"149\" cy=\"272\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Right Arm -->\n  <path d=\"M 250 175 C 240 210, 215 245, 185 270 L 193 278 C 225 250, 250 215, 260 175 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <circle cx=\"189\" cy=\"274\" r=\"6\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Laptop Screen -->\n  <rect x=\"50\" y=\"140\" width=\"170\" height=\"120\" rx=\"8\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <rect x=\"57\" y=\"147\" width=\"156\" height=\"106\" rx=\"4\" fill=\"#EBF3FC\"/>\n\n  <!-- Overlapping Browser Windows on Screen -->\n  <!-- Window A (Back Left) -->\n  <rect x=\"62\" y=\"152\" width=\"85\" height=\"60\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"63.5\" y=\"153.5\" width=\"82\" height=\"10\" fill=\"#4A90D9\"/>\n  <path d=\"M94 172 H135 M94 180 H125 M94 188 H130\" stroke=\"#E0E0E0\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <rect x=\"68\" y=\"170\" width=\"20\" height=\"20\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Window B (Back Right) -->\n  <rect x=\"115\" y=\"162\" width=\"90\" height=\"65\" rx=\