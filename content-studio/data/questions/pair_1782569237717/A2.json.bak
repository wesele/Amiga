        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Spotlight Beams -->\n  <polygon points=\"60,-10 140,-10 240,300 120,300\" fill=\"#4A90D9\" opacity=\"0.15\"/>\n  <polygon points=\"340,-10 260,-10 160,300 280,300\" fill=\"#4A90D9\" opacity=\"0.15\"/>\n  <polygon points=\"170,-10 230,-10 280,300 120,300\" fill=\"#FFC107\" opacity=\"0.1\"/>\n  <circle cx=\"200\" cy=\"135\" r=\"75\" fill=\"#FFC107\" opacity=\"0.15\"/>\n\n  <!-- Music Notes -->\n  <!-- Note 1 -->\n  <circle cx=\"280\" cy=\"100\" r=\"7\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"285\" y1=\"100\" x2=\"285\" y2=\"78\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 285 78 Q 293 82 295 90\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  \n  <!-- Note 2 -->\n  <circle cx=\"120\" cy=\"110\" r=\"7\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"125\" y1=\"110\" x2=\"125\" y2=\"88\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 125 88 Q 133 92 135 100\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Note 3 -->\n  <circle cx=\"310\" cy=\"160\" r=\"6\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"315\" y1=\"160\" x2=\"315\" y2=\"142\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <path d=\"M 315 142 Q 321 145 323 151\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Stage Floor -->\n  <rect x=\"0\" y=\"300\" width=\"400\" height=\"100\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"50\" y1=\"300\" x2=\"20\" y2=\"400\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"120\" y1=\"300\" x2=\"100\" y2=\"400\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"280\" y1=\"300\" x2=\"300\" y2=\"400\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"350\" y1=\"300\" x2=\"380\" y2=\"400\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Stage Light Pool -->\n  <ellipse cx=\"200\" cy=\"305\" rx=\"90\" ry=\"15\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Singer Legs & Shoes -->\n  <line x1=\"185\" y1=\"270\" x2=\"185\" y2=\"308\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <line x1=\"215\" y1=\"270\" x2=\"215\" y2=\"308\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <ellipse cx=\"181\" cy=\"309\" rx=\"10\" ry=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <ellipse cx=\"219\" cy=\"309\" rx=\"10\" ry=\"6\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Singer Torso -->\n  <path d=\"M 176 180 L 224 180 L 215 270 L 185 270 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <polygon points=\"190,180 210,180 200,198\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"198,198 202,198 204,222 200,229 196,222\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"2\"/>\n\n  <!-- Singer Head & Neck -->\n  <rect x=\"194\" y=\"150\" width=\"12\" height=\"32\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"200\" cy=\"135\" r=\"22\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Singer Face & Hair -->\n  <path d=\"M 178 135 Q 175 110 195 110 Q 225 110 222 135 C 215 120 185 120 178 135 Z\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 202 133 Q 207 137 211 133\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <ellipse cx=\"212\" cy=\"145\" rx=\"5\" ry=\"7\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Left Arm (Gesturing) -->\n  <path d=\"M 176 180 Q 160 190 152 195\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n  <path d=\"M 176 180 Q 160 190 152 195\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"10\" stroke-