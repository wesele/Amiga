        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Mountain 1 (Left Peak) -->\n  <polygon points=\"0,320 120,60 280,320\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"0,320 120,60 120,320\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Mountain 2 (Right Peak) -->\n  <polygon points=\"160,320 290,90 400,320\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"160,320 290,90 290,320\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Mid-ground Snow Hill -->\n  <path d=\"M -10,300 Q 150,265 410,290 L 410,340 L -10,340 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Pine Tree Left -->\n  <rect x=\"67\" y=\"270\" width=\"6\" height=\"15\" fill=\"#333333\"/>\n  <polygon points=\"55,270 70,235 85,270\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Pine Tree Right -->\n  <rect x=\"287\" y=\"270\" width=\"6\" height=\"15\" fill=\"#333333\"/>\n  <polygon points=\"275,270 290,235 305,270\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Palace Towers -->\n  <rect x=\"105\" y=\"174\" width=\"25\" height=\"100\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" rx=\"2\"/>\n  <rect x=\"230\" y=\"174\" width=\"25\" height=\"100\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" rx=\"2\"/>\n  \n  <!-- Palace Main Body -->\n  <rect x=\"130\" y=\"204\" width=\"100\" height=\"70\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" rx=\"2\"/>\n  \n  <!-- Palace Domes -->\n  <path d=\"M 104,174 C 95,155 110,135 117.5,127 C 125,135 140,155 131,174 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <path d=\"M 229,174 C 220,155 235,135 242.5,127 C 250,135 265,155 256,174 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <path d=\"M 158,204 C 145,180 165,150 180,140 C 195,150 215,180 202,204 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Spires & Details -->\n  <line x1=\"117.5\" y1=\"127\" x2=\"117.5\" y2=\"112\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"242.5\" y1=\"127\" x2=\"242.5\" y2=\"112\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"180\" y1=\"140\" x2=\"180\" y2=\"120\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <circle cx=\"180\" cy=\"120\" r=\"4.5\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"2\"/>\n  \n  <!-- Palace Gate & Window -->\n  <path d=\"M 165,274 L 165,245 C 165,233 195,233 195,245 L 195,274 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"3.5\" stroke-linejoin=\"round\"/>\n  <circle cx=\"180\" cy=\"215\" r=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"130\" y=\"225\" width=\"100\" height=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Foreground Snowdrift -->\n  <path d=\"M -20,335 Q 150,385 420,325 L 420,420 L -20,420 Z\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Traveler Legs -->\n  <line x1=\"298\" y1=\"335\" x2=\"298\" y2=\"355\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n  <line x1=\"298\" y1=\"335\" x2=\"298\" y2=\"355\" stroke=\"#4A90D9\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>\n  <line x1=\"312\" y1=\"335\" x2=\"312\" y2=\"355\" stroke=\"#333333\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n  <line x1=\"312\" y1=\"335\" x2=\"312\" y2=\"355\" stroke=\"#4A90D9\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>\n  \n  <!-- Traveler Coat -->\n  <path d=\"M 288,337 L 295,295 L 31