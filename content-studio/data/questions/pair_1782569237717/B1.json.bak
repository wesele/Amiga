    ],
    "sentence": "The project manager ______ that the launch date would be postponed by two weeks.",
    "blank": "announced",
    "options": [
      "advised",
      "announced",
      "told",
      "admitted"
    ],
    "answerIdx": 1,
    "hint": "本句需要转述项目经理的通知。动词“announced”表示宣布，后接that从句；注意“told”必须带间接宾语（如told us），“advised”表示建议，“admitted”表示承认。",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U05-S05"
  },
