        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Sky Accents (Blue Bars) -->\n  <rect x=\"30\" y=\"150\" width=\"60\" height=\"8\" rx=\"4\" fill=\"#4A90D9\"/>\n  <rect x=\"15\" y=\"175\" width=\"45\" height=\"8\" rx=\"4\" fill=\"#4A90D9\"/>\n  <rect x=\"315\" y=\"190\" width=\"65\" height=\"8\" rx=\"4\" fill=\"#4A90D9\"/>\n  <rect x=\"335\" y=\"215\" width=\"40\" height=\"8\" rx=\"4\" fill=\"#4A90D9\"/>\n\n  <!-- Green Hills -->\n  <path d=\"M -20 330 A 80 80 0 0 1 120 330 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <path d=\"M 280 330 A 90 90 0 0 1 420 330 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Left Chimney -->\n  <rect x=\"135\" y=\"130\" width=\"30\" height=\"90\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"135\" y=\"150\" width=\"30\" height=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"135\" y=\"190\" width=\"30\" height=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Right Chimney -->\n  <rect x=\"235\" y=\"100\" width=\"30\" height=\"120\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"235\" y=\"120\" width=\"30\" height=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"235\" y=\"160\" width=\"30\" height=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <rect x=\"235\" y=\"200\" width=\"30\" height=\"20\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Factory Main Body -->\n  <rect x=\"110\" y=\"210\" width=\"180\" height=\"120\" rx=\"6\" fill=\"#757575\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Roof Detail -->\n  <rect x=\"170\" y=\"195\" width=\"60\" height=\"15\" fill=\"#333333\" rx=\"2\"/>\n\n  <!-- Factory Windows -->\n  <rect x=\"135\" y=\"235\" width=\"30\" height=\"30\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"150\" y1=\"235\" x2=\"150\" y2=\"265\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"135\" y1=\"250\" x2=\"165\" y2=\"250\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <rect x=\"235\" y=\"235\" width=\"30\" height=\"30\" rx=\"4\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"250\" y1=\"235\" x2=\"250\" y2=\"265\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"235\" y1=\"250\" x2=\"265\" y2=\"250\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Factory Door -->\n  <rect x=\"185\" y=\"275\" width=\"30\" height=\"55\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <circle cx=\"192\" cy=\"305\" r=\"2.5\" fill=\"#FFC107\"/>\n\n  <!-- Ground Line -->\n  <line x1=\"0\" y1=\"330\" x2=\"400\" y2=\"330\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Billowing Smoke (Overlapping Dark Grey Circles) -->\n  <!-- Left Chimney Smoke Puff -->\n  <circle cx=\"155\" cy=\"110\" r=\"16\" fill=\"#616161\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Right Chimney Smoke Puff -->\n  <circle cx=\"245\" cy=\"90\" r=\"18\" fill=\"#616161\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Main Smoke Plume (Lower Layer) -->\n  <circle cx=\"110\" cy=\"70\" r=\"24\" fill=\"#424242\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"135\" cy=\"90\" r=\"22\" fill=\"#424242\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"265\" cy=\"70\" r=\"24\" fill=\"#424242\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"295\" cy=\"45\" r=\"36\" fill=\"#424242\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Main Smoke Plume (Middle Layer) -->\n  <circle cx=\"140\" cy=\"50\" r=\"32\" fill=\"#616161\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"240\" cy=\"40\" r=\"42\" fill=\"#616161\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Main Smoke Plume (Top/Front Layer) -->\n  <circle cx=\"165\" cy=\"80\" r=\"26\" fill=\"#9E9E9E\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"235\" cy=\"60\" r=\"28\" fill=\"#9E9E9E\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"185\" cy=\"45\" r=\"38\" fill=\"#9E9E9E\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"345\" cy=\"55\" r=\"25\" fill=\"#9E9E9E\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Floating Pollution Particles -->\n  <circle cx=\"90\" cy=\"80\" r=\"6\" fill=\"#424242\"/>\n  <circle cx=\"105\" cy=\"110\" r=\"4\" fill=\"#616161\"/>\n  <circle cx=\"330\" cy=\"90\" r=\"7\" fill=\"#424242\"/>\n  <circle cx=\"360\" cy=\"110\" r=\"5\" fill=\"#616161\"/>\n  <circle cx=\"280\" cy=\"115\" r=\"6\" fill=\"#9E9E9E\"/>\n</svg>",
