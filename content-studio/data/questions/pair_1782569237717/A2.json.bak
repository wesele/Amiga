    "imagePrompt": "open laptop on desk with glowing screen showing icons and documents, wifi signal symbol floating beside it, simple flat style, white background",
    "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <!-- White Background -->\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n\n  <!-- Desk Surface -->\n  <polygon points=\"20,300 380,300 350,380 50,380\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Laptop Shadow on Desk -->\n  <ellipse cx=\"200\" cy=\"305\" rx=\"140\" ry=\"8\" fill=\"#D09070\"/>\n\n  <!-- Coffee Mug on Desk (Left) -->\n  <ellipse cx=\"65\" cy=\"300\" rx=\"12\" ry=\"4\" fill=\"#D09070\"/>\n  <path d=\"M 55,275 C 45,275 45,295 55,295\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <rect x=\"55\" y=\"270\" width=\"24\" height=\"28\" rx=\"4\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 62,260 Q 64,264 62,266 T 62,270\" fill=\"none\" stroke=\"#333333\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n\n  <!-- Laptop Screen Lid/Bezel -->\n  <rect x=\"80\" y=\"80\" width=\"240\" height=\"150\" rx=\"8\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Laptop Screen (Active Area) -->\n  <rect x=\"95\" y=\"95\" width=\"210\" height=\"120\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Folders on Screen -->\n  <!-- Folder 1 -->\n  <path d=\"M 110,115 L 110,111 L 120,111 L 123,115 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <rect x=\"110\" y=\"115\" width=\"25\" height=\"18\" rx=\"2\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Folder 2 -->\n  <path d=\"M 110,145 L 110,141 L 120,141 L 123,145 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <rect x=\"110\" y=\"145\" width=\"25\" height=\"18\" rx=\"2\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Documents on Screen -->\n  <!-- Document 1 (Center) -->\n  <rect x=\"155\" y=\"110\" width=\"65\" height=\"85\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"167\" y1=\"125\" x2=\"207\" y2=\"125\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"167\" y1=\"137\" x2=\"207\" y2=\"137\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"167\" y1=\"149\" x2=\"197\" y2=\"149\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"167\" y1=\"161\" x2=\"207\" y2=\"161\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"167\" y1=\"173\" x2=\"187\" y2=\"173\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Document 2 (Right) -->\n  <rect x=\"230\" y=\"125\" width=\"55\" height=\"70\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"240\" y1=\"140\" x2=\"275\" y2=\"140\" stroke=\"#4CAF50\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"240\" y1=\"152\" x2=\"275\" y2=\"152\" stroke=\"#4CAF50\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"240\" y1=\"164\" x2=\"265\" y2=\"164\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"240\" y1=\"176\" x2=\"270\" y2=\"176\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Laptop Hinge -->\n  <rect x=\"170\" y=\"228\" width=\"60\" height=\"14\" rx=\"2\" fill=\"#757575\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Laptop Keyboard Base -->\n  <polygon points=\"100,240 300,240 340,300 60,300\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Front Edge Thickness -->\n  <polygon points=\"60,300 340,300 340,312 60,312\" fill=\"#B0B0B0\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Keyboard Recess -->\n  <polygon points=\"120,248 280,248 296,276 104,276\" fill=\"#757575\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Keyboard Rows (Simplified) -->\n  <path d=\"M 122,253 L 278,253\" stroke=\"#333333\