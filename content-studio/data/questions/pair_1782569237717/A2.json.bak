troke-width=\"4\"/>\n    \n    <!-- Tree 2 -->\n    <line x1=\"270\" y1=\"166\" x2=\"270\" y2=\"150\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <circle cx=\"270\" cy=\"140\" r=\"16\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  </g>\n\n  <!-- Road Surface -->\n  <polygon points=\"-10,222 410,138 410,160 -10,344\" fill=\"#EEEEEE\"/>\n  \n  <!-- Curb Lines (Perspective Boundaries) -->\n  <line x1=\"-10\" y1=\"222\" x2=\"410\" y2=\"138\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <line x1=\"-10\" y1=\"344\" x2=\"410\" y2=\"160\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Road Center Dashed Line (Accent) -->\n  <line x1=\"-10\" y1=\"283\" x2=\"410\" y2=\"149\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-dasharray=\"16, 20\"/>\n\n  <!-- Red Directional Arrow (Flat on Road) -->\n  <g transform=\"translate(270, 192) rotate(-18)\">\n    <path d=\"M -45 -8 L 5 -8 L 5 -20 L 35 0 L 5 20 L 5 8 L -45 8 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  </g>\n\n  <!-- Sidewalk Lamppost -->\n  <g>\n    <path d=\"M 70 340 L 70 170 A 20 20 0 0 1 100 150\" fill=\"none\" stroke=\"#333333\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n    <path d=\"M 100 150 L 100 160\" stroke=\"#333333\" stroke-width=\"5\"/>\n    <polygon points=\"90,160 110,160 115,175 85,175\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  </g>\n\n  <!-- Simplified Person (Walking Along Sidewalk) -->\n  <g>\n    <!-- Back Arm -->\n    <path d=\"M 136 226 L 120 250 L 110 260\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M 136 226 L 120 250 L 110 260\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"10\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Back Hand -->\n    <path d=\"M 110 260 L 105 266\" fill=\"none\" stroke=\"#333333\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n    <path d=\"M 110 260 L 105 266\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n\n    <!-- Back Leg -->\n    <path d=\"M 138 275 L 120 310 L 110 338\" fill=\"none\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M 138 275 L 120 310 L 110 338\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"14\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Back Shoe -->\n    <path d=\"M 110 338 L 96 342\" fill=\"none\" stroke=\"#333333\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n\n    <!-- Front Leg -->\n    <path d=\"M 148 275 L 170 310 L 188 338\" fill=\"none\" stroke=\"#333333\" stroke-width=\"22\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M 148 275 L 170 310 L 188 338\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"14\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Front Shoe -->\n    <path d=\"M 188 338 L 204 338\" fill=\"none\" stroke=\"#333333\" stroke-width=\"14\" stroke-linecap=\"round\"/>\n\n    <!-- Torso (Jacket) -->\n    <polygon points=\"134,220 156,220 150,276 130,276\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n    <!-- Front Arm -->\n    <path d=\"M 148 226 L 168 250 L 178 260\" fill=\"none\" stroke=\"#333333\" stroke-width=\"18\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <path d=\"M 148 226 L 168 250 L 178 260\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"10\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n    <!-- Front Hand -->\n    <path d=\"M 178 260 L 183 266\" fill=\"none\" stroke=\"#333333\" stroke-width=\"16\" stroke-linecap=\"round\"/>\n    <path d=\"M 178 260 L 183 266\" fill=\"none\" stroke=\"#FFD1A9\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n\n    <!-- Head -->\n    <circle cx=\"150\" cy=\"195\" r=\"16\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\"/>\n    \n    <!-- Nose profile -->\n    <path d=\"M 163 195 L 169 198 L 163 201\" fill=\"#FFD1A9\" stro