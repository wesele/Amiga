      {
        "desc": "一辆垃圾车正在收集街道旁的垃圾桶",
        "prompt": "a large orange garbage truck collecting rubbish bins on a city street, daytime, outdoors",
        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Ground / Road Line -->\n  <line x1=\"15\" y1=\"340\" x2=\"385\" y2=\"340\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Mechanical Arm (Behind the Tipped Bin) -->\n  <polyline points=\"235 280 290 230 280 175\" fill=\"none\" stroke=\"#333333\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <polyline points=\"235 280 290 230 280 175\" fill=\"none\" stroke=\"#B0BEC5\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <circle cx=\"290\" cy=\"230\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"280\" cy=\"175\" r=\"5\" fill=\"#333333\"/>\n\n  <!-- Tipped Bin Mid-Air (Dumping Trash) -->\n  <g transform=\"translate(280, 175) rotate(-120)\">\n    <!-- Bin Body -->\n    <path d=\"M -15 -25 L 15 -25 L 11 25 L -11 25 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n    <!-- Lid (Hanging Open) -->\n    <rect x=\"17\" y=\"-25\" width=\"6\" height=\"35\" rx=\"2\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <!-- Wheels -->\n    <circle cx=\"-10\" cy=\"25\" r=\"5\" fill=\"#333333\"/>\n    <circle cx=\"10\" cy=\"25\" r=\"5\" fill=\"#333333\"/>\n    <!-- Handle -->\n    <path d=\"M -15 -15 L -20 -15 L -20 -5 L -15 -5\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  </g>\n\n  <!-- Falling Trash Particles -->\n  <circle cx=\"242\" cy=\"205\" r=\"5\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"246\" y=\"215\" width=\"8\" height=\"8\" rx=\"2\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Truck Chassis -->\n  <rect x=\"45\" y=\"308\" width=\"200\" height=\"12\" fill=\"#333333\" rx=\"3\"/>\n\n  <!-- Wheel Fenders -->\n  <path d=\"M 60 318 A 25 25 0 0 1 110 318\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 160 318 A 25 25 0 0 1 210 318\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <path d=\"M 210 318 A 25 25 0 0 1 260 318\" fill=\"none\" stroke=\"#333333\" stroke-width=\"4\"/>\n\n  <!-- Truck Wheels -->\n  <!-- Front Wheel -->\n  <circle cx=\"85\" cy=\"318\" r=\"22\" fill=\"#333333\"/>\n  <circle cx=\"85\" cy=\"318\" r=\"9\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Mid Wheel -->\n  <circle cx=\"185\" cy=\"318\" r=\"22\" fill=\"#333333\"/>\n  <circle cx=\"185\" cy=\"318\" r=\"9\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Rear Wheel -->\n  <circle cx=\"235\" cy=\"318\" r=\"22\" fill=\"#333333\"/>\n  <circle cx=\"235\" cy=\"318\" r=\"9\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Truck Cabin -->\n  <path d=\"M 50 310 L 50 240 L 75 200 L 115 200 L 115 310 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Cabin Window -->\n  <path d=\"M 75 210 L 105 210 L 105 250 L 58 250 Z\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Window Shine -->\n  <polygon points=\"80 215 90 215 78 245 68 245\" fill=\"#FFFFFF\"/>\n  <!-- Door Handle -->\n  <rect x=\"95\" y=\"265\" width=\"8\" height=\"4\" rx=\"1\" fill=\"#333333\"/>\n  <!-- Headlight -->\n  <rect x=\"42\" y=\"270\" width=\"8\" height=\"15\" rx=\"2\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <!-- Bumper -->\n  <rect x=\"35\" y=\"298\" width=\"15\" height=\"12\" rx=\"3\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Warning Light on Cabin Roof -->\n  <rect x=\"85\" y=\"192\" width=\"14\" height=\"8\" fill=\"#333333\"/>\n  <path d=\"M 86 192 A 6 6 0 0 1 98 192 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\"/>\n\n  <!-- Truck Compactor Body -->\n  <rect x=\"115\" y=\"160\" width=\"110\" height=\"150\" rx=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Vertical Ribs for Texture -->\n  <rect x=\"135\" y=\"175\" width=\"12\" height=\"120\" rx=\"3\" fill=\"#FFA000\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"165\" y=\"175\" width=\"12\" height=\"120\" rx=\"3\" fill=\"#FFA000\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"195\" y=\"175\" width=\"12\" height=\"120\" rx=\"3\" fill=\"#FFA000\" stroke=\"#333333\" stroke-width=\"3\"/>\n  \n  <!-- Eco/Recycling Emblem -->\n  <circle cx=\"165\" cy=\"235\" r=\"18\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"165\" cy=\"235\" r=\"10\" fill=\"#4CAF50\"/>\n\n  <!-- Hopper/Rear Loader Section -->\n  <path d=\"M 225 190 L 260 230 L 260 310 L 225 310 Z\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Dark Hopper Opening -->\n  <path d=\"M 240 230 L 255 245 L 255 295 L 240 295 Z\" fill=\"#333333\" rx=\"2\"/>\n\n  <!-- Standing Bin (On the Right) -->\n  <!-- Bin Body -->\n  <path d=\"M 330 280 L 360 280 L 356 333 L 334 333 Z\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <!-- Lid -->\n  <rect x=\"326\" y=\"272\" width=\"38\" height=\"8\" rx=\"2\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <!-- Handle -->\n  <path d=\"M 328 288 L 323 288 L 323 298 L 328 298\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <!-- Wheels -->\n  <circle cx=\"338\" cy=\"335\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"352\" cy=\"335\" r=\"5\" fill=\"#333333\"/>\n</svg>",
