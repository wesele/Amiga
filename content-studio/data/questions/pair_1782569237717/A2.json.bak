        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Floor Line -->\n  <line x1=\"20\" y1=\"335\" x2=\"380\" y2=\"335\" stroke=\"#333333\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Red Cross on Wall -->\n  <path d=\"M 195 45 h 10 v 10 h 10 v 10 h -10 v 10 h -10 v -10 h -10 v -10 h 10 z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Rolling Medical Tray -->\n  <rect x=\"47\" y=\"200\" width=\"6\" height=\"125\" fill=\"#333333\" rx=\"3\"/>\n  <path d=\"M 30 325 L 70 325\" stroke=\"#333333\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n  <circle cx=\"35\" cy=\"331\" r=\"5\" fill=\"#333333\"/>\n  <circle cx=\"65\" cy=\"331\" r=\"5\" fill=\"#333333\"/>\n  <rect x=\"28\" y=\"190\" width=\"44\" height=\"10\" rx=\"3\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"33\" y=\"170\" width=\"12\" height=\"20\" rx=\"2\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"36\" y=\"166\" width=\"6\" height=\"4\" fill=\"#333333\"/>\n  <rect x=\"50\" y=\"175\" width=\"14\" height=\"15\" rx=\"2\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"54\" y=\"171\" width=\"6\" height=\"4\" fill=\"#333333\"/>\n\n  <!-- Medical Exam Table -->\n  <rect x=\"235\" y=\"245\" width=\"12\" height=\"90\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"313\" y=\"245\" width=\"12\" height=\"90\" fill=\"#E0E0E0\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <rect x=\"220\" y=\"245\" width=\"120\" height=\"65\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <line x1=\"230\" y1=\"275\" x2=\"330\" y2=\"275\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <circle cx=\"280\" cy=\"260\" r=\"3\" fill=\"#333333\"/>\n  <circle cx=\"280\" cy=\"290\" r=\"3\" fill=\"#333333\"/>\n  <rect x=\"210\" y=\"230\" width=\"140\" height=