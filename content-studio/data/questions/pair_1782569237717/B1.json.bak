  {
    "id": "pair_1782569237717-B1-U01-S06-010",
    "type": "T12",
    "typeName": "情景回应",
    "language": "en",
    "cefr": "B1",
    "unit": "U01",
    "unitTheme": "Personal Information and Everyday Contact",
    "difficulty": 3,
    "tags": [
      "polite expressions",
      "apology",
      "requesting",
      "appreciation"
    ],
    "scenario": "在小组讨论中，你不小心打断了同学A的发言。此时你想道歉，表达对他观点的欣赏，并请他继续说完。",
    "options": [
      "I'm sorry, but I don't think what you said is correct.",
      "I apologize for interrupting. Would you mind continuing? I really appreciate your perspective.",
      "Sorry I interrupted, but let me finish what I want to say first."
    ],
    "answerIdx": 1,
    "pragmaticsNote": "在社交场合打断别人后，应先真诚道歉，然后使用礼貌请求（如 Would you mind...?）让对方继续，同时表达对对方观点的欣赏（appreciate），体现尊重和积极互动。选项B和C均不尊重对方的发言机会，语用不当。",
    "pairId": "pair_1782569237717",
    "sectionId": "pair_1782569237717/U01-S06"
  },
