        "imageSvg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 400 400\" width=\"400\" height=\"400\">\n  <rect width=\"400\" height=\"400\" fill=\"#FFFFFF\"/>\n  \n  <!-- Wall Picture Frame (Indoor Decor) -->\n  <rect x=\"50\" y=\"60\" width=\"70\" height=\"90\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"4\"/>\n  <circle cx=\"75\" cy=\"90\" r=\"8\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n  <polygon points=\"55,145 80,115 105,145\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  <polygon points=\"80,145 100,125 120,145\" fill=\"#4CAF50\" stroke=\"#333333\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n  \n  <!-- Table Legs -->\n  <polygon points=\"75,345 75,385 90,385 95,345\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  <polygon points=\"325,345 310,385 325,385 325,345\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Table Top Shadow -->\n  <path d=\"M 50 330 L 350 330 L 340 345 L 60 345 Z\" fill=\"#E5B285\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Table Top Surface -->\n  <path d=\"M 30 270 L 370 270 L 350 330 L 50 330 Z\" fill=\"#FFD1A9\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n\n  <!-- Device Shadows on Table -->\n  <ellipse cx=\"125\" cy=\"275\" rx=\"45\" ry=\"8\" fill=\"#E5B285\"/>\n  <ellipse cx=\"285\" cy=\"270\" rx=\"38\" ry=\"8\" fill=\"#E5B285\"/>\n\n  <!-- Bluetooth Wireless Signals & Logo -->\n  <!-- Left Waves (propagating from phone) -->\n  <path d=\"M 191 187 Q 183 195 191 203\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 181 179 Q 170 195 181 211\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 171 171 Q 157 195 171 219\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Right Waves (propagating to speaker) -->\n  <path d=\"M 219 187 Q 227 195 219 203\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 229 179 Q 240 195 229 211\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  <path d=\"M 239 171 Q 253 195 239 219\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n\n  <!-- Bluetooth Icon -->\n  <path d=\"M 199 187 L 211 203 L 205 210 L 205 180 L 211 187 L 199 203\" fill=\"none\" stroke=\"#4A90D9\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n  <!-- Smartphone (Leaning Left) -->\n  <g transform=\"rotate(-6 125 270)\">\n    <!-- Phone Body -->\n    <rect x=\"85\" y=\"120\" width=\"80\" height=\"150\" rx=\"12\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n    <!-- Screen -->\n    <rect x=\"91\" y=\"128\" width=\"68\" height=\"134\" rx=\"8\" fill=\"#FFFFFF\"/>\n    <!-- Camera Notch -->\n    <rect x=\"115\" y=\"132\" width=\"20\" height=\"5\" rx=\"2.5\" fill=\"#333333\"/>\n    <!-- Music Album Art -->\n    <rect x=\"100\" y=\"145\" width=\"50\" height=\"50\" rx=\"6\" fill=\"#FFC107\" stroke=\"#333333\" stroke-width=\"3\"/>\n    <circle cx=\"125\" cy=\"170\" r=\"10\" fill=\"#FFFFFF\" stroke=\"#333333\" stroke-width=\"2.5\"/>\n    <!-- Progress Bar -->\n    <line x1=\"100\" y1=\"212\" x2=\"150\" y2=\"212\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n    <circle cx=\"120\" cy=\"212\" r=\"4.5\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2\"/>\n    <!-- Play Button -->\n    <circle cx=\"125\" cy=\"236\" r=\"11\" fill=\"#4A90D9\" stroke=\"#333333\" stroke-width=\"2.5\"/>\n    <polygon points=\"123,231 123,241 131,236\" fill=\"#FFFFFF\"/>\n    <!-- Home Bar -->\n    <line x1=\"112\" y1=\"256\" x2=\"138\" y2=\"256\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  </g>\n\n  <!-- Compact Bluetooth Speaker -->\n  <!-- Speaker Strap -->\n  <path d=\"M 325 195 Q 345 205 325 215\" fill=\"none\" stroke=\"#333333\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n  <path d=\"M 325 195 Q 345 205 325 215\" fill=\"none\" stroke=\"#FFC107\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n  \n  <!-- Speaker Cylinder Body -->\n  <path d=\"M 245 185 L 245 260 C 245 272, 325 272, 325 260 L 325 185 Z\" fill=\"#E53935\" stroke=\"#333333\" stroke-width=\"4\" stroke-linejoin=\"round\"/>\n  \n  <!-- Speaker Top Cap -->\n  <ellipse cx=\"285\" cy=\"185\" rx=\"40\" ry=\"10\" fill=\"#333333\" stroke=\"#333333\" stroke-width=\"4\"/>\n  \n  <!-- Speaker Grill Lines (Perspective curves) -->\n  <path d=\"M 245 205 Q 285 215 325 205\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 245 220 Q 285 230 325 220\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 245 235 Q 285 245 325 235\" fill=\"none\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Speaker Status Light -->\n  <circle cx=\"285\" cy=\"254\" r=\"3.5\" fill=\"#4A90D9\"/>\n\n  <!-- Music Notes (Audio Output) -->\n  <!-- Note 1 -->\n  <circle cx=\"342\" cy=\"145\" r=\"5\" fill=\"#333333\"/>\n  <line x1=\"347\" y1=\"145\" x2=\"347\" y2=\"125\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"347\" y1=\"125\" x2=\"357\" y2=\"122\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Note 2 -->\n  <circle cx=\"285\" cy=\"130\" r=\"5\" fill=\"#333333\"/>\n  <line x1=\"290\" y1=\"130\" x2=\"290\" y2=\"110\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <line x1=\"290\" y1=\"110\" x2=\"300\" y2=\"107\" stroke=\"#333333\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n\n  <!-- Sound/Vibration Accents -->\n  <path d=\"M 335 175 L 345 170\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path d=\"M 340 230 L 350 235\" stroke=\"#FFC107\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n  <path 